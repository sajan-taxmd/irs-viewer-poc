<?xml version="1.0" encoding="UTF-8"?>
<xsd:schema xmlns="http://www.irs.gov/efile" xmlns:xsd="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.irs.gov/efile" elementFormDefault="qualified" attributeFormDefault="unqualified" version="1.0">
	<xsd:annotation>
		<xsd:documentation>
			<Description>IRS e-file Schema - Form 7207 - Advanced Manufacturing Production Credit</Description>
			<TaxYear>2025</TaxYear>
			<MaturityLevel>Final Release</MaturityLevel>
			<ReleaseDate>February 19 2026</ReleaseDate>
		</xsd:documentation>
	</xsd:annotation>

	<xsd:include schemaLocation="../../Common/efileTypes.xsd"/>

	<!-- =========================================================== -->
	<!-- =====================  IRS Form 7207  ===================== -->
	<!-- =========================================================== -->

	<xsd:element name="IRS7207">
		<xsd:annotation>
			<xsd:documentation>IRS Form 7207 - Advanced Manufacturing Production Credit</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:complexContent>
				<xsd:extension base="IRS7207Type">
					<xsd:attributeGroup ref="DocumentAttributes">
						<xsd:annotation>
							<xsd:documentation>Common return document attributes</xsd:documentation>
						</xsd:annotation>
					</xsd:attributeGroup>
					<xsd:attribute name="documentName" type="TextType" fixed="IRS7207">
						<xsd:annotation>
							<xsd:documentation>IRS internal use only. To avoid error in the return, do not include the attribute name or value.</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
					<xsd:attribute name="referenceDocumentId" type="IdListType">
						<xsd:annotation>
							<xsd:documentation>List of document ID's of forms, schedules, supporting info. etc. attached to this form</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
					<xsd:attribute name="referenceDocumentName" type="TextType" fixed="BinaryAttachment GeneralDependencySmall"/>
				</xsd:extension>
			</xsd:complexContent>
		</xsd:complexType>
	</xsd:element>

	<xsd:complexType name="IRS7207Type">
		<xsd:sequence>

			<!-- =============== Part I Facility Information =============== -->

			<!-- IRS-issued registration number for the facility -->
			<xsd:element name="FacilityIRSIssdRegistrationNum" type="FacilityIRSIssdRegistrationNumType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>IRS-issued registration number for the facility</Description>
						<LineNumber>Part I Line 1</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Date the facility was placed in service -->
			<xsd:element name="FacilityPlacedInServiceDt" type="DateType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Date the facility was placed in service</Description>
						<LineNumber>Part I Line 2</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Address of facility -->
			<xsd:element name="FacilityUSAddress" type="USAddressType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Address of facility</Description>
						<LineNumber>Part I Line 3a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Facility Description -->
			<xsd:element name="FacilityDesc" type="ShortExplanationType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Facility Description</Description>
						<LineNumber>Part I Line 3a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<xsd:choice minOccurs="0">
				<xsd:sequence>
					<!-- If different than filer, enter owner's person name -->
					<xsd:element name="FacilityOwnerPersonNm" type="PersonNameType">
						<xsd:annotation>
							<xsd:documentation>
								<Description>If different than filer, enter owner's person name</Description>
								<LineNumber>Part I Line 3b (i)</LineNumber>
							</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<!-- If different than filer, enter owner's SSN -->
					<xsd:element name="FacilityOwnerSSN" type="SSNType">
						<xsd:annotation>
							<xsd:documentation>
								<Description>If different than filer, enter owner's SSN</Description>
								<LineNumber>Part I Line 3b (ii)</LineNumber>
							</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
				</xsd:sequence>
				
				<xsd:sequence>
					<!-- If different than filer, enter owner's business name -->
					<xsd:element name="FacilityOwnerBusinessName" type="BusinessNameType">
						<xsd:annotation>
							<xsd:documentation>
								<Description>If different than filer, enter owner's business name</Description>
								<LineNumber>Part I Line 3b (i)</LineNumber>
							</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<!-- If different than filer, enter owner's EIN -->
					<xsd:element name="FacilityOwnerEIN" type="EINType">
						<xsd:annotation>
							<xsd:documentation>
								<Description>If different than filer, enter owner's EIN</Description>
								<LineNumber>Part I Line 3b (ii)</LineNumber>
							</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
				</xsd:sequence>
			</xsd:choice>

			<!-- Location coordinates (Latitude) -->
			<xsd:element name="FacilityLatitudeNum" type="LatitudeCoordinateType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Location coordinates (Latitude)</Description>
						<LineNumber>Part I Line 4 (i)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Location coordinates (Longitude) -->
			<xsd:element name="FacilityLongitudeNum" type="LongitudeCoordinateType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Location coordinates (Longitude)</Description>
						<LineNumber>Part I Line 4 (ii)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Election under section 45X(a)(3)(B) -->
			<xsd:element name="Section45Xa3BElectionInd" type="BooleanType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Election under section 45X(a)(3)(B)</Description>
						<LineNumber>Part I, Line 5</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Eligible components include property produced at a facility taken into account for which a credit under section 48C is being claimed -->
			<xsd:element name="Section48CEligiblePropertyInd" type="BooleanType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Eligible components include property produced at a facility taken into account for which a credit under section 48C is being claimed</Description>
						<LineNumber>Part I, Line 6</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- =============== Part II Eligible Components =============== -->

			<!-- Solar Energy Components - Part II, Line 1 -->

			<!-- Thin film photovoltaic cell or crystalline photovoltaic cell -->
			<xsd:element name="PhotovoltaicCellGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Thin film photovoltaic cell or crystalline photovoltaic cell</Description>
						<LineNumber>Part II, Line 1a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Photovoltaic wafer -->
			<xsd:element name="PhotovoltaicWaferGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Photovoltaic wafer</Description>
						<LineNumber>Part II, Line 1b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Solar grade polysilicon -->
			<xsd:element name="SolarGradePolysiliconGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Solar grade polysilicon</Description>
						<LineNumber>Part II, Line 1c</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Polymeric backsheet -->
			<xsd:element name="PolymericBacksheetGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Polymeric backsheet</Description>
						<LineNumber>Part II, Line 1d</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Solar module -->
			<xsd:element name="SolarModuleGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Solar module</Description>
						<LineNumber>Part II, Line 1e</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Torque tube -->
			<xsd:element name="TorqueTubeGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Torque tube</Description>
						<LineNumber>Part II, Line 1f</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Structural fastener -->
			<xsd:element name="StructuralFastenerGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Structural fastener</Description>
						<LineNumber>Part II, Line 1g</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Wind Energy Components - Part II, Line 2 -->

			<!-- Part II, Line 2a column (d) - Not in XML. Use value from Part III TotalSalesPriceAmt; Comment in schema. -->

			<!-- Amount of Credit related to offshore wind vessel(s) -->
			<xsd:element name="RelatedOffshoreWindVesselCrAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Amount of Credit related to offshore wind vessel(s)</Description>
						<LineNumber>Part II, Line 2a column (e)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Blade -->
			<xsd:element name="BladeGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Blade</Description>
						<LineNumber>Part II, Line 2b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Nacelle -->
			<xsd:element name="NacelleGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Nacelle</Description>
						<LineNumber>Part II, Line 2c</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Tower -->
			<xsd:element name="TowerGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Tower</Description>
						<LineNumber>Part II, Line 2d</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Offshore wind foundation which uses a fixed platform -->
			<xsd:element name="OffshoreWindFndtnFxdPltfGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Offshore wind foundation which uses a fixed platform</Description>
						<LineNumber>Part II, Line 2e</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Offshore wind foundation which uses a floating platform -->
			<xsd:element name="OffshoreWindFndtnFloatPltfGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Offshore wind foundation which uses a floating platform</Description>
						<LineNumber>Part II, Line 2f</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Inverter Components - Part II, Line 3 -->

			<!-- Central inverter -->
			<xsd:element name="CentralInverterGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Central inverter</Description>
						<LineNumber>Part II, Line 3a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Utility inverter -->
			<xsd:element name="UtilityInverterGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Utility inverter</Description>
						<LineNumber>Part II, Line 3b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Commercial inverter -->
			<xsd:element name="CommercialInverterGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Commercial inverter</Description>
						<LineNumber>Part II, Line 3c</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Residential inverter -->
			<xsd:element name="ResidentialInverterGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Residential inverter</Description>
						<LineNumber>Part II, Line 3d</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Microinverter -->
			<xsd:element name="MicroinverterGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Microinverter</Description>
						<LineNumber>Part II, Line 3e</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Distributed wind inverter -->
			<xsd:element name="DistributedWindInverterGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Distributed wind inverter</Description>
						<LineNumber>Part II, Line 3f</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Electrode Active Materials - Part II, Line 4 -->

			<!-- Electrode active materials -->
			<xsd:element name="ElectrodeActiveMaterialsGrp" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Electrode active materials</Description>
						<LineNumber>Part II, Line 4a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence>

						<!-- Costs Incurred Amount -->
						<xsd:element name="CostsIncurredAmt" type="USAmountNNType">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Costs Incurred Amount</Description>
									<LineNumber>Part II, Line 4a column (d)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Amount of Credit -->
						<xsd:element name="CreditAmt" type="USAmountNNType">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amount of Credit</Description>
									<LineNumber>Part II, Line 4a column (e)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>

			<!-- Battery Components - Part II, Line 5 -->

			<!-- Battery Cell -->
			<xsd:element name="BatteryCellGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Battery Cell</Description>
						<LineNumber>Part II, Line 5a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Battery module which uses battery cells -->
			<xsd:element name="BatteryModUseBatteryCellGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Battery module which uses battery cells</Description>
						<LineNumber>Part II, Line 5b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Battery module which does not use battery cells -->
			<xsd:element name="BatteryModNotUseBatteryCellGrp" type="NumberUnitsCreditAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Battery module which does not use battery cells</Description>
						<LineNumber>Part II, Line 5c</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Critical Minerals - Part II, Line 6 -->

			<!-- Part II, Line 6a column (d) - Not in XML.  Use value from Part IV Line 74; Comment in schema. -->
  
			<!-- Amount of Credit for applicable critical minerals -->
			<xsd:element name="ApplcblCriticalMineralsCrAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Amount of Credit for applicable critical minerals</Description>
						<LineNumber>Part II, Line 6a column (e)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- Metallurgical Coal Group -->
			<xsd:element name="MetallurgicalCoalGrp" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Metallurgical Coal Group</Description>
						<LineNumber>Part II, Line 6b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence>

						<!-- Total Costs -->
						<xsd:element name="TotalCostsAmt" type="USAmountNNType">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Total Costs</Description>
									<LineNumber>Part II, Line 6b column (d)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Amount of Credit -->
						<xsd:element name="CreditAmt" type="USAmountNNType">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amount of Credit</Description>
									<LineNumber>Part II, Line 6b column (e)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>

			<!-- Advanced Manufacturing Production Credit From Other Entities - Part II, Line 7 -->

			<!-- Advanced manufacturing production credit from partnerships, S corporations, estates, and trusts -->
			<xsd:element name="AdvncMfrPrdCrOthEntitiesAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Advanced manufacturing production credit from partnerships, S corporations, estates, and trusts</Description>
						<LineNumber>Part II Line 7</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Advanced Manufacturing Production Credit - Part II, Line 8 -->

			<!-- Add amounts in column (e), of lines specified.  Estates and trusts go to specified line.  Partnerships and S corporations, stop here and report this amount on Schedule K.  All others, stop here and report this amount on Form 3800, on specified line -->
			<xsd:element name="AdvncManufacturingProdCrAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Add amounts in column (e), of lines specified.  Estates and trusts go to specified line.  Partnerships and S corporations, stop here and report this amount on Schedule K.  All others, stop here and report this amount on Form 3800, on specified line</Description>
						<LineNumber>Part II Line 8a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Amount allocated to beneficiaries of the estate or trust -->
			<xsd:element name="EstateOrTrustAllocatedBenefAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Amount allocated to beneficiaries of the estate or trust</Description>
						<LineNumber>Part II Line 8b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Estates and trusts, subtract specified lines.  Report this amount on specified line of the Form 3800. -->
			<xsd:element name="EstateTrustAdvncMfrProdCrAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Estates and trusts, subtract specified lines.  Report this amount on specified line of the Form 3800.</Description>
						<LineNumber>Part II Line 8c</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- =============== Part III Related Offshore Wind Vessels =============== -->

			<!-- Offshore wind vessels group -->
			<xsd:element name="OffshoreWindVesselsGrp" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Offshore wind vessels group</Description>
						<LineNumber>Part III</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:sequence>

						<!-- Name of Vessel -->
						<xsd:element name="VesselNm" type="LineExplanationType">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Name of Vessel</Description>
									<LineNumber>Part III, column 1</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Purpose of vessel -->
						<xsd:element name="VesselPurposeDesc" type="ShortExplanationType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Purpose of vessel</Description>
									<LineNumber>Part III, column 2</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Official number of vessel -->
						<xsd:element name="VesselNum" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Official number of vessel</Description>
									<LineNumber>Part III, column 3</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="TextType">
									<xsd:maxLength value="50"/>
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:element>

						<xsd:choice minOccurs="0">
							<!-- New -->
							<xsd:element name="NewInd" type="CheckboxType">
								<xsd:annotation>
									<xsd:documentation>
										<Description>New</Description>
										<LineNumber>Part III, column 4</LineNumber>
									</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<!-- Retrofitted -->
							<xsd:element name="RetrofittedInd" type="CheckboxType">
								<xsd:annotation>
									<xsd:documentation>
										<Description>Retrofitted</Description>
										<LineNumber>Part III, column 4</LineNumber>
									</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
						</xsd:choice>

						<!-- Sales Price -->
						<xsd:element name="SalesPriceAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Sales Price</Description>
									<LineNumber>Part III, column 5</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>

			<!-- Total of All Parts III -->
			<xsd:element name="TotalSalesPriceAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of All Parts III</Description>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- =============== Part IV Costs of Producing Applicable Critical Minerals in Current Tax Year =============== -->

			<!-- Aluminum converted from bauxite to a minimum purity of 99% alumina by mass -->
			<xsd:element name="AluminumConvertedCostsAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Aluminum converted from bauxite to a minimum purity of 99% alumina by mass</Description>
						<LineNumber>Part IV, Line 1</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Aluminum purified to a minimum purity of 99.9% aluminum by mass -->
			<xsd:element name="AluminumPurifiedCostsAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Aluminum purified to a minimum purity of 99.9% aluminum by mass</Description>
						<LineNumber>Part IV, Line 2</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Antimony converted to antimony trisulfide concentrate with a minimum purity of 90% antimony trisulfide by mass -->
			<xsd:element name="AntimonyConvertedCostsAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Antimony converted to antimony trisulfide concentrate with a minimum purity of 90% antimony trisulfide by mass</Description>
						<LineNumber>Part IV, Line 3</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Antimony purified to a minimum purity of 99.65% antimony by mass -->
