<?xml version="1.0" encoding="UTF-8"?>
<!-- edited with XMLSpy v2025 rel. 2 (x64) (https://www.altova.com) by Internal Revenue Service (Internal Revenue Service) -->
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns="http://www.irs.gov/efile" targetNamespace="http://www.irs.gov/efile" elementFormDefault="qualified" attributeFormDefault="unqualified">
	<xsd:annotation>
		<xsd:documentation>
			<Description>IRS e-file Schema - Form 3800</Description>
			<TaxYear>2025</TaxYear>
			<MaturityLevel>Final Release</MaturityLevel>
			<ReleaseDate>February 19 2026</ReleaseDate>
		</xsd:documentation>
	</xsd:annotation>
	<xsd:include schemaLocation="../../../Common/efileTypes.xsd"/>
	<!-- ================================================================ -->
	<!-- ======================  IRS Form 3800 ========================== -->
	<!-- ================================================================ -->
	<xsd:element name="IRS3800">
		<xsd:annotation>
			<xsd:documentation>IRS Form 3800</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:complexContent>
				<xsd:extension base="IRS3800Type">
					<xsd:attributeGroup ref="DocumentAttributes">
						<xsd:annotation>
							<xsd:documentation>Common return document attributes</xsd:documentation>
						</xsd:annotation>
					</xsd:attributeGroup>
					<xsd:attribute name="documentName" type="xsd:string" fixed="IRS3800">
						<xsd:annotation>
							<xsd:documentation>IRS internal use only. To avoid error in the return, do not include the attribute name or value.</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
					<xsd:attribute name="referenceDocumentId" type="IdListType">
						<xsd:annotation>
							<xsd:documentation>List of document ID's of forms, schedules, supporting info. etc. attached to this form</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
					<xsd:attribute name="referenceDocumentName" type="StringType" fixed="GeneralDependencySmall"/>
				</xsd:extension>
			</xsd:complexContent>
		</xsd:complexType>
	</xsd:element>
	<xsd:complexType name="IRS3800Type">
		<xsd:annotation>
			<xsd:documentation>Content model for Form 3800</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<!-- Are you both an "applicable corporation" within the meaning of IRC 59(k)(1) for the CAMT and (b) an "applicable taxpayer" within the meaning of IRC 59A(e ) for the BEAT? -->
			<xsd:element name="CAMTAndBEATInd" type="BooleanType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Are you both an "applicable corporation" within the meaning of IRC 59(k)(1) for the CAMT and (b) an "applicable taxpayer" within the meaning of IRC 59A(e ) for the BEAT?</Description>
						<LineNumber>Line A</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Was an entry made in the specified part and column? -->
			<xsd:element name="CreditTransferElectionInd" type="BooleanType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Was an entry made in the specified part and column?</Description>
						<LineNumber>Line B(i)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- The number of Schedule(s) A (Form 3800), Transfer Election Statement Summary, attached to your return. -->
			<xsd:element name="TransferElectionStatementCnt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>The number of Transfer Election Statements attached to your return.</Description>
						<LineNumber>Line B(ii)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="IntegerPosType10">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="BinaryAttachment"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Part I -->
			<!-- General Business Credit From Non Passive Activity -->
			<xsd:element name="GeneralBusCrFromNnPssvActyAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>General business credit from non passive activity</Description>
						<LineNumber>Part I, line 1</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Credits subject to passive activity limit -->
			<xsd:element name="CrSubjToPassiveActyLmtAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Passive activity credits included from line 2</Description>
						<LineNumber>Part I, line 2</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Passive Activity Credits Allowed for the Current Year -->
			<xsd:element name="PssvActyForGenBusCrAllowedAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Passive activity credits allowed for the current year</Description>
						<LineNumber>Part I, line 3</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Carryforward of General Business Credit from the Current Year -->
			<xsd:element name="CYGeneralBusCrCarryforwardAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Carryforward of general business credit from the current year</Description>
						<LineNumber>Part I, line 4</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="USAmountType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="CarryforwardGeneralBusinessCr"/>
							<xsd:attribute name="carryforwardChgdOrRevsInd" type="CheckboxType">
								<xsd:annotation>
									<xsd:documentation>
										<Description>Indicates current year carryforward amount was changed or revised from original amount</Description>
									</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Carryback of General Business Credit -->
			<xsd:element name="CarryBackGeneralBusinessCrAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Carryback of general business credit</Description>
						<LineNumber>Part I, line 5</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Current Year Credits Not Allowed Against TMT Amount -->
			<xsd:element name="CYCreditsNotAllwAgainstTMTAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Current year credits not allowed against TMT amount</Description>
						<LineNumber>Part I, line 6</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Part II Section A -->
			<!-- Regular Tax Before Credits -->
			<xsd:element name="RegularTaxBeforeCreditsAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Regular tax before credits</Description>
						<LineNumber>Part II, line 7</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Alternative Minimum Tax -->
			<xsd:element name="AlternativeMinimumTaxAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Alternative minimum tax</Description>
						<LineNumber>Part II, line 8</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Sum of Regular Tax Before Credits and AMT -->
			<xsd:element name="AdjustedRegTaxBeforeCreditAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Sum of regular tax before credits and AMT</Description>
						<LineNumber>Part II, line 9</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Foreign Tax Credit -->
			<xsd:element name="ForeignTaxCreditAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Foreign tax credit</Description>
						<LineNumber>Part II, line 10a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Certain Allowable Credits -->
			<xsd:element name="CertainAllowableCreditsAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Certain allowable credits</Description>
						<LineNumber>Part II, line 10b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Sum of Foreign and Personal Tax Credits -->
			<xsd:element name="TotalTaxCreditsAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Sum of foreign and personal tax credits</Description>
						<LineNumber>Part II, line 10c</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Net Income Tax -->
			<xsd:element name="NetIncomeTaxAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Net income tax</Description>
						<LineNumber>Part II, line 11</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Net Regular Tax; if zero or less, enter -0- -->
			<xsd:element name="NetRegularTaxAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Net regular tax; if zero or less, enter -0-</Description>
						<LineNumber>Part II, line 12</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Percent Excess of Net Regular Tax, if any -->
			<xsd:element name="ExcessNetRegularTaxAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Percent Excess of Net Regular Tax, if any</Description>
						<LineNumber>Part II, line 13</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Tentative Minimum Tax -->
			<xsd:element name="TentativeMinimumTaxAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Tentative minimum tax</Description>
						<LineNumber>Part II, line 14</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Greater of Percent Excess or TMT -->
			<xsd:element name="AdjustedExcessNetRegularTaxAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Greater of percent excess or TMT</Description>
						<LineNumber>Part II, line 15</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Subtract Greater of Excess From Net Income Tax.  If Zero or Less, Enter -0- -->
			<xsd:element name="AdjustedNetIncomeTaxAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Subtract greater of excess from net income tax.  If zero or less, enter -0-</Description>
						<LineNumber>Part II, line 16</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Smaller of CY Credits Not Allowed TMT Or Total Adjusted Amount -->
			<xsd:element name="SmllrCYNotAllwTMTOrTotAdjAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Smaller of CY credits not allowed TMT or total adjusted amount</Description>
						<LineNumber>Part II, line 17</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="USAmountType">
							<xsd:attribute name="section383Or384IndicatorCd">
								<xsd:simpleType>
									<xsd:restriction base="TextType">
										<xsd:enumeration value="SEC 383"/>
										<xsd:enumeration value="SEC 384"/>
									</xsd:restriction>
								</xsd:simpleType>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Part II Section B -->
			<!-- Tentative Minimun Tax Times Percent Amount -->
			<xsd:element name="TentativeMinimunTaxTimesPctAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Tentative minimun tax times percent amount</Description>
						<LineNumber>Part II, line 18</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Greater Excess Or Times Percent Amount -->
			<xsd:element name="GreaterExcessOrTimesPctAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Greater excess or times percent amount</Description>
						<LineNumber>Part II, line 19</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Net Income Tax less Greater Excess Amount; If Zero Or Less, Enter -0- -->
			<xsd:element name="NetIncmTaxLessGreaterExcessAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Net income tax less greater excess amount; if zero or less, enter -0-</Description>
						<LineNumber>Part II, line 20</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Subtract Smaller From Net Less Greater Amount; If Zero or Less, Enter -0- -->
			<xsd:element name="SubSmllrFromNetLessGreaterAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Subtract smaller from net less greater amount; if zero or less, enter -0-</Description>
						<LineNumber>Part II, line 21</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Empowerment Zone General Business Credits Amount -->
			<xsd:element name="TotEmpwrZoneGenBusCreditsAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total empowerment zone general business credits amount</Description>
						<LineNumber>Part II, line 22</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- GBC From Passive Activity - All Parts -->
			<xsd:element name="GBCFromPssvActyAllPartsAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>GBC from passive activity - all parts</Description>
						<LineNumber>Part II, line 23</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Passive Activity Credit Allowed for Tax Year -->
			<xsd:element name="PassiveActyAllowedForTYAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Passive activity credit allowed for tax year</Description>
						<LineNumber>Part II, line 24</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Passive Activity Credit for Tax Year -->
			<xsd:element name="TotalPassiveActivityCreditAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total passive activity credit for tax year</Description>
						<LineNumber>Part II, line 25</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Empowerment Zone and Community Employment Credit -->
			<xsd:element name="EmpwrZoneAndComEmploymentCrAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Empowerment zone and community employment credit</Description>
						<LineNumber>Part II, line 26</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Part II Section C -->
			<!-- Net Income Tax Less Percent Excess Amount -->
			<xsd:element name="NetIncomeTaxLessPctExcessAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Net income tax less percent excess amount</Description>
						<LineNumber>Part II, line 27</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Sum Smaller And Empowerment Zone Employment Credit Amount -->
			<xsd:element name="SumSmllrEmpwrZnEmplmnCrAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Sum smaller and empowerment zone employment credit amount</Description>
						<LineNumber>Part II, line 28</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Net Smaller And Empowerment Zone Employment Credit Amount; If Zero Or Less, Enter -0- -->
			<xsd:element name="NetSmllrAndEmpwrZnEmplmnCrAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Net smaller and empowerment zone employment credit amount; if zero or less, enter -0-</Description>
						<LineNumber>Part II, line 29</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Allowed General Business Credit From Non Passive Activity Amount -->
			<xsd:element name="AllwGenBusCrFromNonPssvActyAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Allowed general business credit from non passive activity amount</Description>
						<LineNumber>Part II, line 30</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Reserved - Part II, line 31 -->
			<!-- General Business Passive Activity Credit Amount -->
			<xsd:element name="GenBusEligSmllBusPssvActyCrAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>General business passive activity credit amount</Description>
						<LineNumber>Part II, line 32</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Other Specified Allowable General Business Credit -->
			<xsd:element name="OtherSpecifiedAllwGenBusCrAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Other specified allowable general business credit</Description>
						<LineNumber>Part II, line 33</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Allowed General And Eligible Smaller Business Carryforward Credit Amount -->
			<xsd:element name="AllwGenAndEligSmllBusCfwdCrAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Allowed general and eligible smaller business carryforward credit amount</Description>
						<LineNumber>Part II, line 34</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="USAmountNNType">
							<xsd:attribute name="carryforwardChgdOrRevsInd" type="CheckboxType">
								<xsd:annotation>
									<xsd:documentation>
										<Description>Indicates allowed carryforward amount was changed or revised from original amount</Description>
									</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Allowed General Business Carryback Credit Amount -->
			<xsd:element name="AllwGenAndEligSmllBusCybkCrAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Allowed general business carryback credit amount</Description>
						<LineNumber>Part II, line 35</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Allowed General And Eligible Small Business Credit Amount -->
			<xsd:element name="TotAllwGenAndEligSmllBusCrAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total allowed general and eligible small business credit amount</Description>
						<LineNumber>Part II, line 36</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Smaller General Business Credit Or Total General Eligible Credit Amount -->
			<xsd:element name="SmllrGenBusCrOrTotGenEligCrAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Smaller general business credit or total general eligible credit amount</Description>
						<LineNumber>Part II, line 37</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Part II Section D -->
			<!-- Current Year Credit Allowed -->
			<xsd:element name="CurrentYearCreditAllowedAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Current year credit allowed</Description>
						<LineNumber>Part II, line 38</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="USAmountType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="GenBusinessCreditComputation"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Part III -->
			<!-- Investment Credit (Form 3468) -->
			<xsd:element name="Form3468PartIICYCreditsGrp" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<LineNumber>Part III, Line 1a column a, c, d, e, g, i</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:complexContent>
						<xsd:extension base="CYGBCPssvGrpType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="IRS3468"/>
						</xsd:extension>
					</xsd:complexContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Current year advanced manufacturing production credit (Form 7207) -->
			<xsd:element name="Form7207CYCreditsGrp" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<LineNumber>Part III, Line 1b column a, b, c, d, e, f, g, h, i, j</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:complexContent>
						<xsd:extension base="ElctvPymtPssvGrpType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="IRS7207"/>
						</xsd:extension>
					</xsd:complexContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Credit for Increasing Research Activities (Form 6765) -->
			<xsd:element name="Form6765CYCreditsGrp" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<LineNumber>Part III, Line 1c column a, c, d, e, g, i</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:complexContent>
						<xsd:extension base="CYGBCPssvGrpType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="IRS6765"/>
						</xsd:extension>
					</xsd:complexContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Investment Credit (Form 3468) -->
			<xsd:element name="Form3468PartIIICYCreditsGrp" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<LineNumber>Part III, Line 1d column a, b, c, d, e, f, g, h, i, j</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:complexContent>
						<xsd:extension base="ElctvPymtPssvGrpType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="IRS3468"/>
						</xsd:extension>
					</xsd:complexContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Disabled Access Credit (Form 8826) -->
			<xsd:element name="Form8826CYCreditsGrp" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<LineNumber>Part III, Line 1e column a, c, d, e, g, i</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:complexContent>
						<xsd:extension base="CYGBCPssvGrpType">
