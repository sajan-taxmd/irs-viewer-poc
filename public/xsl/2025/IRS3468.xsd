								<xsd:documentation>
									<Description>Applicable percentage for the net output and prevailing wage and apprenticeship questions in specified part</Description>
									<LineNumber>Part VI, Line 25k</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Calculated clean hydrogen production facilities as energy section 45V(b)(2)(D)  amount -->
						<xsd:element name="CalcClnHydrgn45Vb2DPropBssAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Calculated clean hydrogen production facilities as energy section 45V(b)(2)(D)  amount</Description>
									<LineNumber>Part VI, Line 25l</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Total clean hydrogen production facilities as energy with addition applicable credits amount -->
						<xsd:element name="TotClnHydrgnFcltsEgyPropCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Total clean hydrogen production facilities as energy with addition applicable credits amount</Description>
									<LineNumber>Part VI, Line 26</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>

			<!-- Section N -->

			<!-- Sum of energy credits amount -->
			<xsd:element name="TotalEnergyCreditsAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Sum of energy credits amount</Description>
						<LineNumber>Part VI, Line 27</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Divide sum all bond proceeds for the tax year and all prior tax years, per section 103, as of the close of the tax year, by the aggregate amount of additions to the capital account for the qualified facility -->
			<xsd:element name="CalcTaxExemptBondsPct" type="Decimal4RatioType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Divide sum all bond proceeds for the tax year and all prior tax years, per section 103, as of the close of the tax year, by the aggregate amount of additions to the capital account for the qualified facility</Description>
						<LineNumber>Part VI, Line 28a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Multiply the total energy credits by any calculated tax exempt bond amount -->
			<xsd:element name="CalcTotEgyCrAndTxExmptBondAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Multiply the total energy credits by any calculated tax exempt bond amount</Description>
						<LineNumber>Part VI, Line 28b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Multiply the total energy credits by the indicated amount -->
			<xsd:element name="CalcTotalEnergyCreditAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Multiply the total energy credits by the indicated amount</Description>
						<LineNumber>Part VI, Line 28c</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Enter the smaller amount as indicated -->
			<xsd:element name="SmllrTotEgyCrOrTxExmptBondAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Enter the smaller amount as indicated</Description>
						<LineNumber>Part VI, Line 28d</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Subtract the indicated amounts -->
			<xsd:element name="TotEgyCrLssSmllrTxExmptBondAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Subtract the indicated amounts</Description>
						<LineNumber>Part VI, Line 28e</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- If tax-exempt bonds were used to finance your facility enter the amount indicated. Otherwise, enter the amount indicated.  -->
			<xsd:element name="FacilityTaxExemptBondFncAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>If tax-exempt bonds were used to finance your facility enter the amount indicated. Otherwise, enter the amount indicated.</Description>
						<LineNumber>Part VI, Line 29</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Multiply Facility Tax Exempt Bond amount by 0.90 (90%) or if Elective payment election for facility whose construction began in calendar year 2024, and the facility doesn't meet the rules of section 48(a)(12)(B), doesn't have a maximum net output of less than 1 MW (as measured in ac), or meet an exception under section 45(b)(10)(D). -->
			<xsd:element name="CYACLess1MWEPEAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Multiply Facility Tax Exempt Bond amount by 0.90 (90%) or if Elective payment election for facility whose construction began in calendar year 2024, and the facility doesn't meet the rules of section 48(a)(12)(B), doesn't have a maximum net output of less than 1 MW (as measured in ac), or meet an exception under section 45(b)(10)(D).</Description>
						<LineNumber>Part VI, Line 30</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Unused credit from cooperatives amount -->
			<xsd:element name="UnusedCreditFromCoopAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Unused credit from cooperatives amount</Description>
						<LineNumber>Part VI, Line 31</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Add indicated amounts -->
			<xsd:element name="ReportableEnergyCreditAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Add indicated amounts</Description>
						<LineNumber>Part VI, Line 32</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Part VII -->

			<!-- Indicator for a prior 170(h) deduction -->
			<xsd:element name="Prior170hDeductionInd" type="BooleanType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Indicator for a prior 170(h) deduction</Description>
						<LineNumber>Part VII, Line 1a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- If there was a prior 170(h) deduction, then input the NPS number -->
			<xsd:element name="Prior170hDeductionNPSProjNum" type="NPSProjectNumType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>If there was a prior 170(h) deduction, then input the NPS number</Description>
						<LineNumber>Part VII, Line 1b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Check This Box if You are Electing Under Section 47(d)(5) to Take Your Qualified Rehabilitation Expenditures Into Account for the Tax Year in Which Paid -->
			<xsd:element name="RehabilitationExpendElectInd" type="CheckboxType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Check This Box if You are Electing Under Section 47(d)(5) to Take Your Qualified Rehabilitation Expenditures Into Account for the Tax Year in Which Paid</Description>
						<LineNumber>Part VII, Line 1c</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Rehabilitation period beginning date -->
			<xsd:element name="RehabilitationPeriodBeginDt" type="DateType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Rehabilitation period beginning date</Description>
						<LineNumber>Part VII, Line 1d</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Rehabilitation period end date -->
			<xsd:element name="RehabilitationPeriodEndDt" type="DateType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Rehabilitation period end date</Description>
						<LineNumber>Part VII, Line 1d</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Adjusted basis of building as of the beginning date amount -->
			<xsd:element name="AdjustedBasisOfBuildingAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Adjusted basis of building as of the beginning date amount</Description>
						<LineNumber>Part VII, Line 1e</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Qualified rehabilitation expenditures incurred during the period listed above amount -->
			<xsd:element name="QlfyRehbltExpendIncurredAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Qualified rehabilitation expenditures incurred during the period listed above amount</Description>
						<LineNumber>Part VII, Line 1f</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Qualified rehabilitation expenditures amount -->
			<xsd:element name="QlfyRehabilitationExpendAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Qualified rehabilitation expenditures amount</Description>
						<LineNumber>Part VII, Line 1g</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- Reserved for future use - Part VII, Line 1h -->
			
			<!-- Reserved for future use - Part VII, Line 1i -->

			<!-- Calculation certified historic structure with expenditures paid not under the transition rule amount -->
			<xsd:element name="OtherCertifiedHistStrctrCrAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Calculation certified historic structure with expenditures paid not under the transition rule amount</Description>
						<LineNumber>Part VII, Line 1j</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="USAmountNNType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="OtherCertifiedHistoricStructuresSchedule"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>

			<!-- NPS project number -->
			<xsd:element name="NPSProjectNum" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>NPS project number</Description>
						<LineNumber>Part VII, Line 1k(i)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="NPSProjectNumType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="BinaryAttachment"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>

			<!-- Originating pass-through entity's EIN -->
			<xsd:element name="PassThroughEntityEIN" type="EINType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Originating pass-through entity's EIN</Description>
						<LineNumber>Part VII, Line 1k(ii)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Date of NPS Approval -->
			<xsd:element name="NPSApprovalDt" type="DateType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Date of NPS Approval</Description>
						<LineNumber>Part VII, Line 1k(iii)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Reserved - Part VII, Line 1l -->

			<!-- Date of approved certification of completed work from the NPS Form 10-168 -->
			<xsd:element name="SpcfdDtAftrOrigRehbltCrClaimDt" type="DateType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Date of approved certification of completed work from the NPS Form 10-168</Description>
						<LineNumber>Part VII, Line 1m</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Unused credit from cooperatives -->
			<xsd:element name="UnusedCrRehbltEgyCrFromCoopAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Unused credit from cooperatives</Description>
						<LineNumber>Part VII, Line 2</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Add indicated amounts -->
			<xsd:element name="TotQlfyRehabilitationExpendAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Add indicated amounts</Description>
						<LineNumber>Part VII, Line 3</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

		</xsd:sequence>
	</xsd:complexType>

</xsd:schema>


