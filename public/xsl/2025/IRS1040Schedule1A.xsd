                                <xsd:documentation>
                                    <Description>Qualified vehicle identification number (VIN)</Description>
                                    <LineNumber>22(i)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                            
                            <xsd:simpleType>
                                <xsd:restriction base="TextType">
                                    <xsd:pattern value="[A-Z0-9]{1,17}"/>
                                </xsd:restriction>
                            </xsd:simpleType>
                        </xsd:element>
                        
                        <!-- Qualified car loan interest deducted on Schedule C, E, or F -->
                        <xsd:element name="QualifiedCarLoanIntDedSchAmt" type="USAmountType" minOccurs="0">
                            <xsd:annotation>
