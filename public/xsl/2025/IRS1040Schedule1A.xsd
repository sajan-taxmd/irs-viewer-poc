                    </xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            
            <!-- Foreign earned income exclusion from Form 2555 -->
            <xsd:element name="TotalIncomeExclusionAmt" type="USAmountPosType" minOccurs="0">
