			</xsd:element>
		
			<xsd:element name="IncomeTaxRt10UndTrtyRuleGrp" type="IncomeTaxRt10UndTrtyRuleGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Income Subject To The 10 Percent Tax Rate Under A Tax Treaty Or U.S. Tax Rule</Description>
						<LineNumber>(a)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<xsd:element name="IncomeTaxRt15UndTrtyRuleGrp" type="IncomeTaxRt15UndTrtyRuleGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Income Subject To The 15 Percent Tax Rate Under A Tax Treaty Or U.S. Tax Rule</Description>
						<LineNumber>(b)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<xsd:element name="IncomeTaxRt30UndTrtyRuleGrp" type="IncomeTaxRt30UndTrtyRuleGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Income Subject To The 30 Percent Tax Rate Under A Tax Treaty Or U.S. Tax Rule</Description>
						<LineNumber>(c)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<xsd:element name="IncomeTaxRtOthUndTrtyRuleGrp" type="IncomeTaxRtOthUndTrtyRuleGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Income Subject To The 15 Percent Tax Rate Under A Tax Treaty Or U.S. Tax Rule</Description>
						<LineNumber>(d)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<xsd:element name="IncomeTaxRtOth2UndTrtyRuleGrp" type="IncomeTaxRtOth2UndTrtyRuleGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Income Subject To An Other Percent Tax Rate Under A Tax Treaty Or U.S. Tax Rule</Description>
						<LineNumber>(d)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<xsd:element name="IncomeNotUSBusinessTaxAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Tax on income not effectively connected with a U.S. trade or business amount</Description>
						<LineNumber>15</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>			
			
			<!-- Capital Gains and Losses From Sales Or Exchanges of Property -->
			
			<xsd:element name="CapGainLossSlsOrExchPropGrp" type="CapGainLossSlsOrExchPropGrpType" minOccurs="0"  maxOccurs="25">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Income Subject To An Other Percent Tax Rate Under A Tax Treaty Or U.S. Tax Rule</Description>
						<LineNumber>(d)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<xsd:element name="TotalCapitalLossAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total capital loss amount</Description>
						<LineNumber>17(f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<xsd:element name="TotalCapitalGainAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total capital gain amount</Description>
						<LineNumber>17(g)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<xsd:element name="NetCapitalGainOrLossAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Net capital gain or loss amount</Description>
						<LineNumber>18(g)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
		</xsd:sequence>
	</xsd:complexType>

