                                    <Description>Current tax year</Description>
                                    <LineNumber>Column (xiii)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Total of specified columns -->
                        <xsd:element name="TotalAmt" type="USAmountNegType">
                            <xsd:annotation>
