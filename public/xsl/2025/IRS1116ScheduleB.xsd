                                    <Description>Sixth (6th) preceding tax year</Description>
                                    <LineNumber>Column (v)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Fifth (5th) preceding tax year -->
                        <xsd:element name="FifthPrecedingTYAmt" type="USAmountType" minOccurs="0">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Fifth (5th) preceding tax year</Description>
                                    <LineNumber>Column (vi)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Subtotal -->
                        <xsd:element name="SubtotalAmt" type="USAmountType" minOccurs="0">
                            <xsd:annotation>
