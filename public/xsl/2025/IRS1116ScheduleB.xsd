                                    <Description>Tenth (10th) preceding tax year</Description>
                                    <LineNumber>Column (i)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Columns (ii) thru (vi) - Not in XML. No Entry. -->
                        
                        <!-- Subtotal -->
                        <xsd:element name="SubtotalAmt" type="USAmountNegType">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Subtotal</Description>
                                    <LineNumber>Column (vii)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Column (viii) - Not in XML. Use value from column (vii) -->
                        
                        <!-- Columns (ix) thru (xiii) - Not in XML. No Entry. -->
                        
                        <!-- Total of specified columns -->
                        <xsd:element name="TotalAmt" type="USAmountNegType">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Total of specified columns</Description>
                                    <LineNumber>Column (xiv)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
            
            <!-- Foreign tax carryover generated in current tax year -->
            <xsd:element name="ForeignTxCyovGenCurrTYGrp" minOccurs="0">
