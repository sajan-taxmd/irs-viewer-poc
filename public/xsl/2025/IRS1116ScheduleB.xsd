                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Fourth (4th) preceding tax year</Description>
                                    <LineNumber>Column (ix)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Third (3rd) preceding tax year -->
                        <xsd:element name="ThirdPrecedingTYAmt" type="USAmountType" minOccurs="0">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Third (3rd) preceding tax year</Description>
                                    <LineNumber>Column (x)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Second (2nd) preceding tax year -->
                        <xsd:element name="SecondPrecedingTYAmt" type="USAmountType" minOccurs="0">
                            <xsd:annotation>
