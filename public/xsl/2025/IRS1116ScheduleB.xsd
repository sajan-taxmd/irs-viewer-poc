                        <xsd:element name="OtherAdjustmentsTxt" type="ShortDescriptionType">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Other adjustments</Description>
                                    <LineNumber>Line 2c-2g</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Other foreign tax adjustments preceding tax year -->
                        <xsd:element name="OtherFrgnTaxAdjPrecedingTYGrp" type="ForeignTxCyovReconciliationType">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Other foreign tax adjustments preceding tax year</Description>
