                                    <LineNumber>Column (xiv)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
            
            <!-- Foreign tax carryover to the following tax year -->
            <xsd:element name="ForeignTxCyovFollowingTYGrp" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Foreign tax carryover to the following tax year</Description>
                        <LineNumber>Line 8</LineNumber>
                    </xsd:documentation>
                </xsd:annotation>
                
                <xsd:complexType>
                    <xsd:sequence>
                    
						<!-- Column (i) - Not in XML. No Entry. -->
                        
                        <!-- Ninth (9th) preceding tax year -->
                        <xsd:element name="NinthPrecedingTYAmt" type="USAmountType" minOccurs="0">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Ninth (9th) preceding tax year</Description>
                                    <LineNumber>Column (ii)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Eighth (8th) preceding tax year -->
                        <xsd:element name="EighthPrecedingTYAmt" type="USAmountType" minOccurs="0">
