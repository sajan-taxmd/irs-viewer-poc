<?xml version="1.0" encoding="UTF-8"?>
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns="http://www.irs.gov/efile" targetNamespace="http://www.irs.gov/efile" elementFormDefault="qualified" attributeFormDefault="unqualified" version="1.0">
    <xsd:annotation>
        <xsd:documentation>
            <Description>IRS e-file Schema - Form 1116 Schedule B - Foreign Tax Carryover Reconciliation Schedule</Description>
            <TaxYear>2025</TaxYear>
            <MaturityLevel>Final Release</MaturityLevel>
            <ReleaseDate>February 19 2026</ReleaseDate>
        </xsd:documentation>
    </xsd:annotation>
    <xsd:include schemaLocation="../../Common/efileTypes.xsd"/>
    <!-- ======================================================== -->
    <!-- =============== IRS Form 1116 Schedule B =============== -->
    <!-- ======================================================== -->    
    <xsd:element name="IRS1116ScheduleB">
        <xsd:annotation>
            <xsd:documentation>IRS Form 1116 Schedule B - Foreign Tax Carryover Reconciliation Schedule</xsd:documentation>
        </xsd:annotation>   
        <xsd:complexType>
            <xsd:complexContent>
                <xsd:extension base="IRS1116ScheduleBType">
                    <xsd:attributeGroup ref="DocumentAttributes">
                        <xsd:annotation>
                            <xsd:documentation>Common return document attributes</xsd:documentation>
                        </xsd:annotation>
                    </xsd:attributeGroup>                  
                    <xsd:attribute name="documentName" type="TextType" fixed="IRS1116ScheduleB">
                        <xsd:annotation>
                            <xsd:documentation>IRS internal use only. To avoid errors within the return, do not include the attribute name or value.</xsd:documentation>
                        </xsd:annotation>
                    </xsd:attribute>                
                    <xsd:attribute name="referenceDocumentId" type="IdListType">
                        <xsd:annotation>
                            <xsd:documentation>List of document IDs of forms, schedules, supporting info. etc. attached to this form.</xsd:documentation>
                        </xsd:annotation>
                    </xsd:attribute>                  
                    <xsd:attribute name="referenceDocumentName" type="TextType" fixed="GeneralDependencySmall"/>
                </xsd:extension>
            </xsd:complexContent>
        </xsd:complexType>
    </xsd:element>
    <xsd:complexType name="IRS1116ScheduleBType">
		<xsd:annotation>
			<xsd:documentation>Content model for Form 1116 Schedule B</xsd:documentation>
		</xsd:annotation>
		
		<!-- Line a - Not in XML. Reserved for future use. -->
		
        <xsd:sequence>   
            <xsd:choice>
                <!-- Foreign branch category income -->
                <xsd:element name="ForeignBranchIncomeInd" type="CheckboxType">
                    <xsd:annotation>
                        <xsd:documentation>
                            <Description>Foreign branch category income</Description>
                            <LineNumber>b</LineNumber>
                        </xsd:documentation>
                    </xsd:annotation>                   
                </xsd:element>
                
                <!-- Passive category foreign income -->
                <xsd:element name="ForeignIncPassiveCategoryInd" type="CheckboxType">
                    <xsd:annotation>
                        <xsd:documentation>
                            <Description>Passive category foreign income</Description>
                            <LineNumber>c</LineNumber>
                        </xsd:documentation>
                    </xsd:annotation>                 
                </xsd:element>  
                     
                <!-- Foreign income general category -->
                <xsd:element name="ForeignIncGeneralCategoryInd" type="CheckboxType">
                    <xsd:annotation>
                        <xsd:documentation>
                            <Description>Foreign income general category</Description>
                            <LineNumber>d</LineNumber>
                        </xsd:documentation>
                    </xsd:annotation> 
                </xsd:element>
                
                <!-- Foreign income section 901j -->
                <xsd:element name="ForeignIncSection901jInd" type="CheckboxType">
                    <xsd:annotation>
                        <xsd:documentation>
                            <Description>Foreign income section 901j</Description>
                            <LineNumber>e</LineNumber>
                        </xsd:documentation>
                    </xsd:annotation>  
                </xsd:element>
                
                <!-- Foreign income re-sourced by treaty -->
                <xsd:element name="ForeignIncResourcedTreatyInd" type="CheckboxType">
                    <xsd:annotation>
                        <xsd:documentation>
                            <Description>Foreign income re-sourced by treaty</Description>
                            <LineNumber>f</LineNumber>
                        </xsd:documentation>
                    </xsd:annotation>                
                </xsd:element>
                
                <!-- Foreign income lump-sum distributions -->
                <xsd:element name="ForeignIncLumpSumDistribInd" type="CheckboxType">
                    <xsd:annotation>
                        <xsd:documentation>
                            <Description>Foreign income lump-sum distributions</Description>
                            <LineNumber>g</LineNumber>
                        </xsd:documentation>
                    </xsd:annotation>
                </xsd:element>
            </xsd:choice>
            
            <!-- Sanctioned country code -->
            <xsd:element name="SanctionedCountryCd" type="CountryType" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Sanctioned country code</Description>
                        <LineNumber>h</LineNumber>
                    </xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            
            <!-- Treaty country code -->
            <xsd:element name="TreatyCountryCd" type="CountryType" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Treaty country code</Description>
                        <LineNumber>i</LineNumber>
                    </xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            
            <!-- =============== Foreign Tax Carryover Reconciliation =============== -->
            
            <!-- Foreign tax carryover from the prior tax year -->
            <xsd:element name="ForeignTxCyovPrTYGrp" type="ForeignTxCyovReconciliationType" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Foreign tax carryover from the prior tax year</Description>
                        <LineNumber>Line 1</LineNumber>
                    </xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            
            <!-- =============== Adjustments to line 1 - Line 2 =============== -->
            
            <!-- Carryback adjustment -->
            <xsd:element name="CarrybackAdjustmentGrp" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Carryback adjustment</Description>
                        <LineNumber>Line 2a</LineNumber>
                    </xsd:documentation>
                </xsd:annotation>
                
                <xsd:complexType>
                    <xsd:sequence>
                    
						<!-- Columns (i) thru (xi) - Not in XML. No Entry. -->
                        
                        <!-- First (1st) preceding tax year -->
                        <xsd:element name="FirstPrecedingTYAmt" type="USAmountType">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>First (1st) preceding tax year</Description>
                                    <LineNumber>Column (xii)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Column (xiii) - Not in XML. No Entry. -->
                         
