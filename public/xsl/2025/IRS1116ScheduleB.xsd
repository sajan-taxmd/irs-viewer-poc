                    <xsd:documentation>
                        <Description>Foreign tax carryover generated in current tax year</Description>
                        <LineNumber>Line 6</LineNumber>
                    </xsd:documentation>
                </xsd:annotation>
                
                <xsd:complexType>
                    <xsd:sequence>
                    
						<!-- Columns (i) thru (xii) - Not in XML. No Entry. -->
                        
                        <!-- Current tax year -->
                        <xsd:element name="CurrentTaxYearAmt" type="USAmountType">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Current tax year</Description>
                                    <LineNumber>Column (xiii)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Total of specified columns -->
                        <xsd:element name="TotalAmt" type="USAmountType">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Total of specified columns</Description>
                                    <LineNumber>Column (xiv)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
            
            <!-- Actual or tentative (estimated) carried back to prior tax year -->
            <xsd:element name="ActlTentAmtCarriedBackPrTYGrp" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Actual or tentative (estimated) carried back to prior tax year</Description>
                        <LineNumber>Line 7</LineNumber>
                    </xsd:documentation>
                </xsd:annotation>
                
                <xsd:complexType>
                    <xsd:sequence>
                    
						<!-- Columns (i) thru (xii) - Not in XML. No Entry. -->
						
