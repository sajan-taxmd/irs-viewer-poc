                                    <Description>Eighth (8th) preceding tax year</Description>
                                    <LineNumber>Column (iii)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Seventh (7th) preceding tax year -->
                        <xsd:element name="SeventhPrecedingTYAmt" type="USAmountNegType" minOccurs="0">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Seventh (7th) preceding tax year</Description>
                                    <LineNumber>Column (iv)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Sixth (6th) preceding tax year -->
                        <xsd:element name="SixthPrecedingTYAmt" type="USAmountNegType" minOccurs="0">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Sixth (6th) preceding tax year</Description>
                                    <LineNumber>Column (v)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Fifth (5th) preceding tax year -->
                        <xsd:element name="FifthPrecedingTYAmt" type="USAmountNegType" minOccurs="0">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Fifth (5th) preceding tax year</Description>
                                    <LineNumber>Column (vi)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Subtotal -->
                        <xsd:element name="SubtotalAmt" type="USAmountNegType" minOccurs="0">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Subtotal</Description>
                                    <LineNumber>Column (vii)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Column (viii) - Not in XML.  Use value from Column (vii). Comment in schema -->
                        
                        <!-- Fourth (4th) preceding tax year -->
                        <xsd:element name="FourthPrecedingTYAmt" type="USAmountNegType" minOccurs="0">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Fourth (4th) preceding tax year</Description>
                                    <LineNumber>Column (ix)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Third (3rd) preceding tax year -->
                        <xsd:element name="ThirdPrecedingTYAmt" type="USAmountNegType" minOccurs="0">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Third (3rd) preceding tax year</Description>
                                    <LineNumber>Column (x)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Second (2nd) preceding tax year -->
                        <xsd:element name="SecondPrecedingTYAmt" type="USAmountNegType" minOccurs="0">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Second (2nd) preceding tax year</Description>
                                    <LineNumber>Column (xi)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- First (1st) preceding tax year -->
                        <xsd:element name="FirstPrecedingTYAmt" type="USAmountNegType" minOccurs="0">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>First (1st) preceding tax year</Description>
                                    <LineNumber>Column (xii)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                        
                        <!-- Column (xiii) - Not in XML.  No Entry -->
                        
                        <!-- Total of specified columns -->
                        <xsd:element name="TotalAmt" type="USAmountNegType">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Total of specified columns</Description>
                                    <LineNumber>Column (xiv)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
                    </xsd:sequence>
                </xsd:complexType>
            </xsd:element>
            
            <!-- Foreign tax carryover expired unused in current tax year -->
            <xsd:element name="ForeignTxCyovExprUnsdCurrTYGrp" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Foreign tax carryover expired unused in current tax year</Description>
                        <LineNumber>Line 5</LineNumber>
                    </xsd:documentation>
                </xsd:annotation>
                
                <xsd:complexType>
                    <xsd:sequence>
                        <!-- Tenth (10th) preceding tax year -->
                        <xsd:element name="TenthPrecedingTYAmt" type="USAmountNegType">
                            <xsd:annotation>
