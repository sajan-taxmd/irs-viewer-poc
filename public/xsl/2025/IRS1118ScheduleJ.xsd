<?xml version="1.0" encoding="UTF-8"?>
<xsd:schema xmlns="http://www.irs.gov/efile" xmlns:xsd="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.irs.gov/efile" elementFormDefault="qualified" attributeFormDefault="unqualified" version="1.0">

	<xsd:annotation>
		<xsd:documentation>
			<Description>IRS e-file Schema - Form 1118 Schedule J</Description>
			<TaxYear>2025</TaxYear>
			<MaturityLevel>Final Release</MaturityLevel>
			<ReleaseDate>February 19 2026</ReleaseDate>
		</xsd:documentation>
	</xsd:annotation>

	<xsd:include schemaLocation="../../../Common/efileTypes.xsd"/>


	<!-- =============================================================== -->
	<!-- ======================  IRS Form 1118 Schedule J ============== -->
	<!-- =============================================================== -->


	<xsd:element name="IRS1118ScheduleJ">
		<xsd:annotation>
			<xsd:documentation>IRS Form 1118 Schedule J</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:complexContent>
				<xsd:extension base="IRS1118ScheduleJType">
					<xsd:attributeGroup ref="DocumentAttributes">
						<xsd:annotation>
							<xsd:documentation>Common return document attributes</xsd:documentation>
						</xsd:annotation>
					</xsd:attributeGroup>
					<xsd:attribute name="documentName" type="xsd:string" fixed="IRS1118ScheduleJ">
						<xsd:annotation>
							<xsd:documentation>IRS internal use only. To avoid error in the return, do not include the attribute name or value.</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
					<xsd:attribute name="referenceDocumentId" type="IdListType"/>
					<xsd:attribute name="referenceDocumentName" type="StringType" fixed="AnnualRecaptureRevocableElectionStatement BinaryAttachment"/>

					<xsd:attribute name="uSLossAllocUnderNotice89Cd">
						<xsd:simpleType>
							<xsd:restriction base="TextType">
								<xsd:enumeration value="US Loss Allocation Under Notice 89-3"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:attribute>

				</xsd:extension>
			</xsd:complexContent>
		</xsd:complexType>
	</xsd:element>

	<xsd:complexType name="IRS1118ScheduleJType">
		<xsd:annotation>
			<xsd:documentation>Content model for Form 1118 Schedule J</xsd:documentation>
		</xsd:annotation>

		<xsd:sequence>

			<!-- The Group Applies to Schedule J Part I Line 2e for Column i, ii, iii, iv, and v  -->
			<xsd:element name="AllocationSepLmtLossOthIncmGrp" type="AllocationSepLmtLossOthIncmGrpType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>The group applies to Schedule J Part I Line 2e for column i, ii, iii, iv, and v </Description>
						<LineNumber>Schedule J Part I Line 2e</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- The Group Applies to Schedule J Part I Line 9e for Column i, ii, iii, iv, and v  -->
			<xsd:element name="RchrctrztnSepLmtOtherIncmGrp" type="SepLmtOtherIncmGrpType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>The group applies to Schedule J Part I Line 9e for column i, ii, iii, iv, and v </Description>
						<LineNumber>Schedule J Part I Line 9e</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- The Group Applies to Schedule J Part II Line e for Column i, ii, iii, iv, and v  -->
			<xsd:element name="EOYBalanceSepLmtOtherIncmGrp" type="SepLmtOtherIncmGrpType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>The group applies to Schedule J Part II Line e for column i, ii, iii, iv, and v </Description>
						<LineNumber>Schedule J Part II Line e</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- Part I - Adjustments to Separate Limitation Income or (Losses) in Determining Numerators of Limitation Fractions -->
			
			<!-- Column (i) Section 951A income -->
			<xsd:element name="AdjSepLmtSection951AIncome" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>

						<!-- Income or (loss) before Adjustments -->
						<xsd:element name="TotIncmOrLossBfrAdjustmentsAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Income or (loss) before Adjustments</Description>
									<LineNumber>Schedule J Part I Line 1(i)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Allocation of Current Year Separate Limitation Losses -->
						<xsd:element name="AllocationCYSeparateLmtLosses" type="AllocnCYSepLmtLossSect951AIncmType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Allocation of current year separate limitation losses</Description>
									<LineNumber>Schedule J Part I Line 2(i)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						
						<!-- Lines 3, 4, 5, 6, 7 and 8 -->
						<xsd:group ref="IncmLossAllocCYSubtotalsGroup" minOccurs="0"/>

						<!-- Recharacterization of Separate Limitation Income -->
						<xsd:element name="RecharacterizationSepLmtIncm" type="SepLmtIncmSect951AIncomeType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Recharacterization of separate limitation income</Description>
									<LineNumber>Schedule J Part I Line 9(i)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Lines 10 and 11 -->
						<xsd:group ref="LimitationFractionCalcGroup" minOccurs="0"/>
						
						<!-- Part II  Year-End Balances Of Future Separate Limitation Income That Must Be Recharacterized (Section 904(f) (5)(C)) -->
						<xsd:element name="EOYBalancesOfFutureSepLmtIncm" type="EOYLmtIncmSection951AIncomeType" minOccurs="0"/>

						<!-- Part III - Overall Foreign Loss Account Balances (Section 904(f)(1)) -->
						<xsd:element name="OverallForeignLossAcctBalances" type="ForeignAccountBalanceType" minOccurs="0"/>

						<!-- Part IV - Overall Domestic Loss Account Balances (section 904(g)(1)) -->
						<xsd:element name="OverallDomLossAcctBalances" type="DomesticAccountBalanceType" minOccurs="0"/>
						
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>

			<!-- Column (ii)  Foreign Branch Income-->
			<xsd:element name="AdjSepLmtForeignBranchIncome" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>

						<!-- Part I - Adjustments to Separate Limitation Income or (Losses) in Determining Numerators of Limitation Fractions -->
						
						<!-- Income or (loss) before Adjustments -->
						<xsd:element name="TotIncmOrLossBfrAdjustmentsAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Income or (loss) before Adjustments</Description>
									<LineNumber>Schedule J Part I Line 1(ii)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Allocation of Current Year Separate Limitation Losses -->
						<xsd:element name="AllocationCYSeparateLmtLosses" type="AllocnCYSepLmtLossFrgnBrIncomeType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Allocation of current year separate limitation losses</Description>
									<LineNumber>Schedule J Part I Line 2(ii)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						
						<!-- Lines 3, 4, 5, 6, 7 and 8 -->
						<xsd:group ref="IncmLossAllocCYSubtotalsGroup" minOccurs="0"/>

						<!-- Recharacterization of Separate Limitation Income -->
						<xsd:element name="RecharacterizationSepLmtIncm" type="SepLmtForeignBrIncomeType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Recharacterization of separate limitation income</Description>
									<LineNumber>Schedule J Part I Line 9(ii)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Lines 10 and 11 -->
						<xsd:group ref="LimitationFractionCalcGroup" minOccurs="0"/>
						
						<!-- Part II  Year-End Balances Of Future Separate Limitation Income That Must Be Recharacterized (Section 904(f) (5)(C)) -->
						<xsd:element name="EOYBalancesOfFutureSepLmtIncm" type="EOYLmtIncmFrgnBranchIncomeType" minOccurs="0"/>						
						
						<!-- Part III - Overall Foreign Loss Account Balances (Section 904(f)(1)) -->
						<xsd:element name="OverallForeignLossAcctBalances" type="ForeignAccountBalanceType" minOccurs="0"/>
						
						<!-- Part IV - Overall Domestic Loss Account Balances (section 904(g)(1)) -->
						<xsd:element name="OverallDomLossAcctBalances" type="DomesticAccountBalanceType" minOccurs="0"/>
						
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			
			<!-- Column (iii)  Passive Category Income-->
			<xsd:element name="AdjSepLmtPassiveCategoryIncm" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>

						<!-- Part I - Adjustments to Separate Limitation Income or (Losses) in Determining Numerators of Limitation Fractions -->
						
						<!-- Income or (loss) before Adjustments -->
						<xsd:element name="TotIncmOrLossBfrAdjustmentsAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Income or (loss) before Adjustments</Description>
									<LineNumber>Schedule J Part I Line 1(iii)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Allocation of Current Year Separate Limitation Losses -->
						<xsd:element name="AllocationCYSeparateLmtLosses" type="AllocnCYLossPassiveIncomeType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Allocation of current year separate limitation losses</Description>
									<LineNumber>Schedule J Part I Line 2(iii)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						
						<!-- Lines 3, 4, 5, 6, 7 and 8 -->
						<xsd:group ref="IncmLossAllocCYSubtotalsGroup" minOccurs="0"/>

						<!-- Recharacterization of Separate Limitation Income -->
						<xsd:element name="RecharacterizationSepLmtIncm" type="SepLmtIncmPassiveIncomeType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Recharacterization of separate limitation income</Description>
									<LineNumber>Schedule J Part I Line 9(iii)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Lines 10 and 11 -->
						<xsd:group ref="LimitationFractionCalcGroup" minOccurs="0"/>
						
						<!-- Part II  Year-End Balances Of Future Separate Limitation Income That Must Be Recharacterized (Section 904(f) (5)(C)) -->		
						<xsd:element name="EOYBalancesOfFutureSepLmtIncm" type="EOYLmtIncmPassiveIncomeType" minOccurs="0"/>

						<!-- Part III - Overall Foreign Loss Account Balances (Section 904(f)(1)) -->
						<xsd:element name="OverallForeignLossAcctBalances" type="ForeignAccountBalanceType" minOccurs="0"/>
						
						<!-- Part IV - Overall Domestic Loss Account Balances (section 904(g)(1)) -->
						<xsd:element name="OverallDomLossAcctBalances" type="DomesticAccountBalanceType" minOccurs="0"/>
						
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>

			<!-- Column (iv) General Category Income -->
			<xsd:element name="AdjSepLmtGeneralCategoryIncm" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>

						<!-- Part I - Adjustments to Separate Limitation Income or (Losses) in Determining Numerators of Limitation Fractions -->
						
						<!-- Income or (loss) before Adjustments -->
						<xsd:element name="TotIncmOrLossBfrAdjustmentsAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Income or (loss) before Adjustments</Description>
									<LineNumber>Schedule J Part I Line 1(iv)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Allocation of Current Year Separate Limitation Losses -->
						<xsd:element name="AllocationCYSeparateLmtLosses" type="AllocnCYLossGenLmtIncomeType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Allocation of current year separate limitation losses</Description>
									<LineNumber>Schedule J Part I Line 2(iv)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						
						<!-- Lines 3, 4, 5, 6, 7 and 8 -->
						<xsd:group ref="IncmLossAllocCYSubtotalsGroup" minOccurs="0"/>

						<!-- Recharacterization of Separate Limitation Income -->
						<xsd:element name="RecharacterizationSepLmtIncm" type="SepLmtIncmGenLmtIncomeType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Recharacterization of separate limitation income</Description>
									<LineNumber>Schedule J Part I Line 9(iv)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Lines 10 and 11 -->
						<xsd:group ref="LimitationFractionCalcGroup" minOccurs="0"/>
						
						<!-- Part II  Year-End Balances Of Future Separate Limitation Income That Must Be Recharacterized (Section 904(f) (5)(C)) -->
						<xsd:element name="EOYBalancesOfFutureSepLmtIncm" type="EOYLmtIncmGenLmtIncomeType" minOccurs="0"/>					
						
						<!-- Part III - Overall Foreign Loss Account Balances (Section 904(f)(1)) -->
						<xsd:element name="OverallForeignLossAcctBalances" type="ForeignAccountBalanceType" minOccurs="0"/>
						
						<!-- Part IV - Overall Domestic Loss Account Balances (section 904(g)(1)) -->
						<xsd:element name="OverallDomLossAcctBalances" type="DomesticAccountBalanceType" minOccurs="0"/>
				
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>

			<!-- Column (v) Other Income -->
			<xsd:element name="AdjSepLmtOtherIncome" minOccurs="0" maxOccurs="unbounded">	
				<xsd:complexType>				
					<xsd:sequence>
					
						<!-- Part I - Adjustments to Separate Limitation Income or (Losses) in Determining Numerators of Limitation Fractions -->

						<!-- Select Income from Sanctioned Country to Which Section 901j Applies “901j” or Income Resourced Under a Tax Treaty “RBT” -->
						<xsd:element name="SeparateCategoryCd" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Select income from sanctioned country to which Section 901j applies “901j” or income resourced under a tax treaty “RBT”</Description>
									<LineNumber>Schedule J Part I column (v)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="TextType">
									<xsd:enumeration value="901j"/>
									<xsd:enumeration value="RBT"/>
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:element>

						<!-- Choice between Sanctioned Country Cd or Treaty Country Cd -->
						<xsd:choice minOccurs="0">

							<!-- If 901j is Selected, Enter the Sanctioned Country Code -->
							<xsd:element name="SanctionedCountryCd" type="CountryType">
								<xsd:annotation>
									<xsd:documentation>
										<Description>If 901j is selected, enter the sanctioned country code</Description>
										<LineNumber>Schedule J Part I column (v)</LineNumber>
									</xsd:documentation>
								</xsd:annotation>
							</xsd:element>

							<!-- If RBT is Selected, Enter the Country Code for the Treaty Country -->
							<xsd:element name="TreatyCountryCd" type="CountryType">
								<xsd:annotation>
									<xsd:documentation>
										<Description>If RBT is selected, enter the country code for the treaty country</Description>
										<LineNumber>Schedule J Part I column (v)</LineNumber>
									</xsd:documentation>
								</xsd:annotation>
							</xsd:element>

						</xsd:choice>

						<!-- Enter Description of the Type of Income -->
						<xsd:element name="OtherIncomeDesc" type="LineExplanationType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Enter description of the type of income</Description>
									<LineNumber>Schedule J Part I column (v)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						
						<!-- Income or (loss) before Adjustments -->
						<xsd:element name="TotIncmOrLossBfrAdjustmentsAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Income or (loss) before Adjustments</Description>
									<LineNumber>Schedule J Part I Line 1(v)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Allocation of Current Year Separate Limitation Losses -->
						<xsd:element name="AllocationCYSeparateLmtLosses" type="AllocnCYLossOtherIncomeType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Allocation of current year separate limitation losses</Description>
									<LineNumber>Schedule J Part I Line 2(v)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Lines 3, 4, 5, 6, 7 and 8 -->
						<xsd:group ref="IncmLossAllocCYSubtotalsGroup" minOccurs="0"/>

						<!-- Recharacterization of Separate Limitation Income -->
						<xsd:element name="RecharacterizationSepLmtIncm" type="SepLmtIncmOtherIncomeType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Recharacterization of separate limitation income</Description>
									<LineNumber>Schedule J Part I Line 9(v)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Lines 10 and 11 -->
						<xsd:group ref="LimitationFractionCalcGroup" minOccurs="0"/>
						
						<!-- Part II  Year-End Balances Of Future Separate Limitation Income That Must Be Recharacterized (Section 904(f) (5)(C)) -->
						<xsd:element name="EOYBalancesOfFutureSepLmtIncm" type="EOYLmtIncmOtherIncomeType" minOccurs="0"/>

						<!-- Part III - Overall Foreign Loss Account Balances (Section 904(f)(1)) -->
						<xsd:element name="OverallForeignLossAcctBalances" type="ForeignAccountBalanceType" minOccurs="0"/>
						
						<!-- Part IV - Overall Domestic Loss Account Balances (section 904(g)(1)) -->
						<xsd:element name="OverallDomLossAcctBalances" type="DomesticAccountBalanceType" minOccurs="0"/>

					</xsd:sequence>			
				</xsd:complexType>
			</xsd:element>

			<!-- Column (vi) U.S. Income -->
			<xsd:element name="AdjSepLmtUSIncome" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>

						<!-- Part I - Adjustments to Separate Limitation Income or (Losses) in Determining Numerators of Limitation Fractions -->

						<!-- Income or (loss) before Adjustments -->
						<xsd:element name="TotIncmOrLossBfrAdjustmentsAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Income or (loss) before Adjustments</Description>
									<LineNumber>Schedule J Part I Line 1(vi)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Lines 3, 4, 5, 6, 7 and 8 -->
						<xsd:group ref="IncmLossAllocCYSubtotalsUSGrp" minOccurs="0"/>

						<!-- Recapture of Overall Domestic Losses -->
						<xsd:element name="RcptrOverallDomesticLossesAmt" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Recapture of Overall Domestic Losses</Description>
									<LineNumber>Schedule J Part I Line 10 (vi)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="USAmountNNType">
										<xsd:attribute name="allocationDomesticLossesCd">
											<xsd:simpleType>
												<xsd:restriction base="TextType">
													<xsd:enumeration value="Allocation of domestic losses"/>
												</xsd:restriction>
											</xsd:simpleType>
										</xsd:attribute>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>

		</xsd:sequence>
	</xsd:complexType>
	
							

	<!-- Type Definitions -->

	<!-- Part I, Line 2 e -->
	<xsd:complexType name="AllocationSepLmtLossOthIncmGrpType">
		<xsd:sequence>

			<!-- Select Income from Sanctioned Country to Which Section 901j Applies “901j” or Income Resourced Under a Tax Treaty “RBT” -->
			<xsd:element name="SeparateCategoryCd" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Select income from sanctioned country to which Section 901j applies “901j” or income resourced under a tax treaty “RBT”</Description>
						<LineNumber>Schedule J Part I Line 2e</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="TextType">
						<xsd:enumeration value="901j"/>
						<xsd:enumeration value="RBT"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>

			<!-- Choice between Sanctioned Country Cd or Treaty Country Cd -->
			<xsd:choice minOccurs="0">
			
				<!-- If 901j is Selected, Enter the Sanctioned Country Code -->
				<xsd:element name="SanctionedCountryCd" type="CountryType">
					<xsd:annotation>
						<xsd:documentation>
							<Description>If 901j is selected, enter the sanctioned country code</Description>
							<LineNumber>Schedule J Part I Line 2e</LineNumber>
						</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
			
				<!-- If RBT is Selected, Enter the Country Code for the Treaty Country -->
				<xsd:element name="TreatyCountryCd" type="CountryType">
					<xsd:annotation>
						<xsd:documentation>
							<Description>If RBT is selected, enter the country code for the treaty country</Description>
							<LineNumber>Schedule J Part I Line 2e</LineNumber>
						</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				
			</xsd:choice>
			
			<!-- Enter Description of the Type of Income -->
			<xsd:element name="OtherIncomeDesc" type="LineExplanationType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Enter description of the type of income</Description>
						<LineNumber>Schedule J Part I Line 2e</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Other Income Amount for Section 951AIncome Amount Column (i) -->
			<xsd:element name="Section951AIncomeAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Other income amount for Section 951AIncome amount column (i)</Description>
						<LineNumber>Schedule J Part I Line 2e(i)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Other Income Amount for Foreign Branch Income Amount Column (ii) -->
			<xsd:element name="ForeignBranchIncomeAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Other income amount for foreign branch income amount column (ii)</Description>
						<LineNumber>Schedule J Part I Line 2e(ii)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- Other Income Amount for Passive Category Income Amount Column (iii) -->
			<xsd:element name="PassiveCategoryIncomeAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Other income amount for passive category income amount column (iii)</Description>
						<LineNumber>Schedule J Part I Line 2e(iii)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>			
			
			<!-- Other Income Amount for General Category Income Amount Column (iv) -->
			<xsd:element name="GeneralCategoryIncomeAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Other income amount for general category income amount column (iv)</Description>
						<LineNumber>Schedule J Part I Line 2e(iv)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Other Income Amount for Column (v) -->
			<xsd:element name="OtherIncomeAmt" type="USAmountType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Other income amount for column (v)</Description>
						<LineNumber>Schedule J Part I Line 2e(v)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

		</xsd:sequence>
	</xsd:complexType>
	
	
	<!--Part I, Line 9e and Part II Line e -->
	<xsd:complexType name="SepLmtOtherIncmGrpType">
		<xsd:sequence>

			<!-- Select Income from Sanctioned Country to Which Section 901j Applies “901j” or Income Resourced Under a Tax Treaty “RBT” -->
			<xsd:element name="SeparateCategoryCd" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
