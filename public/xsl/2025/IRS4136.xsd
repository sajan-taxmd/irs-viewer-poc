<?xml version="1.0" encoding="UTF-8"?>
<xsd:schema xmlns="http://www.irs.gov/efile" xmlns:xsd="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.irs.gov/efile" elementFormDefault="qualified" attributeFormDefault="unqualified" version="1.0">
	<xsd:annotation>
		<xsd:documentation>
			<Description>IRS e-file Schema - Form 4136</Description>
			<TaxYear>2025</TaxYear>
			<MaturityLevel>Final Release</MaturityLevel>
			<ReleaseDate>February 19 2026</ReleaseDate>
		</xsd:documentation>
	</xsd:annotation>
	<xsd:include schemaLocation="../../../Common/efileTypes.xsd"/>
	<!-- ============================================================ -->
	<!-- =======================  IRS Form 4136 ===================== -->
	<!-- ============================================================ -->
	<xsd:element name="IRS4136">
		<xsd:annotation>
			<xsd:documentation>IRS Form 4136</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:complexContent>
				<xsd:extension base="IRS4136Type">
					<xsd:attributeGroup ref="DocumentAttributes">
						<xsd:annotation>
							<xsd:documentation>Common return document attributes</xsd:documentation>
						</xsd:annotation>
					</xsd:attributeGroup>
					<xsd:attribute name="documentName" type="xsd:string" fixed="IRS4136">
						<xsd:annotation>
							<xsd:documentation>IRS internal use only. To avoid error in the return, do not include the attribute name or value.</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
					<xsd:attribute name="referenceDocumentId" type="IdListType"/>
					<xsd:attribute name="referenceDocumentName" type="StringType" fixed="BinaryAttachment GeneralDependencySmall"/>
				</xsd:extension>
			</xsd:complexContent>
		</xsd:complexType>
	</xsd:element>
	<xsd:complexType name="IRS4136Type">
		<xsd:annotation>
			<xsd:documentation>Content model for Form 4136</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<!-- ========================= Part I ========================= -->
			<!-- Do you have a qualifying business or business activity with qualifying usage of qualifying fuels eligible for the Credit for Federal Tax on Fuels? -->
			<xsd:element name="QlfyUsageFuelsEligFTCInd" type="BooleanType">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Do you have a qualifying business or business activity with qualifying usage of qualifying fuels eligible for the Credit for Federal Tax on Fuels?</Description>
						<LineNumber>(A)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- If "Yes", how many different business activities do you have that qualify for this credit? -->
			<xsd:element name="QlfyBusinessActivitiesCnt" type="IntegerPosType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>If "Yes", how many different business activities do you have that qualify for this credit?</Description>
						<LineNumber>(B)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Business Name -->
			<xsd:element name="BusinessName" type="BusinessNameType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Business Name</Description>
						<LineNumber>(C)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- EIN -->
			<xsd:element name="EIN" type="EINType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>EIN</Description>
						<LineNumber>(D)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Principal Business Activity Code -->
			<xsd:element name="PrincipalBusinessActivityCd" type="BusinessActivityCodeType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Principal Business Activity Code</Description>
						<LineNumber>(E)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Equipment Type Description Group -->
			<xsd:element name="EquipmentDescriptionGrp" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>Equipment Type Description Group</Description>
								<LineNumber>(F)</LineNumber>
							</xsd:documentation>
						</xsd:annotation>
						<!-- Make -->
						<xsd:element name="MakeNm" type="TextType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Make</Description>
									<LineNumber>(F) (i)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Model -->
						<xsd:element name="ModelNm" type="TextType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Model</Description>
									<LineNumber>(F) (ii)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Type of equipment -->
						<xsd:element name="EquipmentTypeDesc" type="LineExplanationType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Type of equipment</Description>
									<LineNumber>(F) (iii)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<!-- ========================= Part II ========================= -->
			<!-- Other Nontaxable Use of Gasoline Group -->
			<xsd:element name="NontaxableUseOfGasolineGrp" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>Other Nontaxable Use of Gasoline Group</Description>
								<LineNumber>1 a, b, c</LineNumber>
							</xsd:documentation>
						</xsd:annotation>
						<!-- Off-highway business use of gasoline in gallons -->
						<xsd:element name="OffHwyBusUseGasolineGalsQty" type="FuelGallonsType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Off-highway business use of gasoline in gallons</Description>
									<LineNumber>1a(c)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Use of gasoline on a farm for farming purposes -->
						<xsd:element name="FarmingPurposesGasolineGalsQty" type="FuelGallonsType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Use of gasoline on a farm for farming purposes</Description>
									<LineNumber>1b(c)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Other Nontaxable Use of Gasoline Detail -->
						<xsd:element name="OtherNontaxableUseGasolineDtl" minOccurs="0" maxOccurs="7">
							<xsd:complexType>
								<xsd:sequence>
									<xsd:annotation>
										<xsd:documentation>
											<Description>Other Nontaxable Use of Gasoline Detail</Description>
											<LineNumber>1c</LineNumber>
										</xsd:documentation>
									</xsd:annotation>
									<!-- (a) -->
									<xsd:element name="NontaxableUseOfFuelTypeCd">
										<xsd:annotation>
											<xsd:documentation>
												<Description>(a)</Description>
												<LineNumber>1c(a)</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
										<xsd:simpleType>
											<xsd:restriction base="TextType">
												<xsd:enumeration value="04"/>
												<xsd:enumeration value="05"/>
												<xsd:enumeration value="07"/>
												<xsd:enumeration value="11"/>
												<xsd:enumeration value="13"/>
												<xsd:enumeration value="14"/>
												<xsd:enumeration value="15"/>
											</xsd:restriction>
										</xsd:simpleType>
									</xsd:element>
									<!-- (c) -->
									<xsd:element name="GallonsQty" type="FuelGallonsType">
										<xsd:annotation>
											<xsd:documentation>
												<Description>(c)</Description>
												<LineNumber>1c(c)</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
								</xsd:sequence>
							</xsd:complexType>
						</xsd:element>
						<!-- Actual fuel cost from your records -->
						<xsd:element name="ActualFuelCostAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Actual fuel cost from your records</Description>
									<LineNumber>1c(d)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Nontaxable use of gasoline credit -->
						<xsd:element name="NontaxableUseOfGasolineCrAmt" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Nontaxable use of gasoline credit</Description>
									<LineNumber>1c(e)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="USAmountNNType">
										<xsd:attribute name="creditReferenceNum" type="TextType" fixed="362" use="required"/>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<!-- Exported Nontaxable Use of Gasoline Group -->
			<xsd:element name="ExportedNontaxableUseGasGrp" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>Exported Nontaxable Use of Gasoline Group</Description>
								<LineNumber>1d</LineNumber>
							</xsd:documentation>
						</xsd:annotation>
						<!-- Exported noxtaxable use of gasoline - gallons -->
						<xsd:element name="ExportedNontxUseGasGalsQty" type="FuelGallonsType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Exported noxtaxable use of gasoline - gallons</Description>
									<LineNumber>1d(c)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Actual fuel cost from your records -->
						<xsd:element name="ActualFuelCostAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Actual fuel cost from your records</Description>
									<LineNumber>1d(d)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Exported noxtaxable use of gasoline - credit -->
						<xsd:element name="ExportedNontxUseOfGasCrAmt" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Exported noxtaxable use of gasoline - credit</Description>
									<LineNumber>1d(e)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="USAmountNNType">
										<xsd:attribute name="creditReferenceNum" type="TextType" fixed="411" use="required"/>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<!-- Use in commercial aviation -->
			<xsd:element name="CommercialAviationUseGasGrp" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>Use in commercial aviation</Description>
								<LineNumber>2a</LineNumber>
							</xsd:documentation>
						</xsd:annotation>
						<!-- Gasoline use in commercial aviation (other than foreign trade) -->
						<xsd:element name="AviationGasolineGallonsQty" type="FuelGallonsType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Gasoline use in commercial aviation (other than foreign trade)</Description>
									<LineNumber>2a(c)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Actual fuel cost from your records -->
						<xsd:element name="ActualFuelCostAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Actual fuel cost from your records</Description>
									<LineNumber>2a(d)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Amount of credit for gasoline use in commercial aviation (other than foreign trade) -->
						<xsd:element name="AviationGasolineCreditAmt" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amount of credit for gasoline use in commercial aviation (other than foreign trade)</Description>
									<LineNumber>2a(e)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="USAmountNNType">
										<xsd:attribute name="creditReferenceNum" type="TextType" fixed="354" use="required"/>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<!-- Other nontaxable use of aviation gasoline -->
			<xsd:element name="OthNontaxableAviationGasGrp" minOccurs="0" maxOccurs="8">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>Other nontaxable use of aviation gasoline</Description>
								<LineNumber>2b</LineNumber>
							</xsd:documentation>
						</xsd:annotation>
						<!-- (a) -->
						<xsd:element name="NontaxableUseOfFuelTypeCd">
							<xsd:annotation>
								<xsd:documentation>
									<Description>(a)</Description>
									<LineNumber>2b(a)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="TextType">
									<xsd:enumeration value="01"/>
									<xsd:enumeration value="02"/>
									<xsd:enumeration value="09"/>
									<xsd:enumeration value="10"/>
									<xsd:enumeration value="11"/>
									<xsd:enumeration value="13"/>
									<xsd:enumeration value="14"/>
									<xsd:enumeration value="15"/>
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:element>
						<!-- (c) -->
						<xsd:element name="GallonsQty" type="FuelGallonsType">
							<xsd:annotation>
								<xsd:documentation>
									<Description>(c)</Description>
									<LineNumber>2b(c)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<!-- Other nontaxable use of aviation gasoline - Actual fuel cost from your records -->
			<xsd:element name="AviationNontxGasActlFlCstAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Other nontaxable use of aviation gasoline - Actual fuel cost from your records</Description>
						<LineNumber>2b(d)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Amount of credit for other nontaxable use of aviation gasoline -->
			<xsd:element name="AviationNontxGasCrAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Amount of credit for other nontaxable use of aviation gasoline</Description>
						<LineNumber>2b(e)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="USAmountNNType">
							<xsd:attribute name="creditReferenceNum" type="TextType" fixed="324" use="required"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="ExportedNontaxAviationGasGrp" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<LineNumber>2c</LineNumber>
							</xsd:documentation>
						</xsd:annotation>
						<!-- Exported nontaxable aviation gasoline - gallons -->
						<xsd:element name="ExpNontxAviationGasGalsQty" type="FuelGallonsType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Exported nontaxable aviation gasoline - gallons</Description>
									<LineNumber>2c(c)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Actual fuel cost from your records -->
						<xsd:element name="ActualFuelCostAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Actual fuel cost from your records</Description>
									<LineNumber>2c(d)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Exported nontaxable aviation gasoline - credit -->
						<xsd:element name="ExpNontxAviationGasCrAmt" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Exported nontaxable aviation gasoline - credit</Description>
									<LineNumber>2c(e)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="USAmountNNType">
										<xsd:attribute name="creditReferenceNum" type="TextType" fixed="412" use="required"/>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<!-- LUST Tax Aviation Fuel Foreign Trade Group -->
			<xsd:element name="LUSTTxAvnFuelFrgnTradeGrp" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>LUST Tax Aviation Fuel Foreign Trade Group</Description>
								<LineNumber>2d</LineNumber>
							</xsd:documentation>
						</xsd:annotation>
						<!-- Exported nontaxable aviation gasoline - gallons -->
						<xsd:element name="LUSTTxAvnFuelFrgnTradeGalsQty" type="FuelGallonsType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Exported nontaxable aviation gasoline - gallons</Description>
									<LineNumber>2d(c)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Actual fuel cost from your records -->
						<xsd:element name="ActualFuelCostAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Actual fuel cost from your records</Description>
									<LineNumber>2d(d)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- LUST tax aviation fuel - credit -->
						<xsd:element name="LUSTTxAvnFuelFrgnTradeCrAmt" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>LUST tax aviation fuel - credit</Description>
									<LineNumber>2d(e)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="USAmountNNType">
										<xsd:attribute name="creditReferenceNum" type="TextType" fixed="433" use="required"/>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<!-- Exception to Nontaxable Use of Undyed Diesel -->
			<xsd:element name="UndyedDieselUseExceptionInd" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Diesel fuel contains visible evidence of dye</Description>
						<LineNumber>3</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="CheckboxType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="EvidenceOfDyedDieselFuelStatement"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Nontaxable use of Undyed Diesel Fuel Group -->
			<xsd:element name="NontaxableUseUndyedDieselGrp" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>Nontaxable use of Undyed Diesel Fuel Group</Description>
								<LineNumber>3 a, b</LineNumber>
							</xsd:documentation>
						</xsd:annotation>
						<!-- Nontaxable use of Undyed Diesel Detail -->
						<xsd:element name="NontaxableUseOfUndyedDieselDtl" minOccurs="0" maxOccurs="8">
							<xsd:complexType>
								<xsd:sequence>
									<xsd:annotation>
										<xsd:documentation>
											<Description>Other Nontaxable Use of Gasoline Detail</Description>
											<LineNumber>3a(a)</LineNumber>
										</xsd:documentation>
									</xsd:annotation>
									<!-- (a) -->
									<xsd:element name="NontaxableUseOfFuelTypeCd">
										<xsd:annotation>
											<xsd:documentation>
												<Description>(a)</Description>
												<LineNumber>3a(a)</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
										<xsd:simpleType>
											<xsd:restriction base="TextType">
												<xsd:enumeration value="02"/>
												<xsd:enumeration value="06"/>
												<xsd:enumeration value="07"/>
												<xsd:enumeration value="08"/>
												<xsd:enumeration value="11"/>
												<xsd:enumeration value="13"/>
												<xsd:enumeration value="14"/>
												<xsd:enumeration value="15"/>
											</xsd:restriction>
										</xsd:simpleType>
									</xsd:element>
									<!-- (c) -->
									<xsd:element name="GallonsQty" type="FuelGallonsType">
										<xsd:annotation>
											<xsd:documentation>
												<Description>(c)</Description>
												<LineNumber>3a(c)</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
								</xsd:sequence>
							</xsd:complexType>
						</xsd:element>
						<!-- Use on farm undyed diesel fuel - gallons -->
						<xsd:element name="FarmPrpsUndyedDslFuelGalsQty" type="FuelGallonsType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Use on farm undyed diesel fuel - gallons</Description>
									<LineNumber>3b(c)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Actual fuel cost from your records -->
						<xsd:element name="ActualFuelCostAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Actual fuel cost from your records</Description>
									<LineNumber>3b(d)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Use on farm undyed diesel fuel/nontaxable - credit -->
						<xsd:element name="FarmPrpsUndyedDslFuelCrAmt" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Use on farm undyed diesel fuel/nontaxable - credit</Description>
									<LineNumber>3b(e)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="USAmountNNType">
										<xsd:attribute name="creditReferenceNum" type="TextType" fixed="360" use="required"/>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<!-- Train Use of Undyed Diesel Fuel Group -->
			<xsd:element name="TrainsUseUndyedDieselFuelGrp" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>Train Use of Undyed Diesel Fuel Group</Description>
								<LineNumber>Line 3c</LineNumber>
							</xsd:documentation>
						</xsd:annotation>
						<!-- Use of undyed diesel fuel in trains -->
						<xsd:element name="TrainUseOfUndyedDieselGalsQty" type="FuelGallonsType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Use of undyed diesel fuel in trains</Description>
									<LineNumber>3c(c)</LineNumber>
								</xsd:documentation>
