<?xml version="1.0" encoding="UTF-8"?>
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns="http://www.irs.gov/efile" targetNamespace="http://www.irs.gov/efile" elementFormDefault="qualified" attributeFormDefault="unqualified">
	<xsd:annotation>
		<xsd:documentation>
			<Description>IRS e-file Schema - Form 4255</Description>
			<TaxYear>2025</TaxYear>
			<MaturityLevel>Final Release</MaturityLevel>
			<ReleaseDate>February 19 2026</ReleaseDate>
		</xsd:documentation>
	</xsd:annotation>
	<xsd:include schemaLocation="../../../Common/efileTypes.xsd"/>
	<!-- =============================================================== -->
	<!-- ======================  IRS Form 4255 ============================ -->
	<!-- =============================================================== -->
	<xsd:element name="IRS4255">
		<xsd:annotation>
			<xsd:documentation>IRS Form 4255</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:complexContent>
				<xsd:extension base="IRS4255Type">
					<xsd:attributeGroup ref="DocumentAttributes">
						<xsd:annotation>
							<xsd:documentation>Common return document attributes</xsd:documentation>
						</xsd:annotation>
					</xsd:attributeGroup>
					<xsd:attribute name="documentName" type="xsd:string" fixed="IRS4255">
						<xsd:annotation>
							<xsd:documentation>IRS internal use only. To avoid error in the return, do not include the attribute name or value.</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
					<xsd:attribute name="referenceDocumentId" type="IdListType"/>
					<xsd:attribute name="referenceDocumentName" type="StringType" fixed="GeneralDependencySmall"/>
				</xsd:extension>
			</xsd:complexContent>
		</xsd:complexType>
	</xsd:element>
	
	<xsd:complexType name="IRS4255Type">
		<xsd:annotation>
			<xsd:documentation>Content model for Form 4255</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
		
			<!-- Part I -->
			
			<!-- Form 7207 Prior Year Credits Group -->
			<xsd:element name="Form7207PYCreditsGrp" minOccurs="0" maxOccurs="unbounded">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>Form 7207 Prior Year Credits Group</Description>
								<LineNumber>Part I, Line 1a column a, b, c, d, e, f, m1,m2 n1, n2, n3, q, r, s, t</LineNumber>
							</xsd:documentation>
						</xsd:annotation>

						<!-- Credit or deduction claimed in prior year(s) (as adjusted, if applicable) -->
						<xsd:element name="PYCrClmAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Credit or deduction claimed in prior year(s) (as adjusted, if applicable)</Description>
									<LineNumber>Part I column (a)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Gross EPE payment amount portion of column (PYCrClmAmt) -->
						<xsd:element name="PYGroEPEPrtnCrClmAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Gross EPE payment amount portion of column (PYCrClmAmt)</Description>
									<LineNumber>Part I column (b)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Gross EPE in column (PYGroEPEPrtnCrClmAmt) applied against regular tax -->
						<xsd:element name="PYGroEPEPrtnAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Gross EPE in column (PYGroEPEPrtnCrClmAmt) applied against regular tax</Description>
									<LineNumber>Part I column (c)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Net EPE Subtract column (PYGroEPEPrtnAppRegTaxAmt) from column (PYGroEPEPrtnCrClmAmt) -->
						<xsd:element name="PYNetEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Net EPE Subtract column (PYGroEPEPrtnAppRegTaxAmt) from column (PYGroEPEPrtnCrClmAmt)</Description>
									<LineNumber>Part I column (d)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Non-EPE credit (excess of column (PYCrClmAmt) over column (PYGroEPEPrtnCrClmAmt)) that was applied against regular tax -->
						<xsd:element name="PYNonEPECrExAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Non-EPE credit (excess of column (PYCrClmAmt) over column (PYGroEPEPrtnCrClmAmt)) that was applied against regular tax</Description>
									<LineNumber>Part I column (e)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Carryover. Subtract the sum of columns (PYGroEPEPrtnCrClmAmt) and (PYNonEPECrExAppRegTaxAmt) from column (PYCrClmAmt) -->
						<xsd:element name="PYCarryoverAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Carryover. Subtract the sum of columns (PYGroEPEPrtnCrClmAmt) and (PYNonEPECrExAppRegTaxAmt) from column (PYCrClmAmt)</Description>
									<LineNumber>Part I column (f)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Section 6418(g)(2)(A)(i) excessive credit transfer -->
						<xsd:element name="Sect6418g2AiExCrTrnsfrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Section 6418(g)(2)(A)(i) excessive credit transfer</Description>
									<LineNumber>Part I column (m)(1)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Section 6418(g)(2)(A)(ii) 20% of excessive credit transfer -->
						<xsd:element name="Sect6418g2Aii20ExCrTrnsfrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Section 6418(g)(2)(A)(ii) 20% of excessive credit transfer</Description>
									<LineNumber>Part I column (m)(2)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP related to a gross EPE in column (PYGroEPEPrtnCrClmAmt), enter the net EPE portion from column (PYNetEPEAmt).  -->
						<xsd:element name="NetEPEPortionAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP related to a gross EPE in column (PYGroEPEPrtnCrClmAmt), enter the net EPE portion from column (PYNetEPEAmt). </Description>
									<LineNumber>Part I column (n)(1)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP, enter the portion of the EP not in column (NetEPEPortionAmt) (excluding any 20% EP)  -->
						<xsd:element name="PortionEPExcld20pctAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP, enter the portion of the EP not in column (NetEPEPortionAmt) (excluding any 20% EP) </Description>
									<LineNumber>Part I column (n)(2)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP, enter any 20% EP you owe -->
						<xsd:element name="EP20PctOweAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP, enter any 20% EP you owe</Description>
									<LineNumber>Part I column (n)(3)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Amounts that can be reduced by nonrefundable credits -->
						<xsd:element name="RedByNonRfdblCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amounts that can be reduced by nonrefundable credits</Description>
									<LineNumber>Part I column (q)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Amount that cannot be reduced by nonrefundable credits -->
						<xsd:element name="NotRedByNonRfdblCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amount that cannot be reduced by nonrefundable credits</Description>
									<LineNumber>Part I column (r)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Add columns (l) and (n)(1) -->
						<xsd:element name="TotalRcptrNetEPEExPymt100CrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Add columns (l) and (n)(1)</Description>
									<LineNumber>Part I column (s)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Add columns(n)(3), (o)(1),(o)(2), (p)(1) and (p)(2) -->
						<xsd:element name="TotEx20PrvlWgAprntcshpPnltyAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Add columns(n)(3), (o)(1),(o)(2), (p)(1) and (p)(2)</Description>
									<LineNumber>Part I column (t)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>


				</xsd:sequence>
			</xsd:complexType>
			</xsd:element>

			<!-- Form 3468 part III prior year credits group  -->
			<xsd:element name="Form3468PartIIIPYCreditsGrp" type="Form3468PYCreditsType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Form 3468 part III prior year credits group </Description>
						<LineNumber>Part I, Line1b column a,b,c,d,e,f,g,h ,i, j, k, l, m1,m2,m3, n1,n2,n3, o1,o2,o3, p1,p2,p3, q,r,s,t</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Form 7210 Prior Year Credits Group -->
			<xsd:element name="Form7210PYCreditsGrp" type="Form4255PYCredits2Type" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Form 7210 Prior Year Credits Group</Description>
						<LineNumber>Part I, Line1c column a, b, c, d, e, f, m1,m2, n1,n2,n3, o1,o2,o3, p1,p2,p3, q, r, s, t</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Form 3468 Part IV Prior Year Credits Group -->
			<xsd:element name="Form3468PartIVPYCreditsGrp" minOccurs="0" maxOccurs="unbounded">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>Form 3468 Part IV Prior Year Credits Group</Description>
								<LineNumber>Part I, Line 1d column a, b, c, d, e, f, g, h, i, j, k, l, n1, n2, n3, q, r, s, t</LineNumber>
							</xsd:documentation>
						</xsd:annotation>

						<!-- Credit or deduction claimed in prior year(s) (as adjusted, if applicable) -->
						<xsd:element name="PYCrClmAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Credit or deduction claimed in prior year(s) (as adjusted, if applicable)</Description>
									<LineNumber>Part I column (a)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Gross EPE payment amount portion of column (PYCrClmAmt) -->
						<xsd:element name="PYGroEPEPrtnCrClmAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Gross EPE payment amount portion of column (PYCrClmAmt)</Description>
									<LineNumber>Part I column (b)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Gross EPE in column (PYGroEPEPrtnCrClmAmt) applied against regular tax -->
						<xsd:element name="PYGroEPEPrtnAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Gross EPE in column (PYGroEPEPrtnCrClmAmt) applied against regular tax</Description>
									<LineNumber>Part I column (c)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Net EPE Subtract column (PYGroEPEPrtnAppRegTaxAmt) from column (PYGroEPEPrtnCrClmAmt) -->
						<xsd:element name="PYNetEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Net EPE Subtract column (PYGroEPEPrtnAppRegTaxAmt) from column (PYGroEPEPrtnCrClmAmt)</Description>
									<LineNumber>Part I column (d)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Non-EPE credit (excess of column (PYCrClmAmt) over column (PYGroEPEPrtnCrClmAmt)) that was applied against regular tax -->
						<xsd:element name="PYNonEPECrExAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Non-EPE credit (excess of column (PYCrClmAmt) over column (PYGroEPEPrtnCrClmAmt)) that was applied against regular tax</Description>
									<LineNumber>Part I column (e)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Carryover. Subtract the sum of columns (PYGroEPEPrtnCrClmAmt) and (PYNonEPECrExAppRegTaxAmt) from column (PYCrClmAmt) -->
						<xsd:element name="PYCarryoverAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Carryover. Subtract the sum of columns (PYGroEPEPrtnCrClmAmt) and (PYNonEPECrExAppRegTaxAmt) from column (PYCrClmAmt)</Description>
									<LineNumber>Part I column (f)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
			
						<xsd:choice minOccurs="0">
			
							<!-- Recapture percentage. -->
							<xsd:element name="RecapturePct" type="RatioType">
								<xsd:annotation>
									<xsd:documentation>
										<Description>Recapture percentage.</Description>
										<LineNumber>Part I column (g)</LineNumber>
									</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
			
							<!-- Recapture percentage. Enter "N/A" if more than one recapture event on one line -->
							<xsd:element name="RecapturePctNACd">
								<xsd:annotation>
									<xsd:documentation>
										<Description>Recapture percentage. Enter "N/A" if more than one recapture event on one line</Description>
										<LineNumber>Part I column (g)</LineNumber>
									</xsd:documentation>
								</xsd:annotation>
								<xsd:simpleType>
									<xsd:restriction base="TextType">
										<xsd:enumeration value="N/A"/>
									</xsd:restriction>
								</xsd:simpleType>
							</xsd:element>
			
						</xsd:choice>

						<!-- Amount of column (PYCrClmAmt) recaptured, including reduction of carryover. See instructions for basis increase -->
						<xsd:element name="RcptrTotCrRedCyovAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amount of column (PYCrClmAmt) recaptured, including reduction of carryover. See instructions for basis increase</Description>
									<LineNumber>Part I column (h)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Portion of column (RcptrTotCrRedCyovAmt) reducing credit carryover in column (PYCarryoverAmt) -->
						<xsd:element name="RcptrPrtnRdcngCrCyovAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Portion of column (RcptrTotCrRedCyovAmt) reducing credit carryover in column (PYCarryoverAmt)</Description>
									<LineNumber>Part I column (i)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Portion of column (RcptrTotCrRedCyovAmt) recapturing Non-EPE credit applied against regular tax in column (PYNonEPECrExAppRegTaxAmt) -->
						<xsd:element name="RcptrPrtnNonEPECrAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Portion of column (RcptrTotCrRedCyovAmt) recapturing Non-EPE credit applied against regular tax in column (PYNonEPECrExAppRegTaxAmt)</Description>
									<LineNumber>Part I column (j)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Portion of column (RcptrTotCrRedCyovAmt) recapturing gross EPE amount applied against regular tax from column (PYGroEPEPrtnAppRegTaxAmt) -->
						<xsd:element name="RcptrPrtnEPEAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Portion of column (RcptrTotCrRedCyovAmt) recapturing gross EPE amount applied against regular tax from column (PYGroEPEPrtnAppRegTaxAmt)</Description>
									<LineNumber>Part I column (k)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Portion of column (RcptrTotCrRedCyovAmt) recapturing Net EPE amount from column (PYNetEPEAmt) -->
						<xsd:element name="RcptrPrtnNetEPECrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Portion of column (RcptrTotCrRedCyovAmt) recapturing Net EPE amount from column (PYNetEPEAmt)</Description>
									<LineNumber>Part I column (l)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP related to a gross EPE in column (PYGroEPEPrtnCrClmAmt), enter the net EPE portion from column (PYNetEPEAmt).  -->
						<xsd:element name="NetEPEPortionAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP related to a gross EPE in column (PYGroEPEPrtnCrClmAmt), enter the net EPE portion from column (PYNetEPEAmt). </Description>
									<LineNumber>Part I column (n)(1)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP, enter the portion of the EP not in column (NetEPEPortionAmt) (excluding any 20% EP)  -->
						<xsd:element name="PortionEPExcld20pctAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP, enter the portion of the EP not in column (NetEPEPortionAmt) (excluding any 20% EP) </Description>
									<LineNumber>Part I column (n)(2)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP, enter any 20% EP you owe -->
						<xsd:element name="EP20PctOweAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP, enter any 20% EP you owe</Description>
									<LineNumber>Part I column (n)(3)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Amounts that can be reduced by nonrefundable credits -->
						<xsd:element name="RedByNonRfdblCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amounts that can be reduced by nonrefundable credits</Description>
									<LineNumber>Part I column (q)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Amount that cannot be reduced by nonrefundable credits -->
						<xsd:element name="NotRedByNonRfdblCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amount that cannot be reduced by nonrefundable credits</Description>
									<LineNumber>Part I column (r)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Add columns (l) and (n)(1) -->
						<xsd:element name="TotalRcptrNetEPEExPymt100CrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Add columns (l) and (n)(1)</Description>
									<LineNumber>Part I column (s)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Add columns(n)(3), (o)(1),(o)(2), (p)(1) and (p)(2) -->
						<xsd:element name="TotEx20PrvlWgAprntcshpPnltyAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Add columns(n)(3), (o)(1),(o)(2), (p)(1) and (p)(2)</Description>
									<LineNumber>Part I column (t)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
			
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>

			<!-- Form 7218 Prior Year Credits Group -->
			<xsd:element name="Form7218PYCreditsGrp"  type="Form4255PYCredits2Type" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Form 7218 Prior Year Credits Group</Description>
						<LineNumber>Part I, Line 1e column a,b,c,d,e,f, m1,m2, n1,n2,n3, o1,o2,o3, p1,p2,p3, q,r,s,t</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Form 7213 Part II Prior Year Credits Group -->
			<xsd:element name="Form7213PartIIPYCreditsGrp" minOccurs="0" maxOccurs="unbounded">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>Form 7213 Part II Prior Year Credits Group</Description>
								<LineNumber>Part I, Line 1f column a, b, c, d, e, f, m1, m2, n1, n2, n3, o1, o2, o3, q, r, s, t</LineNumber>
							</xsd:documentation>
						</xsd:annotation>

						<!-- Credit or deduction claimed in prior year(s) (as adjusted, if applicable) -->
						<xsd:element name="PYCrClmAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Credit or deduction claimed in prior year(s) (as adjusted, if applicable)</Description>
									<LineNumber>Part I column (a)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Gross EPE payment amount portion of column (PYCrClmAmt) -->
						<xsd:element name="PYGroEPEPrtnCrClmAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Gross EPE payment amount portion of column (PYCrClmAmt)</Description>
									<LineNumber>Part I column (b)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Gross EPE in column (PYGroEPEPrtnCrClmAmt) applied against regular tax -->
						<xsd:element name="PYGroEPEPrtnAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Gross EPE in column (PYGroEPEPrtnCrClmAmt) applied against regular tax</Description>
									<LineNumber>Part I column (c)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Net EPE Subtract column (PYGroEPEPrtnAppRegTaxAmt) from column (PYGroEPEPrtnCrClmAmt) -->
						<xsd:element name="PYNetEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Net EPE Subtract column (PYGroEPEPrtnAppRegTaxAmt) from column (PYGroEPEPrtnCrClmAmt)</Description>
									<LineNumber>Part I column (d)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Non-EPE credit (excess of column (PYCrClmAmt) over column (PYGroEPEPrtnCrClmAmt)) that was applied against regular tax -->
						<xsd:element name="PYNonEPECrExAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Non-EPE credit (excess of column (PYCrClmAmt) over column (PYGroEPEPrtnCrClmAmt)) that was applied against regular tax</Description>
									<LineNumber>Part I column (e)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Carryover. Subtract the sum of columns (PYGroEPEPrtnCrClmAmt) and (PYNonEPECrExAppRegTaxAmt) from column (PYCrClmAmt) -->
						<xsd:element name="PYCarryoverAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Carryover. Subtract the sum of columns (PYGroEPEPrtnCrClmAmt) and (PYNonEPECrExAppRegTaxAmt) from column (PYCrClmAmt)</Description>
									<LineNumber>Part I column (f)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Section 6418(g)(2)(A)(i) excessive credit transfer -->
						<xsd:element name="Sect6418g2AiExCrTrnsfrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Section 6418(g)(2)(A)(i) excessive credit transfer</Description>
									<LineNumber>Part I column (m)(1)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Section 6418(g)(2)(A)(ii) 20% of excessive credit transfer -->
						<xsd:element name="Sect6418g2Aii20ExCrTrnsfrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Section 6418(g)(2)(A)(ii) 20% of excessive credit transfer</Description>
									<LineNumber>Part I column (m)(2)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP related to a gross EPE in column (PYGroEPEPrtnCrClmAmt), enter the net EPE portion from column (PYNetEPEAmt).  -->
						<xsd:element name="NetEPEPortionAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP related to a gross EPE in column (PYGroEPEPrtnCrClmAmt), enter the net EPE portion from column (PYNetEPEAmt). </Description>
									<LineNumber>Part I column (n)(1)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP, enter the portion of the EP not in column (NetEPEPortionAmt) (excluding any 20% EP)  -->
						<xsd:element name="PortionEPExcld20pctAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP, enter the portion of the EP not in column (NetEPEPortionAmt) (excluding any 20% EP) </Description>
									<LineNumber>Part I column (n)(2)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP, enter any 20% EP you owe -->
						<xsd:element name="EP20PctOweAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP, enter any 20% EP you owe</Description>
									<LineNumber>Part I column (n)(3)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Prevailing wage penalty amounts related to a net EPE amount -->
						<xsd:element name="PrvlWagePnltyRltdNetEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Prevailing wage penalty amounts related to a net EPE amount</Description>
									<LineNumber>Part I column (o)(1)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Prevailing wage penalty amounts related to a non-net EPE amount -->
						<xsd:element name="PrvlWagePnltyRltdNonNetEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Prevailing wage penalty amounts related to a non-net EPE amount</Description>
									<LineNumber>Part I column (o)(2)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Prevailing wage penalty amounts not related to an EPE amount -->
						<xsd:element name="PrvlWagePnltyNotRltdEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Prevailing wage penalty amounts not related to an EPE amount</Description>
									<LineNumber>Part I column (o)(3)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Amounts that can be reduced by nonrefundable credits -->
						<xsd:element name="RedByNonRfdblCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amounts that can be reduced by nonrefundable credits</Description>
									<LineNumber>Part I column (q)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Amount that cannot be reduced by nonrefundable credits -->
						<xsd:element name="NotRedByNonRfdblCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amount that cannot be reduced by nonrefundable credits</Description>
									<LineNumber>Part I column (r)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Add columns (l) and (n)(1) -->
						<xsd:element name="TotalRcptrNetEPEExPymt100CrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Add columns (l) and (n)(1)</Description>
									<LineNumber>Part I column (s)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Add columns(n)(3), (o)(1),(o)(2), (p)(1) and (p)(2) -->
						<xsd:element name="TotEx20PrvlWgAprntcshpPnltyAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Add columns(n)(3), (o)(1),(o)(2), (p)(1) and (p)(2)</Description>
									<LineNumber>Part I column (t)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
			
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			
			<!-- Form 3468 Part V Prior Year Credits Group  -->
			<xsd:element name="Form3468PartVPYCreditsGrp" type="Form3468PYCreditsType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Form 3468 Part V Prior Year Credits Group </Description>
						<LineNumber>Part I, Line1g column a,b,c,d,e,f,g,h ,i, j, k, l, m1,m2,m3, n1,n2,n3, o1,o2,o3, p1,p2,p3, q,r,s,t</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Form 8936 Part V Prior Year Credits Group -->
			<xsd:element name="Form8936PartVPYCreditsGrp" minOccurs="0" maxOccurs="unbounded">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>Form 8936 Part V Prior Year Credits Group</Description>
								<LineNumber>Part I Line 1h column a, b, c, d, e, f, g, h, i, j, k, l, n1, n2, n3, q, r, s, t</LineNumber>
							</xsd:documentation>
						</xsd:annotation>

						<!-- Credit or deduction claimed in prior year(s) (as adjusted, if applicable) -->
						<xsd:element name="PYCrClmAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Credit or deduction claimed in prior year(s) (as adjusted, if applicable)</Description>
									<LineNumber>Part I column (a)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Gross EPE payment amount portion of column (PYCrClmAmt) -->
						<xsd:element name="PYGroEPEPrtnCrClmAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Gross EPE payment amount portion of column (PYCrClmAmt)</Description>
									<LineNumber>Part I column (b)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Gross EPE in column (PYGroEPEPrtnCrClmAmt) applied against regular tax -->
						<xsd:element name="PYGroEPEPrtnAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Gross EPE in column (PYGroEPEPrtnCrClmAmt) applied against regular tax</Description>
									<LineNumber>Part I column (c)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Net EPE Subtract column (PYGroEPEPrtnAppRegTaxAmt) from column (PYGroEPEPrtnCrClmAmt) -->
						<xsd:element name="PYNetEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Net EPE Subtract column (PYGroEPEPrtnAppRegTaxAmt) from column (PYGroEPEPrtnCrClmAmt)</Description>
									<LineNumber>Part I column (d)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Non-EPE credit (excess of column (PYCrClmAmt) over column (PYGroEPEPrtnCrClmAmt)) that was applied against regular tax -->
						<xsd:element name="PYNonEPECrExAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Non-EPE credit (excess of column (PYCrClmAmt) over column (PYGroEPEPrtnCrClmAmt)) that was applied against regular tax</Description>
									<LineNumber>Part I column (e)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Carryover. Subtract the sum of columns (PYGroEPEPrtnCrClmAmt) and (PYNonEPECrExAppRegTaxAmt) from column (PYCrClmAmt) -->
						<xsd:element name="PYCarryoverAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Carryover. Subtract the sum of columns (PYGroEPEPrtnCrClmAmt) and (PYNonEPECrExAppRegTaxAmt) from column (PYCrClmAmt)</Description>
									<LineNumber>Part I column (f)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<xsd:choice minOccurs="0">

							<!-- Recapture percentage. -->
							<xsd:element name="RecapturePct" type="RatioType">
								<xsd:annotation>
									<xsd:documentation>
										<Description>Recapture percentage.</Description>
										<LineNumber>Part I column (g)</LineNumber>
									</xsd:documentation>
								</xsd:annotation>
							</xsd:element>

							<!-- Recapture percentage. Enter "N/A" if more than one recapture event on one line -->
							<xsd:element name="RecapturePctNACd">
								<xsd:annotation>
									<xsd:documentation>
										<Description>Recapture percentage. Enter "N/A" if more than one recapture event on one line</Description>
										<LineNumber>Part I column (g)</LineNumber>
									</xsd:documentation>
								</xsd:annotation>
								<xsd:simpleType>
									<xsd:restriction base="TextType">
										<xsd:enumeration value="N/A"/>
									</xsd:restriction>
								</xsd:simpleType>
							</xsd:element>

						</xsd:choice>

						<!-- Amount of column (PYCrClmAmt) recaptured, including reduction of carryover. See instructions for basis increase -->
						<xsd:element name="RcptrTotCrRedCyovAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amount of column (PYCrClmAmt) recaptured, including reduction of carryover. See instructions for basis increase</Description>
									<LineNumber>Part I column (h)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Portion of column (RcptrTotCrRedCyovAmt) reducing credit carryover in column (PYCarryoverAmt) -->
						<xsd:element name="RcptrPrtnRdcngCrCyovAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Portion of column (RcptrTotCrRedCyovAmt) reducing credit carryover in column (PYCarryoverAmt)</Description>
									<LineNumber>Part I column (i)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Portion of column (RcptrTotCrRedCyovAmt) recapturing Non-EPE credit applied against regular tax in column (PYNonEPECrExAppRegTaxAmt) -->
						<xsd:element name="RcptrPrtnNonEPECrAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Portion of column (RcptrTotCrRedCyovAmt) recapturing Non-EPE credit applied against regular tax in column (PYNonEPECrExAppRegTaxAmt)</Description>
									<LineNumber>Part I column (j)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Portion of column (RcptrTotCrRedCyovAmt) recapturing gross EPE amount applied against regular tax from column (PYGroEPEPrtnAppRegTaxAmt) -->
						<xsd:element name="RcptrPrtnEPEAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Portion of column (RcptrTotCrRedCyovAmt) recapturing gross EPE amount applied against regular tax from column (PYGroEPEPrtnAppRegTaxAmt)</Description>
									<LineNumber>Part I column (k)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Portion of column (RcptrTotCrRedCyovAmt) recapturing Net EPE amount from column (PYNetEPEAmt) -->
						<xsd:element name="RcptrPrtnNetEPECrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Portion of column (RcptrTotCrRedCyovAmt) recapturing Net EPE amount from column (PYNetEPEAmt)</Description>
									<LineNumber>Part I column (l)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP related to a gross EPE in column (PYGroEPEPrtnCrClmAmt), enter the net EPE portion from column (PYNetEPEAmt).  -->
						<xsd:element name="NetEPEPortionAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP related to a gross EPE in column (PYGroEPEPrtnCrClmAmt), enter the net EPE portion from column (PYNetEPEAmt). </Description>
									<LineNumber>Part I column (n)(1)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP, enter the portion of the EP not in column (NetEPEPortionAmt) (excluding any 20% EP)  -->
						<xsd:element name="PortionEPExcld20pctAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP, enter the portion of the EP not in column (NetEPEPortionAmt) (excluding any 20% EP) </Description>
									<LineNumber>Part I column (n)(2)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP, enter any 20% EP you owe -->
						<xsd:element name="EP20PctOweAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP, enter any 20% EP you owe</Description>
									<LineNumber>Part I column (n)(3)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Amounts that can be reduced by nonrefundable credits -->
						<xsd:element name="RedByNonRfdblCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amounts that can be reduced by nonrefundable credits</Description>
									<LineNumber>Part I column (q)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Amount that cannot be reduced by nonrefundable credits -->
						<xsd:element name="NotRedByNonRfdblCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amount that cannot be reduced by nonrefundable credits</Description>
									<LineNumber>Part I column (r)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Add columns (l) and (n)(1) -->
						<xsd:element name="TotalRcptrNetEPEExPymt100CrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Add columns (l) and (n)(1)</Description>
									<LineNumber>Part I column (s)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Add columns(n)(3), (o)(1),(o)(2), (p)(1) and (p)(2) -->
						<xsd:element name="TotEx20PrvlWgAprntcshpPnltyAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Add columns(n)(3), (o)(1),(o)(2), (p)(1) and (p)(2)</Description>
									<LineNumber>Part I column (t)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>

