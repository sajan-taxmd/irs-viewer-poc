								<xsd:documentation>
									<Description>Apprenticeship penalty amounts not related to an EPE amount</Description>
									<LineNumber>Part I column (p)(3)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Amount that cannot be reduced by nonrefundable credits -->
						<xsd:element name="NotRedByNonRfdblCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amount that cannot be reduced by nonrefundable credits</Description>
									<LineNumber>Part I column (r)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>

			<!-- Other Line 1 Amount Prior Year Credits Group -->
			<xsd:element name="OtherAmount1Grp" type="Form3468PYCreditsType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Other Line 1 Amount Prior Year Credits Group</Description>
						<LineNumber>Part I, Line 1z column a,b,c,d,e,f,g,h,I,j,k,l, m1,m2,m3, n1,n2,n3, o1,o2,o3, p1,p2,p3, q,r,s,t</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Form 8933 Prior Year Credits Group -->
			<xsd:element name="Form8933PYCreditsGrp" type="Form4255PYCredits3Type" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Form 8933 Prior Year Credits Group</Description>
						<LineNumber>Part I, Line 2a column a,b,c,d,e,f,g, h, i, j, k, l, m1,m2, n1,n2,n3, o1,o2,o3, p1,p2,p3, q,r,s,t </LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Form 8911 Prior Year Credits Group -->
			<xsd:element name="Form8911PYCreditsGrp" type="Form4255PYCredits3Type" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Form 8911 Prior Year Credits Group</Description>
						<LineNumber>Part I, Line 2b column a,b,c,d, e,f,g,h, i, j, k, l, m1,m2, n1,n2,n3, o1,o2,o3, p1,p2,p3, q,r,s,t </LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Other Line 2 Amount Prior Year Credits Group -->
			<xsd:element name="OtherAmount2Grp" type="Form3468PYCreditsType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Other Line 2 Amount Prior Year Credits Group</Description>
						<LineNumber>Part I, Line 2z column a,b,c,d,e,f,g,h,i,j,k,l, m1,m2,m3, n1 n2,n3, o1,o2,o3, p1,p2,p3, q,r,s t</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Total Amounts Prior Year Credits Group -->
			<xsd:element name="TotalAmountsPYCreditsGrp" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>Total Amounts Prior Year Credits Group</Description>
								<LineNumber>Part I, Line 3 column a,b,c,d, e, f, h, i, j, k, l, m1,m2,m3, n1,n2,n3, o1,o2,o3 p1,p2,p3, q,r,s,t</LineNumber>
							</xsd:documentation>
						</xsd:annotation>

						<!-- Credit or deduction claimed in prior year(s) (as adjusted, if applicable) -->
						<xsd:element name="PYCrClmAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Credit or deduction claimed in prior year(s) (as adjusted, if applicable)</Description>
									<LineNumber>Part I column (a)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Gross EPE payment amount portion of column (PYCrClmAmt) -->
						<xsd:element name="PYGroEPEPrtnCrClmAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Gross EPE payment amount portion of column (PYCrClmAmt)</Description>
									<LineNumber>Part I column (b)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Gross EPE in column (PYGroEPEPrtnCrClmAmt) applied against regular tax -->
						<xsd:element name="PYGroEPEPrtnAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Gross EPE in column (PYGroEPEPrtnCrClmAmt) applied against regular tax</Description>
									<LineNumber>Part I column (c)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Net EPE Subtract column (PYGroEPEPrtnAppRegTaxAmt) from column (PYGroEPEPrtnCrClmAmt) -->
						<xsd:element name="PYNetEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Net EPE Subtract column (PYGroEPEPrtnAppRegTaxAmt) from column (PYGroEPEPrtnCrClmAmt)</Description>
									<LineNumber>Part I column (d)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Non-EPE credit (excess of column (PYCrClmAmt) over column (PYGroEPEPrtnCrClmAmt)) that was applied against regular tax -->
						<xsd:element name="PYNonEPECrExAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Non-EPE credit (excess of column (PYCrClmAmt) over column (PYGroEPEPrtnCrClmAmt)) that was applied against regular tax</Description>
									<LineNumber>Part I column (e)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Carryover. Subtract the sum of columns (PYGroEPEPrtnCrClmAmt) and (PYNonEPECrExAppRegTaxAmt) from column (PYCrClmAmt) -->
						<xsd:element name="PYCarryoverAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Carryover. Subtract the sum of columns (PYGroEPEPrtnCrClmAmt) and (PYNonEPECrExAppRegTaxAmt) from column (PYCrClmAmt)</Description>
									<LineNumber>Part I column (f)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Amount of column (PYCrClmAmt) recaptured, including reduction of carryover. See instructions for basis increase -->
						<xsd:element name="RcptrTotCrRedCyovAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amount of column (PYCrClmAmt) recaptured, including reduction of carryover. See instructions for basis increase</Description>
									<LineNumber>Part I column (h)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Portion of column (RcptrTotCrRedCyovAmt) reducing credit carryover in column (PYCarryoverAmt) -->
						<xsd:element name="RcptrPrtnRdcngCrCyovAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Portion of column (RcptrTotCrRedCyovAmt) reducing credit carryover in column (PYCarryoverAmt)</Description>
									<LineNumber>Part I column (i)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Portion of column (RcptrTotCrRedCyovAmt) recapturing Non-EPE credit applied against regular tax in column (PYNonEPECrExAppRegTaxAmt) -->
						<xsd:element name="RcptrPrtnNonEPECrAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Portion of column (RcptrTotCrRedCyovAmt) recapturing Non-EPE credit applied against regular tax in column (PYNonEPECrExAppRegTaxAmt)</Description>
									<LineNumber>Part I column (j)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Portion of column (RcptrTotCrRedCyovAmt) recapturing gross EPE amount applied against regular tax from column (PYGroEPEPrtnAppRegTaxAmt) -->
						<xsd:element name="RcptrPrtnEPEAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Portion of column (RcptrTotCrRedCyovAmt) recapturing gross EPE amount applied against regular tax from column (PYGroEPEPrtnAppRegTaxAmt)</Description>
									<LineNumber>Part I column (k)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Portion of column (RcptrTotCrRedCyovAmt) recapturing Net EPE amount from column (PYNetEPEAmt) -->
						<xsd:element name="RcptrPrtnNetEPECrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Portion of column (RcptrTotCrRedCyovAmt) recapturing Net EPE amount from column (PYNetEPEAmt)</Description>
									<LineNumber>Part I column (l)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Section 6418(g)(2)(A)(i) excessive credit transfer -->
						<xsd:element name="Sect6418g2AiExCrTrnsfrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Section 6418(g)(2)(A)(i) excessive credit transfer</Description>
									<LineNumber>Part I column (m)(1)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Section 6418(g)(2)(A)(ii) 20% of excessive credit transfer -->
						<xsd:element name="Sect6418g2Aii20ExCrTrnsfrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Section 6418(g)(2)(A)(ii) 20% of excessive credit transfer</Description>
									<LineNumber>Part I column (m)(2)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Section 6418(g)(3) credit transfer recapture -->
						<xsd:element name="Sect6418g3CrTrnsfrRcptrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Section 6418(g)(3) credit transfer recapture</Description>
									<LineNumber>Part I column (m)(3)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP related to a gross EPE in column (PYGroEPEPrtnCrClmAmt), enter the net EPE portion from column (PYNetEPEAmt).  -->
						<xsd:element name="NetEPEPortionAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP related to a gross EPE in column (PYGroEPEPrtnCrClmAmt), enter the net EPE portion from column (PYNetEPEAmt). </Description>
									<LineNumber>Part I column (n)(1)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP, enter the portion of the EP not in column (NetEPEPortionAmt) (excluding any 20% EP)  -->
						<xsd:element name="PortionEPExcld20pctAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP, enter the portion of the EP not in column (NetEPEPortionAmt) (excluding any 20% EP) </Description>
									<LineNumber>Part I column (n)(2)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- If you owe an EP, enter any 20% EP you owe -->
						<xsd:element name="EP20PctOweAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>If you owe an EP, enter any 20% EP you owe</Description>
									<LineNumber>Part I column (n)(3)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Prevailing wage penalty amounts related to a net EPE amount -->
						<xsd:element name="PrvlWagePnltyRltdNetEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Prevailing wage penalty amounts related to a net EPE amount</Description>
									<LineNumber>Part I column (o)(1)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Prevailing wage penalty amounts related to a non-net EPE amount -->
						<xsd:element name="PrvlWagePnltyRltdNonNetEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Prevailing wage penalty amounts related to a non-net EPE amount</Description>
									<LineNumber>Part I column (o)(2)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Prevailing wage penalty amounts not related to an EPE amount -->
						<xsd:element name="PrvlWagePnltyNotRltdEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Prevailing wage penalty amounts not related to an EPE amount</Description>
									<LineNumber>Part I column (o)(3)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Apprenticeship penalty amounts related to a net EPE amount -->
						<xsd:element name="AprnctshpPnltyRltdNetEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Apprenticeship penalty amounts related to a net EPE amount</Description>
									<LineNumber>Part I column (p)(1)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Apprenticeship penalty amounts related to a non-net EPE amount -->
						<xsd:element name="AprntcshpPnltyRltdNonNetEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Apprenticeship penalty amounts related to a non-net EPE amount</Description>
									<LineNumber>Part I column (p)(2)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Apprenticeship penalty amounts not related to an EPE amount -->
						<xsd:element name="AprntcshpPnltyNotRltdEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Apprenticeship penalty amounts not related to an EPE amount</Description>
									<LineNumber>Part I column (p)(3)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Amounts that can be reduced by nonrefundable credits -->
						<xsd:element name="RedByNonRfdblCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amounts that can be reduced by nonrefundable credits</Description>
									<LineNumber>Part I column (q)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Amount that cannot be reduced by nonrefundable credits -->
						<xsd:element name="NotRedByNonRfdblCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Amount that cannot be reduced by nonrefundable credits</Description>
									<LineNumber>Part I column (r)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Add columns (l) and (n)(1) -->
						<xsd:element name="TotalRcptrNetEPEExPymt100CrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Add columns (l) and (n)(1)</Description>
									<LineNumber>Part I column (s)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Add columns(n)(3), (o)(1),(o)(2), (p)(1) and (p)(2) -->
						<xsd:element name="TotEx20PrvlWgAprntcshpPnltyAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Add columns(n)(3), (o)(1),(o)(2), (p)(1) and (p)(2)</Description>
									<LineNumber>Part I column (t)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			
			<!-- Part II -->

			<!-- Section A -->

			<!-- Properties -->
			<xsd:element name="CrtnCrRcptrExPymtPnltyPropGrp" type="CrtnCrRcptrExPymtPnltyPropGrpType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Properties</Description>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Part III -->

			<!-- Property Emissions Tier Recapture Group -->
			<xsd:element name="PropEmissionsTierRcptrGrp" minOccurs="0" maxOccurs="unbounded">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>Property Emissions Tier Recapture Group</Description>
							</xsd:documentation>
						</xsd:annotation>

						<!-- Enter the emissions rate or value of the hydrogen that the facility was designed and reasonably expected to produce from Form 3468, Part I, line 2a(i). -->
						<xsd:element name="FacilityEmissionsValueOrRt" type="LargeRatioType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Enter the emissions rate or value of the hydrogen that the facility was designed and reasonably expected to produce from Form 3468, Part I, line 2a(i).</Description>
									<LineNumber>1</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Enter the basis of property placed in service during the tax year from Form 3468, Part VI, Section M, line 25a, 25d, 25g, or25j, that corresponds to the emissions rate or value on line 1. -->
						<xsd:element name="CleanHydrgn45Vb2PropBasisAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Enter the basis of property placed in service during the tax year from Form 3468, Part VI, Section M, line 25a, 25d, 25g, or25j, that corresponds to the emissions rate or value on line 1.</Description>
									<LineNumber>2</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Enter the energy percentage used to calculate the section 48 credit during the tax year from Form 3468, Part VI, Section M. line 25b, 25e, 25h, or 25k, that corresponds to the emissions rate or value on line 1. -->
						<xsd:element name="NetOutLss1MWStsfdWgReqSectPct" type="RatioType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Enter the energy percentage used to calculate the section 48 credit during the tax year from Form 3468, Part VI, Section M. line 25b, 25e, 25h, or 25k, that corresponds to the emissions rate or value on line 1.</Description>
									<LineNumber>3</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Multiply line 2 by line 3 -->
						<xsd:element name="CalcClnHydrgnByEgyPctAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Multiply line 2 by line 3</Description>
									<LineNumber>4</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Enter the emissions rate of the hydrogen for the current tax year. If you didn't obtain an annual verification report for the current tax year, enter 0 and go to line 6. -->
						<xsd:element name="CYHydrogenEmissionsRt" type="RatioType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Enter the emissions rate of the hydrogen for the current tax year. If you didn't obtain an annual verification report for the current tax year, enter 0 and go to line 6.</Description>
									<LineNumber>5</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Enter the energy percentage that corresponds with the emissions rate on line 5 that would have been used to calculate the section 48 credit. If you didn't obtain an annual verification report for the current tax year, enter 0. -->
						<xsd:element name="HydrogenEmissionsEnergyPct" type="Decimal2RatioType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Enter the energy percentage that corresponds with the emissions rate on line 5 that would have been used to calculate the section 48 credit. If you didn't obtain an annual verification report for the current tax year, enter 0.</Description>
									<LineNumber>6</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Multiply line 6 by line 2 -->
						<xsd:element name="CalcPropBasisEgyPctAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Multiply line 6 by line 2</Description>
									<LineNumber>7</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Subtract line 7 from line 4 -->
						<xsd:element name="CalcEmissionsTierRcptrAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Subtract line 7 from line 4</Description>
									<LineNumber>8</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Multiply line 8 by 20% (0.20). This is the total increase in tax resulting from the emissions tier recapture event in the current tax year. Enter the result in Part I, line 1j, column (h). -->
						<xsd:element name="TotalIncreaseInTaxAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Multiply line 8 by 20% (0.20). This is the total increase in tax resulting from the emissions tier recapture event in the current tax year. Enter the result in Part I, line 1j, column (h).</Description>
									<LineNumber>9</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>

		</xsd:sequence>
	</xsd:complexType>

	<xsd:complexType name="Form3468PYCreditsType">
		<xsd:sequence>

			<!-- Credit or deduction claimed in prior year(s) (as adjusted, if applicable) -->
			<xsd:element name="PYCrClmAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Credit or deduction claimed in prior year(s) (as adjusted, if applicable)</Description>
						<LineNumber>Part I column (a)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Gross EPE payment amount portion of column (PYCrClmAmt) -->
			<xsd:element name="PYGroEPEPrtnCrClmAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Gross EPE payment amount portion of column (PYCrClmAmt)</Description>
						<LineNumber>Part I column (b)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Gross EPE in column (PYGroEPEPrtnCrClmAmt) applied against regular tax -->
			<xsd:element name="PYGroEPEPrtnAppRegTaxAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Gross EPE in column (PYGroEPEPrtnCrClmAmt) applied against regular tax</Description>
						<LineNumber>Part I column (c)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Net EPE Subtract column (PYGroEPEPrtnAppRegTaxAmt) from column (PYGroEPEPrtnCrClmAmt) -->
			<xsd:element name="PYNetEPEAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Net EPE Subtract column (PYGroEPEPrtnAppRegTaxAmt) from column (PYGroEPEPrtnCrClmAmt)</Description>
						<LineNumber>Part I column (d)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Non-EPE credit (excess of column (PYCrClmAmt) over column (PYGroEPEPrtnCrClmAmt)) that was applied against regular tax -->
