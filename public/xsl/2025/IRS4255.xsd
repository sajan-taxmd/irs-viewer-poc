			<!-- Form 7205 Prior Year Credits Group -->
			<xsd:element name="Form7205PYCreditsGrp" minOccurs="0" maxOccurs="unbounded">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:annotation>
							<xsd:documentation>
								<Description>Form 7205 Prior Year Credits Group</Description>
								<LineNumber>Part I, Line 1o column o3,  p3, r</LineNumber>
							</xsd:documentation>
						</xsd:annotation>

						<!-- Prevailing wage penalty amounts not related to an EPE amount -->
						<xsd:element name="PrvlWagePnltyNotRltdEPEAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Prevailing wage penalty amounts not related to an EPE amount</Description>
									<LineNumber>Part I column (o)(3)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>

						<!-- Apprenticeship penalty amounts not related to an EPE amount -->
