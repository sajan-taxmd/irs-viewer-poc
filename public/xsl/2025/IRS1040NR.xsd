<?xml version="1.0" encoding="UTF-8"?>
<xsd:schema xmlns="http://www.irs.gov/efile" xmlns:xsd="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.irs.gov/efile" elementFormDefault="qualified" attributeFormDefault="unqualified" version="1.0">
	<xsd:annotation>
		<xsd:documentation>
			<Description>IRS e-file Schema - IRS Form 1040NR</Description>
			<TaxYear>2025</TaxYear>
			<MaturityLevel>Final Release</MaturityLevel>
			<ReleaseDate>February 19 2026</ReleaseDate>
		</xsd:documentation>
	</xsd:annotation>
	<xsd:include schemaLocation="../../../Common/efileTypes.xsd"/>
	<!-- =============================================================== -->
	<!-- ======================= IRS Form 1040NR ======================= -->
	<!-- =============================================================== -->
	<xsd:element name="IRS1040NR">
		<xsd:annotation>
			<xsd:documentation>IRS Form 1040NR</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:complexContent>
				<xsd:extension base="IRS1040NRType">
					<xsd:attributeGroup ref="DocumentAttributes">
						<xsd:annotation>
							<xsd:documentation>Common return document attributes</xsd:documentation>
						</xsd:annotation>
					</xsd:attributeGroup>
					<xsd:attribute name="documentName" type="xsd:string" fixed="IRS1040NR">
						<xsd:annotation>
							<xsd:documentation>IRS internal use only. To avoid error in the return, do not include the attribute name or value.</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
					<xsd:attribute name="referenceDocumentId" type="IdListType">
						<xsd:annotation>
							<xsd:documentation>List of document ID's of forms, schedules, supporting info. etc. attached to this form</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
					<xsd:attribute name="referenceDocumentName" type="TextType" fixed="BinaryAttachment IRS982 IRS1040Schedule1 IRS1040Schedule2 IRS1040Schedule3 IRS1040NRScheduleA IRS1040NRScheduleNEC IRS1040NRScheduleOI IRS1040NRScheduleP IRS1310 IRS2120 IRS2210 IRS2210F IRS4835 IRS4952 IRS6252 IRS6781 IRS8082 IRS8275 IRS8275R IRS8594 IRS8606 IRS8615 IRS8697 IRS8814 IRS8815 IRS8828 IRS8840 IRS8843 IRS8853 IRS8854 IRS8866 IRS8867 IRS8938 IRS8958 IRS9465 IRSRRB1042S IRS1040X IRSSSA1042S FormOrScheduleChangeExplanationStatement Chapter11BankruptcyStatement ExcludeUpTo10DaysPresenceStatement ExemptionFromWithholdingStatement FECRecord GeneralDependencyMedium GeneralDependencySmall GrossIncomeExclusionStatement MultiLevelMarketingStatement NameChangeStatement PenaltiesStatement PropertyIncomeTreatedAsEffectivelyConnectedIncomeStatement ProtectiveStatement ResidencyTerminationDateStatement RevokeResidentSpouseStatement Section962ElectionExplanationStatement SpecialDepreciationAllowanceElectionOutStatement SpecialTaxStatement"/>
				</xsd:extension>
			</xsd:complexContent>
		</xsd:complexType>
	</xsd:element> 
	<xsd:complexType name="IRS1040NRType">
		<xsd:annotation>
			<xsd:documentation>Content model for IRS Form 1040NR</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:choice minOccurs="0">
				<!-- Amended Return Indicator -->
				<xsd:element name="AmendedReturnInd" type="CheckboxType">
					<xsd:annotation>
						<xsd:documentation>
							<Description>Amended Return Indicator</Description>
						</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<!-- Superseded Return Indicator -->
				<xsd:element name="SupersededReturnInd" type="CheckboxType">
					<xsd:annotation>
						<xsd:documentation>
							<Description>Superseded Return Indicator</Description>
						</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
			</xsd:choice>
			
			<!-- Address Change Indicator -->
			<xsd:element name="AddressChangeInd" type="CheckboxType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Address Change Indicator</Description>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- Check This Box For A Protective Return -->
			<xsd:element name="ProtectiveReturnInd" type="CheckboxType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Check this box for a protective return</Description>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- Filed Pursuant To Section 30191002 Indicator -->
            <xsd:element name="FiledPursuantToSect30191002Ind" type="CheckboxType" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Filed Pursuant To Section 30191002 Indicator</Description>
                    </xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            
            <!-- Combat Zone Indicator -->
            <xsd:element name="CombatZoneInd" type="CheckboxType" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Combat Zone Indicator</Description>
                    </xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            
            <!-- Combat Zone -->
            <xsd:element name="CombatZoneTxt" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Combat Zone</Description>
                    </xsd:documentation>
                </xsd:annotation>
                <xsd:simpleType>
                    <xsd:restriction base="TextType">
                        <xsd:maxLength value="30"/>
                    </xsd:restriction>
                </xsd:simpleType>
            </xsd:element>
            
            <!-- Deceased Indicator -->
            <xsd:element name="DeceasedInd" type="CheckboxType" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Deceased Indicator</Description>
                    </xsd:documentation>
                </xsd:annotation>
            </xsd:element>
			
			<!-- Primary Date Of Death -->
			<xsd:element name="PrimaryDeathDt" type="DateType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Primary date of death</Description>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Spouse Date Of Death -->
			<xsd:element name="SpouseDeathDt" type="DateType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Spouse date of death</Description>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- Other Special Condition Indicator -->
            <xsd:element name="OtherInd" type="CheckboxType" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Other Special Condition Indicator</Description>
                    </xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            
            <!-- Other Special Condition Text -->
            <xsd:element name="SpecialConditionTxt" type="SpecialConditionTextType" minOccurs="0" maxOccurs="3">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Other Special Condition Text</Description>
                    </xsd:documentation>
                </xsd:annotation>
            </xsd:element>
			
			<!-- =============== Filing Status =============== -->
			
			<!-- Individual Return Filing Status Code Indicator -->
            <xsd:element name="IndividualReturnFilingStatusCd">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Individual Return Filing Status Code Indicator</Description>
                    </xsd:documentation>
                </xsd:annotation>
                
                <xsd:simpleType>
                    <xsd:restriction base="TextType">
                        <xsd:enumeration value="1"/>
                        <xsd:enumeration value="3"/>
                        <xsd:enumeration value="5"/>
                    </xsd:restriction>
                </xsd:simpleType>
            </xsd:element>
            
            <!-- EstateInd - Not used -->
            <!-- TrustInd - Not used -->
			
            <!-- Qualifying person name -->
            <xsd:element name="QualifyingPersonName" type="PersonFullNameType" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Qualifying person name</Description>
                    </xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            
            <!-- Qualifying person SSN -->
            <xsd:element name="QualifyingPersonSSN" type="SSNType" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Qualifying person SSN</Description>
                    </xsd:documentation>
                </xsd:annotation>
            </xsd:element>
			
			<!-- Virtual Currency Acquired Indicator -->
			<xsd:element name="VirtualCurAcquiredDurTYInd" type="BooleanType">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Virtual Currency Acquired Indicator</Description>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- =============== Dependents =============== -->
			<!-- Dependent Detail -->
			<xsd:element name="DependentDetail" minOccurs="0" maxOccurs="100">
				<xsd:complexType>
					<xsd:sequence>
						<!-- Dependent First Name -->
						<xsd:element name="DependentFirstNm" type="PersonFirstNameType">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Dependent first name</Description>
									<LineNumber>(1)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Dependent Last Name -->
						<xsd:element name="DependentLastNm" type="PersonLastNameType">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Dependent last name</Description>
									<LineNumber>(2)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Dependent Name Control -->
						<xsd:element name="DependentNameControlTxt" type="PersonNameControlType">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Dependent name control</Description>
									<LineNumber>(2)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Dependent/Qualifying Child Identity Protection PIN -->
						<xsd:element name="IdentityProtectionPIN" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Dependent/Qualifying Child Identity Protection PIN</Description>
									<LineNumber>(2)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="TextType">
									<xsd:length value="6"/>
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:element>
						<xsd:choice>
							<!-- Dependent SSN -->
							<xsd:element name="DependentSSN" type="SSNType">
								<xsd:annotation>
									<xsd:documentation>
										<Description>Dependent SSN</Description>
										<LineNumber>(3)</LineNumber>
									</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<!-- Died Literal Code -->
							<xsd:element name="DiedLiteralCd">
								<xsd:annotation>
									<xsd:documentation>
										<Description>Died literal code</Description>
										<LineNumber>(3)</LineNumber>
									</xsd:documentation>
								</xsd:annotation>
								<xsd:simpleType>
									<xsd:restriction base="TextType">
										<xsd:enumeration value="DIED"/>
									</xsd:restriction>
								</xsd:simpleType>
							</xsd:element>
						</xsd:choice>
						<!-- Dependent Relationship Code -->
						<xsd:element name="DependentRelationshipCd">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Dependent relationship code</Description>
									<LineNumber>(4)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="TextType">
									<xsd:enumeration value="SON"/>
									<xsd:enumeration value="DAUGHTER"/>
									<xsd:enumeration value="STEPCHILD"/>
									<xsd:enumeration value="FOSTER CHILD"/>
									<xsd:enumeration value="BROTHER"/>
									<xsd:enumeration value="SISTER"/>
									<xsd:enumeration value="STEPBROTHER"/>
									<xsd:enumeration value="STEPSISTER"/>
									<xsd:enumeration value="HALF BROTHER"/>
									<xsd:enumeration value="HALF SISTER"/>
									<xsd:enumeration value="GRANDCHILD"/>
									<xsd:enumeration value="NIECE"/>
									<xsd:enumeration value="NEPHEW"/>
									<xsd:enumeration value="PARENT"/>
									<xsd:enumeration value="GRANDPARENT"/>
									<xsd:enumeration value="AUNT"/>
									<xsd:enumeration value="UNCLE"/>
									<xsd:enumeration value="OTHER"/>
									<xsd:enumeration value="NONE"/>
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:element>
						
						<!-- Lived with you more than half of year -->
                        <xsd:element name="YesLiveWithChildOverHalfYrInd" type="CheckboxType" minOccurs="0">
                            <xsd:annotation>
                                <xsd:documentation>
                                    <Description>Lived with you more than half of year</Description>
                                    <LineNumber>(5)</LineNumber>
                                </xsd:documentation>
                            </xsd:annotation>
                        </xsd:element>
						
						<!-- Eligible For Child Tax Credit Indicator -->
				       <xsd:choice minOccurs="0">
						<xsd:element name="EligibleForChildTaxCreditInd" type="CheckboxType">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Eligible for child tax credit indicator</Description>
									<LineNumber>(6)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Eligible for Other Dependent Child Tax Credit Indicator -->
						<xsd:element name="EligibleForODCInd" type="CheckboxType">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Eligible for other dependent child tax credit indicator</Description>
									<LineNumber>(6)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
				       </xsd:choice>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<!-- More Dependents Indicator -->
			<xsd:element name="MoreDependentsInd" type="CheckboxType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>More dependents indicator</Description>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Exemption Primary And Spouse Count -->
			<xsd:element name="TotalExemptPrimaryAndSpouseCnt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total exemption primary and spouse count</Description>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="IntegerNNType">
						<xsd:totalDigits value="1"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<!-- Child Who Lived With You Count -->
			<xsd:element name="ChldWhoLivedWithYouCnt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Child who lived with you count</Description>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="IntegerNNType">
						<xsd:totalDigits value="2"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<!-- Other Dependents Listed Count -->
			<xsd:element name="OtherDependentsListedCnt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Other dependents listed count</Description>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="IntegerNNType">
						<xsd:totalDigits value="2"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>

			<!-- Total Exemptions Count -->
			<xsd:element name="TotalExemptionsCnt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total exemptions count</Description>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="IntegerNNType">
						<xsd:totalDigits value="2"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>

			<!-- =============== Income Effectively Connected With U.S. Trade or Business =============== -->
			<!-- Wages from Form(s) W-2, box 1 -->
			<xsd:element name="WagesAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Wages from Form(s) W-2, box 1</Description>
						<LineNumber>1a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="USAmountNNType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="TextType" fixed="IRSW2"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			
			<!-- Household employee wages -->
			<xsd:element name="HouseholdEmployeeWagesAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Household employee wages</Description>
						<LineNumber>1b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- Tip income -->
			<xsd:element name="TipIncomeAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Tip income</Description>
						<LineNumber>1c</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- Medicaid waiver payments not reported on Form(s) W-2 -->
			<xsd:element name="MedicaidWaiverPymtNotRptW2Amt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Medicaid waiver payments not reported on Form(s) W-2</Description>
						<LineNumber>1d</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		
			<!-- Taxable dependent care benefits from Form 2441, line 26 -->
			<xsd:element name="TaxableBenefitsAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Taxable dependent care benefits from Form 2441, line 26</Description>
						<LineNumber>1e</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- Employer-provided adoption benefits from Form 8839, line 29 -->
			<xsd:element name="TaxableBenefitsForm8839Amt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Employer-provided adoption benefits from Form 8839, line 29</Description>
						<LineNumber>1f</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- Wages from Form 8919, line 6 -->
			<xsd:element name="TotalWagesWithNoWithholdingAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Wages from Form 8919, line 6</Description>
						<LineNumber>1g</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- Wages Not Shown -->
			<xsd:element name="WagesNotShownGrp" minOccurs="0" maxOccurs="20">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:choice>
							<!-- Wages Literal Code -->
							<xsd:element name="WagesLiteralCd">
								<xsd:annotation>
									<xsd:documentation>
										<Description>Wages literal code</Description>
										<LineNumber>1h</LineNumber>
									</xsd:documentation>
								</xsd:annotation>
								<xsd:simpleType>
									<xsd:restriction base="TextType">
										<xsd:enumeration value="FB"/>
										<xsd:enumeration value="FEC"/>
										<xsd:enumeration value="PSO"/>
									</xsd:restriction>
								</xsd:simpleType>
							</xsd:element>
							<!-- Other Wages Not Shown -->
							<xsd:element name="OtherWagesNotShownTxt">
								<xsd:annotation>
									<xsd:documentation>
										<Description>Other wages not shown</Description>
										<LineNumber>1h</LineNumber>
									</xsd:documentation>
								</xsd:annotation>
								<xsd:simpleType>
									<xsd:restriction base="TextType">
										<xsd:maxLength value="50"/>
									</xsd:restriction>
								</xsd:simpleType>
							</xsd:element>
						</xsd:choice>
						<!-- Wages Not Shown Amount -->
						<xsd:element name="WagesNotShownAmt" type="USAmountType">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Wages not shown amount</Description>
									<LineNumber>1h</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>			
			
			<!-- Other earned income -->
			<xsd:element name="OtherEarnedIncomeAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Other earned income</Description>
						<LineNumber>1h</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="USAmountType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="TextType" fixed="NonW2DisabilityPaymentStatement"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			
			<!-- Nontaxable Combat Pay Election Amount -->
			<xsd:element name="NontxCombatPayElectionAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Nontaxable Combat Pay Election Amount</Description>
						<LineNumber>1i</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Line 1j Reserved -->

			<!-- Treaty Tax Exempt US Income Amount -->
			<xsd:element name="TreatyTaxExemptUSIncomeAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Treaty Tax Exempt US Income Amount</Description>
						<LineNumber>1k</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- Wages, Salaries And Tips Amount -->
			<xsd:element name="WagesSalariesAndTipsAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Wages, Salaries And Tips Amount</Description>
						<LineNumber>1z</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<!-- Tax Exempt Interest Amount -->
			<xsd:element name="TaxExemptInterestAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Tax exempt interest amount</Description>
						<LineNumber>2a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Taxable Interest Amount -->
			<xsd:element name="TaxableInterestAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Taxable interest amount</Description>
						<LineNumber>2b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Qualified Dividends Amount -->
			<xsd:element name="QualifiedDividendsAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Qualified dividends amount</Description>
						<LineNumber>3a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Ordinary Dividends Amount -->
			<xsd:element name="OrdinaryDividendsAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Ordinary dividends amount</Description>
						<LineNumber>3b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Qualified Form 8814 included on line 3b -->
            <xsd:element name="ChildDivIncldQualifiedDivInd" type="CheckboxType" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Qualified Form 8814 included on line 3b</Description>
                        <LineNumber>3c (1)</LineNumber>
                    </xsd:documentation>
                </xsd:annotation>
            </xsd:element>
            <!-- Qualified Form 8814 included on line 3b -->
            <xsd:element name="ChildDivIncldOrdinaryDivInd" type="CheckboxType" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Qualified Form 8814 included on line 3b</Description>
                        <LineNumber>3c (2)</LineNumber>
                    </xsd:documentation>
                </xsd:annotation>
            </xsd:element>
			<!-- IRA Distributions Amount -->
			<xsd:element name="IRADistributionsAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>IRA distributions amount</Description>
						<LineNumber>4a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Taxable IRA Amount -->
			<xsd:element name="TaxableIRAAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Taxable IRA amount</Description>
						<LineNumber>4b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
