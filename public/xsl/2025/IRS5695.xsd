<?xml version="1.0" encoding="UTF-8"?>
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns="http://www.irs.gov/efile" targetNamespace="http://www.irs.gov/efile" elementFormDefault="qualified" attributeFormDefault="unqualified" version="1.0">
	<xsd:annotation>
		<xsd:documentation>
			<Description>IRS e-file Schema - IRS Form 5695 Residential Energy Credit</Description>
			<TaxYear>2025</TaxYear>
			<MaturityLevel>Final Release</MaturityLevel>
			<ReleaseDate>February 19 2026</ReleaseDate>
		</xsd:documentation>
	</xsd:annotation>

	<xsd:include schemaLocation="../../../Common/efileTypes.xsd"/>

	<!--  ================================================================== -->
	<!--  ======================== IRS Form 5695 =========================== -->
	<!--  ================================================================== -->

	<xsd:element name="IRS5695">
		<xsd:annotation>
			<xsd:documentation>IRS Form 5695</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:complexContent>
				<xsd:extension base="IRS5695Type">
					<xsd:attributeGroup ref="DocumentAttributes">
						<xsd:annotation>
							<xsd:documentation>Common return document attributes</xsd:documentation>
						</xsd:annotation>
					</xsd:attributeGroup>
					<xsd:attribute name="documentName" type="xsd:string" fixed="IRS5695"/>
				</xsd:extension>
			</xsd:complexContent>
		</xsd:complexType>
	</xsd:element>

	<xsd:complexType name="IRS5695Type">
		<xsd:annotation>
			<xsd:documentation>Content model for Form 5695</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>

			<xsd:element name="NameLine1Txt" type="NameLine1Type">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Name</Description>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			
			<xsd:element name="SSN" type="SSNType">
				<xsd:annotation>
					<xsd:documentation>
						<Description>SSN</Description>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- Part I - Residential Clean Energy Credit -->
			<xsd:element name="ResidentialCleanEnergyCrGrp" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Residential Clean Energy Credit Group</Description>
					</xsd:documentation>
				</xsd:annotation>			
				<xsd:complexType>
					<xsd:sequence>
						<!-- Residential Clean Energy Home Address -->
						<xsd:element name="ResidentialCleanEgyHomeAddress" type="USAddressType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Residential Clean Energy Home Address</Description>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>					
						<!-- Solar Electric Property Cost Amount -->
						<xsd:element name="SolarElecPropCostAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Solar Electric Property Cost Amount</Description>
									<LineNumber>1</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Solar Water Heating Property Cost Amount -->
						<xsd:element name="SolarWaterHtPropCostAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Solar Water Heating Property Cost Amount</Description>
									<LineNumber>2</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Small Wind Property Cost Amount -->
						<xsd:element name="SmallWindPropCostAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Small Wind Property Cost Amount</Description>
									<LineNumber>3</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Geothermal Heat Pump Property Cost Amount -->
						<xsd:element name="GeothrmlHtPumpPropCostAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Geothermal Heat Pump Property Cost Amount</Description>
									<LineNumber>4</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Qualified Battery Storage Technology Indicator -->
						<xsd:element name="QlfyBatteryStorageTechInd" type="BooleanType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Qualified Battery Storage Technology Indicator</Description>
									<LineNumber>5a</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>						
						<!-- Qualified Battery Storage Technology Cost Amount -->
						<xsd:element name="QlfyBatteryStorageTechCostsAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Qualified Battery Storage Technology Cost Amount</Description>
									<LineNumber>5b</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>						
						<!-- Total Energy Credits Amount -->
						<xsd:element name="TotalEnergyCreditsAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Total Energy Credits Amount</Description>
									<LineNumber>6a</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Total Energy Credits Standard Percentage Credit Amount -->
						<xsd:element name="TotalEnergyCreditsStdPctCrAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Total Energy Credits Standard Percentage Credit Amount</Description>
									<LineNumber>6b</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Qualified Fuel Cell Property in US Indicator -->
						<xsd:element name="QlfyFuelCellPropertyInUSInd" type="BooleanType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Qualified Fuel Cell Property in US Indicator</Description>
									<LineNumber>7a</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Qualified Fuel Cell Property Home Address -->
						<xsd:element name="QlfyFuelCellPropertyHmAddress" type="USAddressType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Qualified Fuel Cell Property Home Address</Description>
									<LineNumber>7b</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Joint Occupancy Indicator -->
						<xsd:element name="JointOccupancyInd" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Joint Occupancy Indicator</Description>
									<LineNumber>7c</LineNumber>
							</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:simpleContent>
									<xsd:extension base="CheckboxType">
										<xsd:attribute name="referenceDocumentId" type="IdListType"/>
										<xsd:attribute name="referenceDocumentName" type="StringType" fixed="JointOccupancyStatement"/>
									</xsd:extension>
								</xsd:simpleContent>
							</xsd:complexType>
						</xsd:element>
						<!-- Fuel Cell Property Cost Amount -->
						<xsd:element name="FuelCellPropCostAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Fuel Cell Property Cost Amount</Description>
									<LineNumber>8</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Fuel Cell Property Standard Percentage Credit Amount -->
						<xsd:element name="FuelCellPropStdPctCrAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Fuel Cell Property Standard Percentage Credit Amount</Description>
									<LineNumber>9</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Fuel Cell Property Kilowatt Capacity Number -->
						<xsd:element name="FuelCellPropKWCapNum" type="LargeRatioType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Fuel Cell Property Kilowatt Capacity Number</Description>
									<LineNumber>10</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Fuel Cell Property Kilowatt Capacity Amount -->
						<xsd:element name="FuelCellPropKWCapAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Fuel Cell Property Kilowatt Capacity Amount</Description>
									<LineNumber>10</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Fuel Cell Property Allowable Cost Amount -->
						<xsd:element name="FuelCellPropAllwblCostAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Fuel Cell Property Allowable Cost Amount</Description>
									<LineNumber>11</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Prior Year Carryforward Residential Clean Energy Credit -->
						<xsd:element name="PYCfwdRsdntlCleanEnergyCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Prior Year Carryforward Residential Clean Energy Credit</Description>
									<LineNumber>12</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Total of Energy Credits Amount -->
						<xsd:element name="TotalOfEnergyCreditsAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Total of Energy Credits Amount</Description>
									<LineNumber>13</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Tax less Credits Amount -->
						<xsd:element name="TaxLessCreditsAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Tax less Credits Amount</Description>
									<LineNumber>14</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Residential Clean Energy Credit Amount -->
						<xsd:element name="ResidentialCleanEnergyCrAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Residential Clean Energy Credit Amount</Description>
									<LineNumber>15</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Carryforward Residential Clean Energy Credit Amount -->
						<xsd:element name="CfwdRsdntlCleanEnergyCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Carryforward Residential Clean Energy Credit Amount</Description>
									<LineNumber>16</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
					</xsd:sequence>				
					<xsd:attribute name="referenceDocumentId" type="IdListType"/>
				        <xsd:attribute name="referenceDocumentName" type="StringType" fixed="ResidentialCleanEnergyHomeStatement"/>
				</xsd:complexType>
			</xsd:element>

			<!-- Part II - Energy Efficient Home Improvement Credit -->
			<xsd:element name="EgyEffcntHmImprvCrGrp" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Energy Efficient Home Improvement Credit Group</Description>
					</xsd:documentation>
				</xsd:annotation>			
				<xsd:complexType>
					<xsd:sequence>
						<!-- Home Located in USA Indicator -->
						<xsd:element name="HomeLocatedInUSAInd" type="BooleanType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Home Located in USA Indicator</Description>
									<LineNumber>17a</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Original User Indicator -->
						<xsd:element name="OriginalUserInd" type="BooleanType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Original User Indicator</Description>
									<LineNumber>17b</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Five Year Expectation Indicator -->
						<xsd:element name="FiveYearUseExpectationInd" type="BooleanType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Five Year Expectation Indicator</Description>
									<LineNumber>17c</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>						
						<!-- Energy Efficient Home Improvement Credit Main Home US Address -->
						<xsd:element name="HomeAddress" type="USAddressType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Energy Efficient Home Improvement Credit Main Home US Address</Description>
									<LineNumber>17d</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Improvement Related To Construction of Main Home Indicator -->
						<xsd:element name="ImprvRltdToConstMainHomeInd" type="BooleanType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Improvement Related To Construction of Main Home Indicator</Description>
									<LineNumber>17e</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Insulation or System Heat Gain Loss Cost Amount -->
						<xsd:element name="InsulationOrSysHtGnLossCostAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Insulation or System Heat Gain Loss Cost Amount</Description>
									<LineNumber>18a</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Insulation or System Heat Standard Percentage Credit Amount -->
						<xsd:element name="InsulationOrSysHtStdPctCrAmt" type="USAmountNNType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Insulation or System Heat Standard Percentage Credit Amount</Description>
									<LineNumber>18b</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Exterior Door Energy Star Requirements Group-->
						<xsd:element name="ExteriorDoorEgyStarRqrGrp" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Exterior Door Energy Star Requirements Group</Description>
									<LineNumber>19a - h</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:complexType>
								<xsd:sequence>
									<!-- Most Expensive Exterior Door Cost Amount -->
									<xsd:element name="MostExpnsExtrDoorCostAmt" type="USAmountNNType">
										<xsd:annotation>
											<xsd:documentation>
												<Description>Most Expensive Exterior Door Cost Amount</Description>
												<LineNumber>19a</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<!-- Qualifying Exterior Door - Qualified Manufacturer Identification Number (QMID)-->
									<xsd:element name="MostExpnsExtrDoorQMID" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>
												<Description>Qualifying Exterior Door - Qualified Manufacturer Identification Number (QMID)</Description>
												<LineNumber>19b</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
										<xsd:simpleType>
											<xsd:restriction base="AlphaNumericType">
												<xsd:pattern value="[A-Z][0-9][A-Z][0-9]"/>
											</xsd:restriction>
										</xsd:simpleType>
									</xsd:element>
									<!-- Most Expensive Exterior Door Standard Percentage Credit Amount -->
									<xsd:element name="MostExpnsExtrDoorsStdPctCrAmt" type="USAmountNNType">
										<xsd:annotation>
											<xsd:documentation>
												<Description>Most Expensive Exterior Door Standard Percentage Credit Amount</Description>
												<LineNumber>19c</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<!-- Other Exterior Door Energy Star Requirements Group -->
									<xsd:element name="OthExteriorDoorEgyStarRqrGrp" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>
												<Description>Other Exterior Door Energy Star Requirements Group</Description>
												<LineNumber>19d - g</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
										<xsd:complexType>
											<xsd:sequence>
												<!-- Next Most Expensive Exterior Door(s) Group -->
												<xsd:element name="NextMostExpnsExtrDoorGrp" type="QMIDCostGrpType" maxOccurs="2">
													<xsd:annotation>
														<xsd:documentation>
															<Description>Next Most Expensive Exterior Door(s) Group</Description>
															<LineNumber>19d (i) - (ii)</LineNumber>
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<!--  Next Most Expensive Qualifying Exterior Door(s) Total Cost Amount -->									
												<xsd:element name="NextMostExpnsExtrDoorCostAmt" type="USAmountNNType">
													<xsd:annotation>
														<xsd:documentation>
															<Description>Next Most Expensive Qualifying Exterior Door(s) Total Cost Amount</Description>
															<LineNumber>19d</LineNumber>
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<!-- Other Qualifying Exterior Door Cost Amount -->
												<xsd:element name="OtherQlfyExtrDoorsCostAmt" type="USAmountNNType" minOccurs="0">
													<xsd:annotation>
														<xsd:documentation>
															<Description>Other Qualifying Exterior Door Cost Amount</Description>
															<LineNumber>19e</LineNumber>
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>
												<!-- Total Other Qualifying Exterior Door Cost Amount -->
												<xsd:element name="TotalOtherQlfyExtrDoorsCostAmt" type="USAmountNNType">
													<xsd:annotation>
														<xsd:documentation>
															<Description>Total Other Qualifying Exterior Door Cost Amount</Description>
															<LineNumber>19f</LineNumber>
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>	
												<!-- Other Qualifying Exterior Door Standard Percentage Credit Amount -->
												<xsd:element name="OtherQlfyExtrDoorsStdPctCrAmt" type="USAmountNNType">
													<xsd:annotation>
														<xsd:documentation>
															<Description>Other Qualifying Exterior Door Standard Percentage Credit Amount</Description>
															<LineNumber>19g</LineNumber>
														</xsd:documentation>
													</xsd:annotation>
												</xsd:element>												
											</xsd:sequence>
										</xsd:complexType>						
									</xsd:element>
									<!-- Exterior Doors Total Credit Amount -->
									<xsd:element name="TotalExtrDoorsCreditAmt" type="USAmountNNType">
										<xsd:annotation>
											<xsd:documentation>
												<Description>Exterior Doors Total Credit Amount</Description>
												<LineNumber>19h</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>									
								</xsd:sequence>
							</xsd:complexType>
						</xsd:element>
						<!-- Exterior Windows And Skylights Energy Star Requirements Group-->
						<xsd:element name="ExtrWndwSkyltEgyStarRqrGrp" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Exterior Windows And Skylights Energy Star Requirements Group</Description>
									<LineNumber>20a - d</LineNumber>
								</xsd:documentation>
							</xsd:annotation>							
							<xsd:complexType>
								<xsd:sequence>
									<!-- Most Expensive Qualifying Exterior Window(s) or Skylight(s) Group-->
									<xsd:element name="MostExpnsExtrWndwSkyltGrp" type="QMIDCostGrpType" maxOccurs="4">
										<xsd:annotation>
											<xsd:documentation>
												<Description>Most Expensive Qualifying Exterior Window(s) or Skylight(s) Group</Description>
												<LineNumber>20a (i) - (iv)</LineNumber>
											</xsd:documentation>
										</xsd:annotation>										
									</xsd:element>
									<!-- Most Expensive Qualifying Exterior Window(s) or Skylight(s) Total Cost Amount -->
									<xsd:element name="MostExpnsExtrWndwSkyltCostAmt" type="USAmountNNType">
										<xsd:annotation>
											<xsd:documentation>
												<Description>Most Expensive Qualifying Exterior Window(s) or Skylight(s) Total Cost Amount</Description>
												<LineNumber>20a</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>	
									<!-- Other Qualifying Exterior Windows or Skylights Cost Amount -->
									<xsd:element name="OthQlfyExtrWndwSkyltCostAmt" type="USAmountNNType" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>
												<Description>Other Qualifying Exterior Windows or Skylights Cost Amount</Description>
												<LineNumber>20b</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>
									<!-- Exterior Window or Skylight Cost Amount -->
									<xsd:element name="ExteriorWndwOrSkylightCostAmt" type="USAmountNNType">
										<xsd:annotation>
											<xsd:documentation>
												<Description>Exterior Window or Skylight Cost Amount</Description>
												<LineNumber>20c</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>	
									<!-- Exterior Window or Skylight Standard Percentage Credit Amount -->
									<xsd:element name="ExtrWndwSkylightStdPctCrAmt" type="USAmountNNType">
										<xsd:annotation>
											<xsd:documentation>
												<Description>Exterior Window or Skylight Standard Percentage Credit Amount</Description>
												<LineNumber>20d</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>																	
								</xsd:sequence>
							</xsd:complexType>
						</xsd:element>
															
						<!-- Qualified Energy Property Cost United States Home Indicator -->
						<xsd:element name="QlfyEnergyPropCostsUSHomeInd" type="BooleanType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Qualified Energy Property Cost United States Home Indicator</Description>
									<LineNumber>21a</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Original Service Placement Indicator -->
						<xsd:element name="OriginallyPlacedInServiceInd" type="BooleanType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Original Service Placement Indicator</Description>
									<LineNumber>21b</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Qualified Energy Property Address -->
						<xsd:element name="QualifiedEnergyPropertyAddress" type="USAddressType" minOccurs="0" maxOccurs="4">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Qualified Energy Property Address</Description>
									<LineNumber>21c</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!--  Central Air Conditioning Group -->
						<xsd:element name="CentralAirConditionerGrp" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Central Air Conditioning Group</Description>
									<LineNumber>22a - d</LineNumber>
								</xsd:documentation>
							</xsd:annotation>							
							<xsd:complexType>
								<xsd:sequence>
									<!-- Most Expensive Central Air Conditioner Qualified Manufacturer Identification Number (QMID)-->
									<xsd:element name="MostExpnsCentralAirCondQMID" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>
												<Description>Most Expensive Central Air Conditioner Qualified Manufacturer Identification Number (QMID)</Description>
												<LineNumber>22a</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
										<xsd:simpleType>
											<xsd:restriction base="AlphaNumericType">
												<xsd:pattern value="[A-Z][0-9][A-Z][0-9]"/>
											</xsd:restriction>
										</xsd:simpleType>
									</xsd:element>
									<!-- Most Expensive Central Air Conditioner Cost Amount -->
									<xsd:element name="MostExpnsCentralAirCondCostAmt" type="USAmountNNType">
										<xsd:annotation>
											<xsd:documentation>
												<Description>Most Expensive Central Air Conditioner Cost Amount</Description>
												<LineNumber>22a</LineNumber>
											</xsd:documentation>
										</xsd:annotation>
									</xsd:element>	
									<!-- Other Central Air Conditioner Cost Amount -->
									<xsd:element name="OthCentralAirCondCostAmt" type="USAmountNNType" minOccurs="0">
										<xsd:annotation>
											<xsd:documentation>
												<Description>Other Central Air Conditioner Cost Amount</Description>
												<LineNumber>22b</LineNumber>
											</xsd:documentation>
