	<xsd:complexType name="QMIDCostGrpType">
        <xsd:sequence>
            <!-- Qualified Manufacturer Identification Number (QMID) -->
            <xsd:element name="QMID" minOccurs="0">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Qualified Manufacturer Identification Number (QMID)</Description>
                    </xsd:documentation>
                </xsd:annotation>
                
                <xsd:simpleType>
                    <xsd:restriction base="AlphaNumericType">
                        <xsd:pattern value="[A-Z][0-9][A-Z][0-9]"/>
                    </xsd:restriction>
                </xsd:simpleType>
            </xsd:element>
            
            <!-- Cost Amount -->
            <xsd:element name="CostAmt">
                <xsd:annotation>
                    <xsd:documentation>
                        <Description>Cost Amount</Description>
                    </xsd:documentation>
                </xsd:annotation>
                
                <xsd:simpleType>
                    <xsd:restriction base="USAmountNNType">
                        <xsd:maxInclusive value="99999999"/>
                    </xsd:restriction>
                </xsd:simpleType>
            </xsd:element>
        </xsd:sequence>
    </xsd:complexType>
</xsd:schema>
