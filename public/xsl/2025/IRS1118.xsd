			<!-- Apportionment Interest Deductions -->
			<xsd:element name="ApportionmentInterestDedGrp" type="ApportionmentInterestDedGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Apportionment Interest Deductions</Description>
						<LineNumber>Schedule H Part II (b)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Stewardship Deductions Group -->
			<xsd:element name="StewardshipDeductionsGrp" type="StewardshipDeductionsGrpType" minOccurs="0">
