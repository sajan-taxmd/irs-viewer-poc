	<!-- ===== Type for Repeating Element "Part I - Tax Deemed Paid 951a1 Inclusions under Section 960 in Schedule C ===== -->
	<xsd:complexType name="Section951a1InclusionsCorpGrpType">
		<xsd:sequence>
			<!-- Foreign Corporation Name -->
			<xsd:element name="ForeignCorporationName" type="BusinessNameType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Name of Foreign Corporation</Description>
						<LineNumber>Schedule C Line 1a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Choice between Foreign Corporation EIN or Foreign Entity Identification Group -->
			<xsd:choice minOccurs="0">
				<!-- Foreign Corporation EIN -->
				<xsd:element name="ForeignCorporationEIN" type="EINType">
					<xsd:annotation>
						<xsd:documentation>
							<Description>Foreign Corporation EIN</Description>
							<LineNumber>Schedule C Line 1b</LineNumber>
						</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<!-- Foreign Entity Identification Group -->
				<xsd:element name="ForeignEntityIdentificationGrp" type="ForeignEntityIdentificationGrpType">
					<xsd:annotation>
						<xsd:documentation>
							<Description>Foreign Entity Identification Group</Description>
							<LineNumber>Schedule C Line 1b</LineNumber>
						</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
			</xsd:choice>
			<!-- QBU Reference ID Number -->
			<xsd:element name="TestedUnitReferenceIdNum" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Tested Unit Reference ID</Description>
						<LineNumber>Schedule C Line 1c</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="AlphaNumericType">
						<xsd:minLength value="1"/>
						<xsd:maxLength value="50"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<!-- Tax Year End -->
			<xsd:element name="TaxYearEndMonthYr" type="YearMonthType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Tax Year End</Description>
						<LineNumber>Schedule C Line 2</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Country Name -->
			<xsd:element name="CountryCd" type="CountryType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Country of Incorporation</Description>
						<LineNumber>Schedule C Line 3</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Functional Currency of Foreign Corporation -->
			<xsd:element name="FunctionalCurrencyCd" type="CurrencyCodeType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Functional Currency of Foreign Corporation</Description>
						<LineNumber>Schedule C Line 4</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Regulation Section 1.960-1(d)(2)(ii)(B)(2) -->
			<xsd:element name="SubpartFIncomeGrpRegSect1960Cd" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Regulation Section 1.960-1(d)(2)(ii)(B)(2)</Description>
						<LineNumber>Schedule C Line 5a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="TextType">
						<xsd:enumeration value="DIRRA"/> <!-- Dividends, interest, rents, royalties, & annuities -->
						<xsd:enumeration value="NGCPT"/> <!-- Net gain from certain property transactions -->
						<xsd:enumeration value="NGCT"/> <!-- Net gain from commodities transactions -->
						<xsd:enumeration value="NFCG"/> <!-- Net foreign currency gain -->
						<xsd:enumeration value="IEQI"/> <!-- Income equivalent to interest -->
						<xsd:enumeration value="NPC"/> <!-- Income from notional principal contracts -->
						<xsd:enumeration value="PILOD"/> <!-- Payments in lieu of dividends -->
						<xsd:enumeration value="PSC"/> <!-- Personal service contracts -->
						<xsd:enumeration value="FBCSA"/> <!-- Foreign base company sales income -->
						<xsd:enumeration value="FBCSE"/> <!-- Foreign base company services income -->
						<xsd:enumeration value="FIFBC"/> <!-- Full inclusion foreign base company income -->
						<xsd:enumeration value="INSUR"/> <!-- Insurance income -->
						<xsd:enumeration value="BOYC"/> <!-- International boycott income -->
						<xsd:enumeration value="BKOP"/> <!-- Bribes, kickbacks and other payments -->
						<xsd:enumeration value="901J"/> <!-- Section 901(j) -->
					</xsd:restriction>
				</xsd:simpleType>
