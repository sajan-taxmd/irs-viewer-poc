						<Description>Appropriations Other Deductions Group</Description>
						<LineNumber>Schedule H Part II column (e)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:complexContent>
						<xsd:extension base="ApprtnOtherDeductionsGrpType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="OtherAllocableDeductionsSchedule">
								<xsd:annotation>
									<xsd:documentation>
									</xsd:documentation>
								</xsd:annotation>
							</xsd:attribute>
						</xsd:extension>
					</xsd:complexContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Total Section 951A - Section 245A Aggregate -->
			<xsd:element name="TotSect951ASect245AAggrgtAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Section 951A - Section 245A Aggregate</Description>
						<LineNumber>Schedule H Part II Line 3a(1) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Section 951A - Other Category Aggregate -->
			<xsd:element name="TotSect951AOtherCatAggrgtAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Section 951A - Other Category Aggregate</Description>
						<LineNumber>Schedule H Part II Line 3a(2) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Section 951A - Total Aggregate -->
			<xsd:element name="TotSect951AAggregateAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Section 951A - Total Aggregate</Description>
						<LineNumber>Schedule H Part II Line 3a(3) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Foreign Branch - Section 245A Aggregate -->
			<xsd:element name="TotFrgnBranchSect245AAggrgtAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Foreign Branch - Section 245A Aggregate</Description>
						<LineNumber>Schedule H Part II Line 3b(1) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Foreign Branch - Other Category Aggregate -->
			<xsd:element name="TotFrgnBranchOtherCatAggrgtAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Foreign Branch - Other Category Aggregate</Description>
						<LineNumber>Schedule H Part II Line 3b(2) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Foreign Branch - Total Aggregate -->
			<xsd:element name="TotFrgnBranchAggregateAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Foreign Branch - Total Aggregate</Description>
						<LineNumber>Schedule H Part II Line 3b(3) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Passive - Section 245A Aggregate -->
			<xsd:element name="TotPassiveSect245AAggrgtAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Passive - Section 245A Aggregate</Description>
						<LineNumber>Schedule H Part II Line 3c(1) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Passive - Other Category Aggregate -->
			<xsd:element name="TotPassiveOtherCatAggrgtAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Passive - Other Category Aggregate</Description>
						<LineNumber>Schedule H Part II Line 3c(2) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Passive - Category Aggregate -->
			<xsd:element name="TotPassiveCatAggregateAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Passive - Category Aggregate</Description>
						<LineNumber>Schedule H Part II Line 3c(3) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total General - Section 245A Aggregate -->
			<xsd:element name="TotGeneralSect245AAggrgtAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total General - Section 245A Aggregate</Description>
						<LineNumber>Schedule H Part II Line 3d(1) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total General - Other Category Aggregate -->
			<xsd:element name="TotGeneralCatOtherCatAggrgtAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total General - Other Category Aggregate</Description>
						<LineNumber>Schedule H Part II Line 3d(2) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total General - Category Aggregate -->
			<xsd:element name="TotGeneralCatAggregateAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total General - Category Aggregate</Description>
						<LineNumber>Schedule H Part II Line 3d(3) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Section 901j 245A Dividend Group  -->
			<xsd:element name="TotalSect901j245ADivGrp" type="TotalSect901j245ADivGrpType" minOccurs="0" maxOccurs="20">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Section 901j 245A Dividend Group</Description>
						<LineNumber>Schedule H Part II Line 3e(1) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Section 901j Other Group  -->
			<xsd:element name="TotalSect901jOtherGrp" type="TotalSect901jOtherGrpType" minOccurs="0" maxOccurs="20">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Section 901j Other Group</Description>
						<LineNumber>Schedule H Part II Line 3e(2) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Section 901(j) - Aggregate -->
			<xsd:element name="TotSect901jAggregateAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Section 901(j) - Aggregate</Description>
						<LineNumber>Schedule H Part II Line 3e(3) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Resourced By Treaty Section 245A Dividend Group -->
			<xsd:element name="TotalRBTSect245ADivGrp" type="TotalRBTSect245ADivGrpType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Resourced By Treaty Section 245A Dividend Group</Description>
						<LineNumber>Schedule H Part II Line 3e(1) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Resourced By Treaty Other Group -->
			<xsd:element name="TotalRBTOtherGrp" type="TotalRBTOtherGrpType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Resourced By Treaty Other Group</Description>
						<LineNumber>Schedule H Part II Line 3e(2) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total RBT - Total Aggregate -->
			<xsd:element name="TotRBTAggregateAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total RBT - Total Aggregate</Description>
						<LineNumber>Schedule H Part II Line 3e(3) column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Section 245A Dividend -->
			<xsd:element name="TotUSSrceIncmSect245AAggrgtAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Section 245A Dividend</Description>
						<LineNumber>Schedule H Part II Line 3f(1) Column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- ExpnsAllocApprtnSect245ADiv Amount -->
			<xsd:element name="ExpnsAllocApprtnSect245ADivAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Expenses Allocated  Apportioned Section 245A</Description>
						<LineNumber>Schedule H Part II Line 4</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- ===== Schedule H  Part III - Other Deductions ===== -->
			<xsd:element name="OfficerCompensationExpenseGrp" type="OfficerCompensationExpenseGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Officer Comp</Description>
						<LineNumber>Schedule H Part III Column (a)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Apportionment Interest Deductions -->
			<xsd:element name="AmortizationDeductionsGrp" type="AmortizationDeductionsGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Amortization Deductions</Description>
						<LineNumber>Schedule H Part III Column (b)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Depletion Deductions Group -->
			<xsd:element name="DepletionDeductionsGrp" type="DepletionDeductionsGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Depletion Deductions</Description>
						<LineNumber>Schedule H Part III Column (c)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Product Liability Damages Group -->
			<xsd:element name="ProductLiabilityDamagesGrp" type="ProductLiabilityDamagesGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Product Liability Damages Group</Description>
						<LineNumber>Schedule H Part III Column (d)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Other Certain Appropriation Deductions Group -->
			<xsd:element name="OtherCertainApprtnDedGrp" type="OtherCertainApprtnDedGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Other Certain Apportioned Deductions</Description>
						<LineNumber>Schedule H Part III Column (e)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Deductions Allocated Apprtn245ADiv Group -->
			<xsd:element name="TotDedAllocApprtn245ADivGrp" type="TotDedAllocApprtn245ADivGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Deductions Allocated and Apportioned to Section 245A</Description>
						<LineNumber>Schedule H Part III Column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Certain Deductions Allocated Appropriations Group -->
			<xsd:element name="TotalCertainDedAllocApprtnGrp" type="TotalCertainDedAllocApprtnGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Certain Deductions Allocated and Apportioned</Description>
						<LineNumber>Schedule H Part III Column (g)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Dividends Amount -->
			<xsd:element name="CrtnDedExpnssApprtn245ADivAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Certain Deductions and Expenses Apportioned to 245A Dividends</Description>
						<LineNumber>Schedule H Part III Line 3 Column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>	
		</xsd:sequence>
	</xsd:complexType>
	<!-- ===== Type for Total Section 901j 245A Dividend Group ===== -->
	<xsd:complexType name="TotalSect901j245ADivGrpType">
		<xsd:sequence>
			<!-- Section 901j Income -->
			<xsd:element name="Section901jIncomeCd">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Section 901j Income</Description>
						<LineNumber>Schedule H Part II Line 3e(1) column (f)</LineNumber>
						<LineNumber>Schedule H Part III Line 2e Column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
				      <xsd:restriction base="TextType">
					    <xsd:enumeration value="901j"/>
				      </xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<!-- Sanctioned Country Code -->
			<xsd:element name="SanctionedCountryCd" type="CountryType">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Sanctioned Country Code</Description>
						<LineNumber>Schedule H Part II Line 3e(1) column (f)</LineNumber>
						<LineNumber>Schedule H Part III Line 2e Column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Section 245A Dividend -->
			<xsd:element name="Section245ADividendAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Section 245A Dividend</Description>
						<LineNumber>Schedule H Part II Line 3e(1) column (f)</LineNumber>
						<LineNumber>Schedule H Part III Line 2e Column (f)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>			
		</xsd:sequence>
	</xsd:complexType>
	<!-- =========================================== Done for schedule A-H Type ======================================================================== -->
	<!-- ===== Type for Repeating Element "Income or (Loss) Before Adjustments" in Schedule A and Foreign Taxes Paid, Accrued, and Deemed Paid" in Schedule B ===== -->
	<xsd:complexType name="ScheduleAAndScheduleBPartIType">
		<xsd:sequence>
			<!-- Row ID -->
			<xsd:element name="RowId" type="IRS1118RowIDType" minOccurs="1">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Row identifier letter(s)</Description>
						<LineNumber>Schedule A identifier column</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Choice between Foreign Corporation EIN Or Foreign Entity Identification Group -->
			<xsd:choice minOccurs="0">
				<!-- Foreign Corporation EIN -->
				<xsd:element name="ForeignCorporationEIN" type="EINType">
					<xsd:annotation>
						<xsd:documentation>
							<Description>Foreign Corporation EIN</Description>
							<LineNumber>Schedule A Line 1a</LineNumber>
						</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
				<!-- Foreign Entity Identification Group -->
				<xsd:element name="ForeignEntityIdentificationGrp" type="ForeignEntityIdentificationGrpType">
					<xsd:annotation>
						<xsd:documentation>
							<Description>Foreign Entity Identification Group</Description>
							<LineNumber>Schedule A Line 1a</LineNumber>
						</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
			</xsd:choice>
			<!-- Branch Code -->
			<xsd:element name="BranchCd" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Branch Code</Description>
						<LineNumber>Schedule A Line 1a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="TextType">
						<xsd:enumeration value="BRANCH"/>
						<xsd:enumeration value="UNRELATED"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<!-- Choice between: Foreign Country or U.S. Possession or "965" or "951A" or "863(b)" or "NOL" or "RICs" or "HTKO" or "G2B" or "B2G" -->
			<xsd:choice minOccurs="0" maxOccurs="5">
				<!-- Foreign Country or U.S. Possession - "951A" -->
				<xsd:element name="Section951AIncomeCd">
					<xsd:annotation>
						<xsd:documentation>
							<Description>Foreign Country or U.S. Possession - 951A</Description>
							<LineNumber>Schedule A Line 1b</LineNumber>
						</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="TextType">
							<xsd:enumeration value="951A"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:element>
				<!-- Foreign Country or U.S. Possession - "NOL" -->
				<xsd:element name="NetOperatingLossCd">
					<xsd:annotation>
						<xsd:documentation>
							<Description>Foreign Country or U.S. Possession - NOL</Description>
							<LineNumber>Schedule A Line 1b</LineNumber>
						</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="TextType">
							<xsd:enumeration value="NOL"/>
						</xsd:restriction>
					</xsd:simpleType>
