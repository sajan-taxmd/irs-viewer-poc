<?xml version="1.0" encoding="UTF-8"?>
<xsd:schema xmlns="http://www.irs.gov/efile" xmlns:xsd="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.irs.gov/efile" elementFormDefault="qualified" attributeFormDefault="unqualified" version="1.0">
	<xsd:annotation>
		<xsd:documentation>
			<Description>IRS e-file Schema - Form 1118</Description>
			<TaxYear>2025</TaxYear>
			<MaturityLevel>Final Release</MaturityLevel>
			<ReleaseDate>February 19 2026</ReleaseDate>
		</xsd:documentation>
	</xsd:annotation>
	<xsd:include schemaLocation="../../../Common/efileTypes.xsd"/>
	<!-- =============================================================== -->
	<!-- =======================  IRS Form 1118 ======================== -->
	<!-- =============================================================== -->
	<xsd:element name="IRS1118">
		<xsd:annotation>
			<xsd:documentation>IRS Form 1118</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:complexContent>
				<xsd:extension base="IRS1118Type">
					<xsd:attributeGroup ref="DocumentAttributes">
						<xsd:annotation>
							<xsd:documentation>Common return document attributes</xsd:documentation>
						</xsd:annotation>
					</xsd:attributeGroup>
					<xsd:attribute name="documentName" type="StringType" fixed="IRS1118">
						<xsd:annotation>
							<xsd:documentation>IRS internal use only. To avoid error in the return, do not include the attribute name or value.</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
					<xsd:attribute name="referenceDocumentId" type="IdListType">
						<xsd:annotation>
							<xsd:documentation>List of document ID's of forms, schedules, supporting info. etc. attached to this form</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
					<xsd:attribute name="referenceDocumentName" type="StringType" fixed="BinaryAttachment CurrencyConversionStatement GeneralDependencySmall IRS1118ScheduleI IRS1118ScheduleL"/>
				</xsd:extension>
			</xsd:complexContent>
		</xsd:complexType>
	</xsd:element>
	<xsd:complexType name="IRS1118Type">
		<xsd:annotation>
			<xsd:documentation>Content model for Form 1118</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<!-- Name of the Corporation -->
			<xsd:element name="CorporationName" type="BusinessNameType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Name of the corporation</Description>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Corporation's EIN -->
			<xsd:element name="CorporationEIN" type="EINType">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Corporation EIN</Description>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Choice: Between a sequence and element – (Sequence - Sect951AOrPassiveCatIncomeCd, IRS1118ScheduleD) or SeparateCategoryCd -->
			<!-- Section 951A Or Passive Category Code -->
			<xsd:choice>
				<xsd:sequence>
					<xsd:element name="Sect951AOrPassiveCatIncomeCd">
						<xsd:annotation>
							<xsd:documentation>
								<Description>951A and Passive Category Codes</Description>
								<LineNumber>Line a</LineNumber>
							</xsd:documentation>
						</xsd:annotation>
						<xsd:simpleType>
							<xsd:restriction base="TextType">
								<xsd:enumeration value="PAS"/>
								<xsd:enumeration value="951A"/>
								<xsd:enumeration value="RBT PAS"/>
								<xsd:enumeration value="RBT 951A"/>
							</xsd:restriction>
						</xsd:simpleType>
					</xsd:element>
					<!-- IRS1118 Schedule D - Tax Deemed Paid by Corporation with respect to 951A Inclusions of Earnings from Foreign Corporations under section 960(d) -->
					<xsd:element name="IRS1118ScheduleD" type="IRS1118ScheduleDType" minOccurs="0"/>
				</xsd:sequence>
				<!-- Separate Category Code -->
				<xsd:element name="SeparateCategoryCd">
					<xsd:annotation>
						<xsd:documentation>
							<Description>Separate category code</Description>
							<LineNumber>Line a</LineNumber>
						</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="TextType">
							<xsd:enumeration value="GEN"/>
							<xsd:enumeration value="901j"/>
							<xsd:enumeration value="FB"/>
							<xsd:enumeration value="RBT GEN"/>
							<xsd:enumeration value="RBT FB"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:element>
			</xsd:choice>
			<!-- Sanctioned Country Code -->
			<xsd:element name="SanctionedCountryCd" type="CountryType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Sanctioned country code</Description>
						<LineNumber>b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Treaty Country Code -->
			<xsd:element name="TreatyCountryCd" type="CountryType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Treaty country code</Description>
						<LineNumber>c</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- IRS1118 Schedule A - Income or (Loss) Before Adjustments -->
			<xsd:element name="IRS1118ScheduleA" type="IRS1118ScheduleAType" minOccurs="0"/>
			<!-- IRS1118 Schedule B - Foreign Tax Credit -->
			<xsd:element name="IRS1118ScheduleB" type="IRS1118ScheduleBType" minOccurs="0"/>
			<!-- IRS1118 Schedule C - Tax Deemed Paid by Domestic Corporation Filing Return -->
			<xsd:element name="IRS1118ScheduleC" type="IRS1118ScheduleCType" minOccurs="0"/>
			<!-- IRS1118 Schedule E - Tax Deemed Paid With Respect to Previously Taxed Income by Domestic Corporation Filing the Return (Section 960(b)) -->
			<xsd:element name="IRS1118ScheduleE" type="IRS1118ScheduleEType" minOccurs="0"/>
			<!-- IRS1118 Schedule G - Reductions of Taxes Paid, Accrued, or Deemed Paid -->
			<xsd:element name="IRS1118ScheduleG" type="IRS1118ScheduleGType" minOccurs="0"/>
			<!-- IRS1118 Schedule H -  Apportionment of Certain Deductions -->
			<xsd:element name="IRS1118ScheduleH" type="IRS1118ScheduleHType" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- =============================================================== -->
	<!-- ===================  IRS Form 1118 Schedule A ================= -->
	<!-- =============================================================== -->
	<xsd:complexType name="IRS1118ScheduleAType">
		<xsd:annotation>
			<xsd:documentation>Content model for Form 1118 Schedule A</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<!-- Income or (Loss) Before Adjustments Table -->
			<xsd:element name="IncmLossBfrAdjFrgnTxsPdAccrGrp" type="ScheduleAAndScheduleBPartIType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Income or (Loss) Before Adjustments table</Description>
						<LineNumber>Schedule A Line 1a-17 and Schedule B Part 1 Line 1-3</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Inclusions 951A Exclude Gross Up -->
			<xsd:element name="TotInclsn951AExcldGrossUpAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Inclusions 951A Exclude Gross Up</Description>
						<LineNumber>Schedule A Line 3a Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Inclusions 951A Gross Up -->
			<xsd:element name="TotInclusionSec951AGrossUpAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Inclusions 951A Gross Up</Description>
						<LineNumber>Schedule A Line 3b Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Dividends Amount -->
			<xsd:element name="TotalDividendsAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Dividends Amount</Description>
						<LineNumber>Schedule A Line 4 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Interest -->
			<xsd:element name="TotalInterestReceivedAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Interest</Description>
						<LineNumber>Schedule A Line 5 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Gross Rents, Royalties, and License Fees -->
			<xsd:element name="TotalGroRentsRyltsLcnsFeesAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Gross Rents, Royalties, and License Fees</Description>
						<LineNumber>Schedule A Line 6 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Sales -->
			<xsd:element name="TotalSalesAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Sales</Description>
						<LineNumber>Schedule A Line 7 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Gross Income From Performance of Services -->
			<xsd:element name="TotalGrossIncomeAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Gross Income From Performance of Services</Description>
						<LineNumber>Schedule A Line 8 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Currency Gain Amount -->
			<xsd:element name="TotalCurrencyGainAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Currency Gain Amount</Description>
						<LineNumber>Schedule A Line 9 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Other Income Loss Amount -->
			<xsd:element name="TotalOtherIncomeLossAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Other Income Loss Amount</Description>
						<LineNumber>Schedule A Line 11 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Gross Income Or Loss Amount -->
			<xsd:element name="TotalGrossIncomeOrLossAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Gross Income Or Loss Amount</Description>
						<LineNumber>Schedule A Line 12 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Dividends Received Deduction -->
			<xsd:element name="TotalDividendsReceivedDedAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Dividends Received Deduction</Description>
						<LineNumber>Schedule A Line 13a Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Deduction Allowed Under Section 250(a)(1)(A) -->
			<xsd:element name="TotDedSect250a1AIntngblIncmAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Deduction Allowed Under Section 250(a)(1)(A)</Description>
						<LineNumber>Schedule A Line 13b Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Deduction Allowed Under Section 250(a)(1)(B) -->
			<xsd:element name="TotDedSect250a1BIntngblIncmAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Deduction Allowed Under Section 250(a)(1)(B)</Description>
						<LineNumber>Schedule A Line 13c Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Rental, Royalty, and Licensing Expenses - Depreciation, Depletion, and Amortization -->
			<xsd:element name="TotalDeprecDpltnAmortExpnsAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Rental, Royalty, and Licensing Expenses - Depreciation, Depletion, and Amortization</Description>
						<LineNumber>Schedule A Line 13d Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Rental, Royalty, and Licensing Expenses - Other Expenses -->
			<xsd:element name="TotalOtherExpensesAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Rental, Royalty, and Licensing Expenses - Other Expenses</Description>
						<LineNumber>Schedule A Line 13e Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Expenses Allocable to Sales Income -->
			<xsd:element name="TotExpensesRelatedSalesIncmAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Expenses Allocable to Sales Income</Description>
						<LineNumber>Schedule A Line 13f Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Expenses Allocable to Gross Income From Performance of Services -->
			<xsd:element name="TotalGroIncmRelatedExpensesAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Expenses Allocable to Gross Income From Performance of Services</Description>
						<LineNumber>Schedule A Line 13g Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Currency Loss Amount -->
			<xsd:element name="TotalCurrencyLossAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Currency Loss Amount</Description>
						<LineNumber>Schedule A Line 13h Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Other Allocable Deductions -->
			<xsd:element name="TotOtherAllocableDeductionsAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Other Allocable Deductions</Description>
						<LineNumber>Schedule A Line 13j Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Total Allocable Deductions -->
			<xsd:element name="AggrgtTotalAllocableDedAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Total Allocable Deductions</Description>
						<LineNumber>Schedule A Line 13k Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Apportioned Share of Deductions -->
			<xsd:element name="TotalApportionedShareDedAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Apportioned Share of Deductions</Description>
						<LineNumber>Schedule A Line 14 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Net Operating Loss Deduction -->
			<xsd:element name="TotalNOLDeductionAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Net operating loss deduction</Description>
						<LineNumber>Schedule A Line 15 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Total Deductions (add 14(i) through 16) -->
			<xsd:element name="AggregateTotalDeductionAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Total deductions (add 14(i) through 16)</Description>
						<LineNumber>Schedule A Line 16 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Total Income or (Loss) Before Adjustments (col 13 minus col 17) -->
			<xsd:element name="AggrgtTotIncmOrLossBfrAdjAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of total income or (loss) before adjustments (col 13 minus col 17)</Description>
						<LineNumber>Schedule A Line 17 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<!-- =============================================================== -->
	<!-- ===================  IRS Form 1118 Schedule B ================= -->
	<!-- =============================================================== -->
	<xsd:complexType name="IRS1118ScheduleBType">
		<xsd:annotation>
			<xsd:documentation>Content model for Form 1118 Schedule B</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<!-- ===== Schedule B - Part I - Total Foreign Taxes Paid, Accrued, and Deemed Paid ===== -->
			<!-- Choice between Credit is Claimed for Taxes: Paid or Accrued -->
			<xsd:choice minOccurs="0">
				<!-- Credit is Claimed for Taxes Paid -->
				<xsd:element name="ForeignTaxesPaidCreditInd">
					<xsd:annotation>
						<xsd:documentation>
							<Description>Credit is Claimed for Taxes Paid</Description>
							<LineNumber>Schedule B Part I Line 1</LineNumber>
						</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:simpleContent>
							<xsd:extension base="CheckboxType">
								<xsd:attribute name="referenceDocumentId" type="IdListType"/>
								<xsd:attribute name="referenceDocumentName" type="StringType" fixed="ForeignTaxesPaidAccruedAndDeemedPaidStatement"/>
							</xsd:extension>
						</xsd:simpleContent>
					</xsd:complexType>
				</xsd:element>
				<!-- Credit is Claimed for Taxes Accrued -->
				<xsd:element name="ForeignTaxesAccruedCreditInd">
					<xsd:annotation>
						<xsd:documentation>
							<Description>Credit is Claimed for Taxes Accrued</Description>
							<LineNumber>Schedule B Part I Line 1</LineNumber>
						</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:simpleContent>
							<xsd:extension base="CheckboxType">
								<xsd:attribute name="referenceDocumentId" type="IdListType"/>
								<xsd:attribute name="referenceDocumentName" type="StringType" fixed="ForeignTaxesPaidAccruedAndDeemedPaidStatement"/>
							</xsd:extension>
						</xsd:simpleContent>
					</xsd:complexType>
				</xsd:element>
			</xsd:choice>
			<!-- Total of Tax Withheld at Source on Dividends -->
			<xsd:element name="TotalTaxWithheldDividendsAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Tax Withheld at Source on Dividends</Description>
						<LineNumber>Schedule B Part I Line 2a Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Tax Withheld at Source on Distributions -->
			<xsd:element name="TotTxWithheldDistributionsAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Tax Withheld at Source on Distributions</Description>
						<LineNumber>Schedule B Part I Line 2b(1) Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Tax Withheld at Source on Branch Remittance -->
			<xsd:element name="TotTxWthldBranchRemittanceAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Tax Withheld at Source on Branch Remittance</Description>
						<LineNumber>Schedule B Part I Line 2c Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Tax Withheld at Source on Interest -->
			<xsd:element name="TotalTaxWithheldInterestAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Tax Withheld at Source on Interest</Description>
						<LineNumber>Schedule B Part I Line 2d Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Tax Withheld at Source on Rents, Royalties, and License Fees -->
			<xsd:element name="TotTxWithheldRentsRyltsLcnsAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Tax Withheld at Source on Rents, Royalties, and License Fees</Description>
						<LineNumber>Schedule B Part I Line 2e Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Tax Withheld at Source on Other -->
			<xsd:element name="TotalTaxWithheldOtherAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Tax Withheld at Source on Other</Description>
						<LineNumber>Schedule B Part I Line 2f Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Other Foreign Taxes Paid or Accrued on Sales Income -->
			<xsd:element name="TotalTxPdOrAccrSalesIncomeAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Other Foreign Taxes Paid or Accrued on Sales Income</Description>
						<LineNumber>Schedule B Part I Line 2g Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Other Foreign Taxes Paid or Accrued on Services Income -->
			<xsd:element name="TotalTxPdOrAccrServicesIncmAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Other Foreign Taxes Paid or Accrued on Services Income</Description>
						<LineNumber>Schedule B Part I Line 2h Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Other Foreign Taxes Paid or Accrued on Other Income -->
			<xsd:element name="TotalTxPdOrAccrOtherIncmAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Other Foreign Taxes Paid or Accrued on Other Income</Description>
						<LineNumber>Schedule B Part I Line 2i Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Total Foreign Taxes Paid or Accrued -->
			<xsd:element name="AggrtTotFrgnTaxesPaidOrAccrAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Total Foreign Taxes Paid or Accrued</Description>
						<LineNumber>Schedule B Part I Line 2j Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total of Taxes Deemed Paid -->
			<xsd:element name="TotalTaxesDeemedPaidAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total of Taxes Deemed Paid</Description>
						<LineNumber>Schedule B Part I Line 3 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- ===== Schedule B - Part II - Separate Foreign Tax Credit ===== -->
			<!-- For Total Foreign Taxes Paid, Schedule B Part II Line 1a, use value of Schedule B Part I Line 2j Total -->
			<!-- For Total Taxes Deemed Paid, Schedule B Part II Line 2, use value of Schedule B Part I Line 3 Total -->
			<!-- For Reductions of Taxes Paid, Schedule B Part II Line 3, use value of Schedule G Part I Total  -->
			<!-- Foreign Taxes Paid or Accrued by the Corporation During Prior Tax Years That Were Suspended due to the Rules of Section 909 and for Which the Related Income is Taken into Account by the Corporation During the Current Tax Year (See Instructions) -->
			<xsd:element name="TxsAttributableRelatedIncmAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Foreign taxes paid or accrued by the corporation during prior tax years that were suspended due to the rules of section 909 and for which the related income is taken into account by the corporation during the current tax year (see instructions)</Description>
						<LineNumber>Schedule B Part II Line 1b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Taxes Reclassified Under High-Tax Kickout(HTKO) -->
			<xsd:element name="ForeignIncHighTaxKickOutAdjAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Taxes reclassified under high-tax kickout(HTKO)</Description>
						<LineNumber>Schedule B Part II Line 4</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Enter The Sum Of Any Carryover -->
			<xsd:element name="TotCYCarryoverFrgnOilAndTxAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Enter the sum of any carryover</Description>
						<LineNumber>Schedule B Part II Line 5</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="USAmountType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="IRS1118ScheduleK"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Total Foreign Taxes -->
			<xsd:element name="TotalForeignTaxesAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total foreign taxes (combine lines 1 through 5)</Description>
						<LineNumber>Schedule B Part II Line 6</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="USAmountType">
							<xsd:attribute name="foreignIncHighTaxedKickOutCd">
								<xsd:simpleType>
									<xsd:restriction base="TextType">
										<xsd:enumeration value="HTKO"/>
									</xsd:restriction>
								</xsd:simpleType>
							</xsd:attribute>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Applicable Schedule J Part I line 11 Amount (if available) or Total of Total Income or (Loss) Before Adjustments from Schedule A -->
			<xsd:element name="ScheduleJOrTotalIncmBfrAdjAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Enter the amount from the applicable column of Schedule J, Part I, line 11. If Schedule J is not required to be completed, enter the result from the "Totals" line of column 17 of the applicable Schedule A</Description>
						<LineNumber>Schedule B Part II Line 7</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="USAmountType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="IRS1118ScheduleJ"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Total Taxable Income -->
			<xsd:element name="TotalTaxableIncomeAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total taxable income from all sources (enter taxable income from the corporation's tax return)</Description>
						<LineNumber>Schedule B Part II Line 8a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Adjustments to Total Taxable Income -->
			<xsd:element name="TotalTaxableIncomeAdjAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Adjustments to total taxable income</Description>
						<LineNumber>Schedule B Part II Line 8b</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Taxable Income minus Adjustments to Total Taxable Income -->
			<xsd:element name="NetTotalTaxableIncomeAdjAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total taxable income minus adjustments to total taxable income</Description>
						<LineNumber>Schedule B Part II Line 8c</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Applicable Schedule J Part I line 11 Amount (if available) or Total of Total Income or (Loss) Before Adjustments from Schedule A divided by Total Taxable Income minus Adjustments to Total Taxable Income -->
			<xsd:element name="NumLimitationFractionAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Divide line 7 by line 8c.  Enter the resulting fraction as a decimal.  If line 7 is greater than line 8c, enter 1</Description>
						<LineNumber>Schedule B Part II Line 9</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="xsd:decimal">
						<xsd:totalDigits value="16"/>
						<xsd:fractionDigits value="15"/>
						<xsd:minInclusive value="0.000000000000000"/>
						<xsd:maxInclusive value="1.000000000000000"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<!-- Total U.S. Credit Allowed Income Tax -->
			<xsd:element name="TotalUSIncomeTaxCrAllowedAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total U.S. income tax against which credit is allowed</Description>
						<LineNumber>Schedule B Part II Line 10</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Multiplying Line 9 by Line 10 -->
			<xsd:element name="LmtFrctnTimesTotUSIncmTaxCrAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Multiplying line 9 by line 10</Description>
						<LineNumber>Schedule B Part II Line 11</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Increase in Limitation -->
			<xsd:element name="IncreaseLimitationSect960cAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Increase in limitation</Description>
						<LineNumber>Schedule B Part II Line 12</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Credit Limitation -->
			<xsd:element name="CreditLimitationAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Credit limitation</Description>
						<LineNumber>Schedule B Part II Line 13</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Separate Foreign Tax Credit -->
			<xsd:element name="SeparateForeignTaxCreditAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Separate foreign tax credit</Description>
						<LineNumber>Schedule B Part II Line 14</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- ===== Schedule B - Part III - Summary of Separate Credits ===== -->
			<xsd:element name="SummaryOfSeparateCredits" minOccurs="0">
				<xsd:complexType>
					<xsd:sequence>
						<!-- Foreign Income Section 951A Credit -->
						<xsd:element name="ForeignIncmSection951ACrAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Credit for taxes on section 951A category income</Description>
									<LineNumber>Schedule B Part III Line 1</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Foreign Branch Income Credit -->
						<xsd:element name="ForeignBranchIncomeCrAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Credit for taxes on foreign branch income</Description>
									<LineNumber>Schedule B Part III Line 2</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Passive Income Tax Credit -->
						<xsd:element name="ForeignPassiveIncTaxCreditAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Credit for taxes on passive income</Description>
									<LineNumber>Schedule B Part III Line 3</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- General Income Tax Credit -->
						<xsd:element name="ForeignGeneralIncTaxCreditAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Credit for taxes on general income</Description>
									<LineNumber>Schedule B Part III Line 4</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Foreign Income Section 901(j) Credit -->
						<xsd:element name="ForeignIncmSection901jCrAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Credit for taxes on section 901(j) category income</Description>
									<LineNumber>Schedule B Part III Line 5</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Income Re-sourced by Treaty Tax Credit -->
						<xsd:element name="ForeignIncRsrcdTreatyTaxCrAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Credit for taxes on income re-sourced by treaty</Description>
									<LineNumber>Schedule B Part III Line 6</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Sub-total of Tax Credits -->
						<xsd:element name="RelatedTaxAdjustmentAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Total (add lines 1 through 6)</Description>
									<LineNumber>Schedule B Part III Line 7</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Smaller of specified lines -->
						<xsd:element name="SmllrTotUSIncmTxOrRltdTxAdjAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Smaller of specified lines</Description>
									<LineNumber>Schedule B Part III Line 8</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- International Boycott Operations Credit Reduction -->
						<xsd:element name="IntlBoycottCreditReductionAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Reduction in credit for international boycott operations</Description>
									<LineNumber>Schedule B Part III Line 9</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Total Foreign Tax Credit -->
						<xsd:element name="ForeignTaxCreditAmt" type="USAmountType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Total Foreign Tax Credit</Description>
									<LineNumber>Schedule B Part III Line 10</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<!-- =============================================================== -->
	<!-- ===================  IRS Form 1118 Schedule C ================= -->
	<!-- =============================================================== -->
	<xsd:complexType name="IRS1118ScheduleCType">
		<xsd:annotation>
			<xsd:documentation>Content model for Form 1118 Schedule C</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<!-- ===== Schedule C - Part I Tax Deemed Paid 951a1 Inclusions under Section 960 ===== -->
			<!-- Section 951 (a)(1) Inclusions Corporation Group -->
			<xsd:element name="Section951a1InclusionsCorpGrp" type="Section951a1InclusionsCorpGrpType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Section 951 (a)(1) Inclusions Corporation Group</Description>
						<LineNumber>Schedule C Line 1 - 10</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total (add Amounts in Column 10) -->
			<xsd:element name="TotalTaxesDeemedPaidAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total (add Amounts in Column 10)</Description>
						<LineNumber>Schedule C Line 10 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<!-- =============================================================== -->
	<!-- ===================  IRS Form 1118 Schedule D ================= -->
	<!-- =============================================================== -->
	<xsd:complexType name="IRS1118ScheduleDType">
		<xsd:annotation>
			<xsd:documentation>Content model for Form 1118 Schedule D</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<!-- ===== Schedule D - Tax Deemed Paid by Corporation with respect to 951A Inclusions of Earnings from Foreign Corporations under section 960(d) ===== -->
			<!-- Foreign Corporation's Tested Income and Foreign Taxes Table -->
			<xsd:element name="ForeignTestedIncmAndFrgnTxGrp" type="FrgnTestedIncmAndFrgnTaxGrpType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Foreign Corporation's Tested Income and Foreign Taxes Table</Description>
						<LineNumber>Schedule D Part I Line 1a- 9</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Pro Rata Share of CFC Tested Income -->
			<xsd:element name="TotProRataShrCFCTestedIncmAmt" type="USAmountNNType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total (add amounts in column 5)</Description>
						<LineNumber>Schedule D Part I Line 5 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Pro Rata Share of Tested Foreign Income Taxes Paid or Accrued by CFC -->
			<xsd:element name="TotShrFrgnIncmTxPdOrAccrCFCAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total (add amount in column 9)</Description>
						<LineNumber>Schedule D Part I Line 9 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- ===== Schedule D Part II- Foreign Income Tax Deemed Paid ===== -->
			<!-- Global Intangible Low Taxed Income Table -->
			<xsd:element name="GlobalIntangibleLowTxIncmGrp" type="GlobalIntangibleLowTxIncmGrpType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Dividends Paid Out of Pre-1987 Accumulated Profits table</Description>
						<LineNumber>Schedule D Part II Line 1-4</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<!-- =============================================================== -->
	<!-- ===================  IRS Form 1118 Schedule E ================= -->
	<!-- =============================================================== -->
	<xsd:complexType name="IRS1118ScheduleEType">
		<xsd:annotation>
			<xsd:documentation>Content model for Form 1118 Schedule E</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<!-- ===== Schedule E - Part I - Tax Deemed Paid by Domestic Corporations ===== -->
			<!-- Tax Deemed Paid Section 901 960(b) Group-->
			<xsd:element name="TaxDeemedPdSect901Sect960bGrp" type="TaxDeemedPdSect901and960bGrpType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Tax Deemed Paid Section 901 960(b) Group</Description>
						<LineNumber>Schedule E Part I Line 1a-16</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total (Add Amounts in Column 11) -->
			<xsd:element name="TotalTaxDeemedPdSection960bAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total (Add Amounts in Column 11)</Description>
						<LineNumber>Schedule E Part I Line 11 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total amount Disallowed under section 965(g) with respect to 960(b). -->
			<xsd:element name="TotDsallwSect965gSect960b1Amt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total amount Disallowed under section 965(g) with respect to 960(b).</Description>
						<LineNumber>Schedule E Part I Line 12 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total amount Disallowed under Section 960(d)(4) with respect to 960(b). -->
			<xsd:element name="TotDsallwSect960d4Sect960b1Amt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total amount Disallowed under Section 960(d)(4) with respect to 960(b).</Description>
						<LineNumber>Schedule E Part I Line 13 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Section 901 Taxes Paid or Accrued. -->
			<xsd:element name="TotSect901TaxPdOrAccruedAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total Section 901 Taxes Paid or Accrued.</Description>
						<LineNumber>Schedule E Part I Line 14 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total amount Disallowed under Section 965(g) with respect to 901. -->
			<xsd:element name="TotDsallwSect965gSect901Amt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total amount Disallowed under Section 965(g) with respect to 901.</Description>
						<LineNumber>Schedule E Part I Line 15 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total amount Disallowed under Section 960(d)(4) with respect to 901. -->
			<xsd:element name="TotDsallwSect960d4Sect901Amt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total amount Disallowed under Section 960(d)(4) with respect to 901.</Description>
						<LineNumber>Schedule E Part I Line 16 Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>			
			<!-- ===== Schedule E - Part II - Tax Paid or Deemed Paid by First and Lower-Tier Foreign Corporations ===== -->
			<!-- Lower Tier Section 901 960(b) Foreign Corporation Group -->
			<xsd:element name="LwrTierSect901960bFrgnCorpGrp" type="LwrTierSect901960bFrgnCorpGrpType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Lower Tier Section 901 960(b) Foreign Corporation Group</Description>
						<LineNumber>Schedule E Part II Line 1a-14</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<!-- =============================================================== -->
	<!-- ===================  IRS Form 1118 Schedule G ================= -->
	<!-- =============================================================== -->
	<xsd:complexType name="IRS1118ScheduleGType">
		<xsd:annotation>
			<xsd:documentation>Content model for Form 1118 Schedule G</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<!-- ===== Part I - Reduction Amounts ===== -->
			<!-- Section 901(e) Tax Reduction -->
			<xsd:element name="Section901eTaxReductionAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Reduction of Taxes Under Section 901(e)</Description>
						<LineNumber>Schedule G Part I Line A</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="USAmountType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="ReductionOfTaxesUnderSection901eSchedule"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Oil and Gas Extraction Tax Reduction -->
			<xsd:element name="ReductionForeignOilGasTaxesAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Reduction of Oil and Gas Extraction Taxes</Description>
						<LineNumber>Schedule G Part I Line B</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- International Boycott Provisions Tax Reduction -->
			<xsd:element name="ForeignTaxCreditReductionAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Reduction of Taxes Due to International Boycott Provisions</Description>
						<LineNumber>Schedule G Part I Line C</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Section 6038(c) Penalty Tax Reduction -->
			<xsd:element name="Sect6038cPnltyTxReductionAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Reduction of Taxes for Section 6038(c) Penalty</Description>
						<LineNumber>Schedule G Part I Line D</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="USAmountType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="ReductionOfTaxesForSection6038cPenaltySchedule"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Taxes Suspended Under Section 909 Amt  -->
			<xsd:element name="TaxesSuspendedUnderSect909Amt" type="USAmountType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Taxes Suspended Under Section 909 Amt</Description>
						<LineNumber>Schedule G Part I Line E</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Reduction For Disallowed Taxes Under Section 965(g) Amount -->
			<xsd:element name="RedDsallwTaxesUnderSect965gAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Reduction for disallowed taxes under section 965(g)</Description>
						<LineNumber>Schedule G Part I Line F</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Reduction For Disallowed Taxes Under Section 245A Amount -->
			<xsd:element name="RedDsallwTaxesUnderSect245AAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Reduction for disallowed taxes under section 245A</Description>
						<LineNumber>Schedule G Part I Line G</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Reduction for disallowed taxes under section 960(d)(4) -->
			<xsd:element name="RedDsallwTaxesUndSect960d4Amt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Reduction for disallowed taxes under section 960(d)(4)</Description>
						<LineNumber>Schedule G Part I Line H</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>			
			<!-- Other reductions in Amount -->
			<xsd:element name="OtherTaxReductionsAmt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Other reductions in taxes</Description>
						<LineNumber>Schedule G Part I Line I</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="USAmountType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="StringType" fixed="OtherReductionOfTaxesSchedule"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Total Tax Reductions -->
			<xsd:element name="ForeignTaxReductionAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total (add lines A through H)</Description>
						<LineNumber>Schedule G Part I Total</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Check This Box if, During the Tax Year,  the Corporation Paid or Accrued any Foreign Tax That was Disqualified for Credit Under Section 901 (m) -->
			<xsd:element name="CorpPayAccrFrgnTaxSect901mInd" type="CheckboxType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Check this box if, during the tax year,  the corporation paid or accrued any foreign tax that was disqualified for credit under section 901 (m)</Description>
						<LineNumber>Schedule G Part II Line J</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Check This Box if, During the Tax Year,  the Corporation Paid or Accrued any Foreign Tax That was Disqualified for Credit Under Section 901(j), (k) or (l)  -->
			<xsd:element name="CorpPayAccrFrgnTxSect901jklInd" type="CheckboxType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Check this box if, during the tax year,  the corporation paid or accrued any foreign tax that was disqualified for credit under section 901(j), (k) or (l)</Description>
						<LineNumber>Schedule G Part II Line K</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<!-- =============================================================== -->
	<!-- ===================  IRS Form 1118 Schedule H ================= -->
	<!-- =============================================================== -->
	<xsd:complexType name="IRS1118ScheduleHType">
		<xsd:annotation>
			<xsd:documentation>Content model for Form 1118 Schedule H</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<!-- ===== Schedule H  Part I  Research and Experimental Deductions ===== -->
			<!-- ===== (a) Gross Receipts Method ===== -->
			<!-- Gross Receipts Method Group -->
			<xsd:element name="GrossReceiptsMethodGrp" type="GrossReceiptsMethodGrpType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Gross Receipts Method Group</Description>
						<LineNumber>Schedule H Part I, column (a), Lines 1 - 7</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- ===== (b) Total R&E Deductions (enter the sum of all amounts entered in all applicable “R&E Deductions” columns) ===== -->
			<!-- Total R&E Deductions Entered Amount -->
			<xsd:element name="TotREDeductionsEnteredAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total R and E deductions entered</Description>
						<LineNumber>Schedule H Part I, column (b), Line1</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total US Source Gross Intangible Income Amount -->
			<xsd:element name="TotUSSrceGroIntngblIncmAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total US source gross intangible income</Description>
						<LineNumber>Schedule H Part I, column (b), Line2a</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Research Experimental Deduction Amount -->
			<xsd:element name="TotResearchExperimentalDedAmt" type="USAmountType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total research experimental deduction</Description>
						<LineNumber>Schedule H Part I, column (b), Line 4d</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Section 951A Foreign Source R&E Deduction Group -->
			<xsd:element name="TotSect951AFrgnSrceREDedGrp" type="TotSect951AFrgnSrceREDedGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total section 951A foreign source R and E deduction group</Description>
						<LineNumber>Schedule H Part I, Column (b), Line 6a (7)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Foreign Branch Source R&E Deduction Group -->
			<xsd:element name="TotFrgnBrFrgnSrceREDedGrp" type="TotFrgnBrFrgnSrceREDedGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total foreign branch source R and E deduction group</Description>
						<LineNumber>Schedule H Part I, column (b), Line 6a (7) or 6b(7)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Passive Category Foreign Source R&E Deduction Group -->
			<xsd:element name="TotPssvCatFrgnSrceREDedGrp" type="TotPssvCatFrgnSrceREDedGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total passive category foreign source R and E deduction group</Description>
						<LineNumber>Schedule H Part I, column (b), Line 6a(7) or 6b(7), or 6c (7)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total General Category Foreign Source R and E Deduction Group -->
			<xsd:element name="TotGenCatFrgnSrceREDedGrp" type="TotGenCatFrgnSrceREDedGrpType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total general category foreign source R and E deduction group</Description>
						<LineNumber>Schedule H Part I, column (b), Line 6a(7) or 6b(7) or 6c (7) or 6d(7)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total Section 901j Category Foreign Source R&E Deduction Group -->
			<xsd:element name="TotSect901jCatFrgnSrceREDedGrp" type="TotSect901jCatFrgnSrceREDedGrpType" minOccurs="0" maxOccurs="20">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total section 901j category foreign source R and E deduction group</Description>
						<LineNumber>Schedule H Part I, column (b), Line 6a(7) or 6b(7) or 6c (7) or 6d(7) or 6e(7)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Total RBT Foreign Source R&E Deduction Group -->
			<xsd:element name="TotRBTFrgnSrceREDedGrp" type="TotRBTFrgnSrceREDedGrpType" minOccurs="0" maxOccurs="unbounded">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total RBT foreign source R and E deduction group</Description>
						<LineNumber>Schedule H Part I, column (b), Line 6a, (7) or 6b, (7), or 6c (7), or 6d, (7), or 6e, (7)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>

			<!-- ===== Schedule H  Part II  Deductions Allocated and Apportioned Based on Assets ===== -->
