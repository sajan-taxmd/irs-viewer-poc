					<xsd:documentation>
						<Description>Stewardship Deductions Group</Description>
						<LineNumber>Schedule H Part II column (c)</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Crtn Industrial Invstment Damages Group  -->
			<xsd:element name="CrtnIndustrialInvstDamagesGrp" type="CrtnIndustrialInvstDamagesGrpType" minOccurs="0">
				<xsd:annotation>
