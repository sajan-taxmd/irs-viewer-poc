<?xml version="1.0" encoding="UTF-8"?>
<xsd:schema xmlns="http://www.irs.gov/efile" xmlns:xsd="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.irs.gov/efile" elementFormDefault="qualified" attributeFormDefault="unqualified" version="1.0">
	<xsd:annotation>
		<xsd:documentation>
			<Description>IRS e-file Schema - IRS Form 1040NR Other Information</Description>
			<TaxYear>2025</TaxYear>
			<MaturityLevel>Final Release</MaturityLevel>
			<ReleaseDate>February 19 2026</ReleaseDate>
		</xsd:documentation>
	</xsd:annotation>
	<xsd:include schemaLocation="../../../Common/efileTypes.xsd"/>
	<!-- =============================================================== -->
	<!-- ================ IRS Form 1040-NR Schedule OI ================= -->
	<!-- =============================================================== -->
	<xsd:element name="IRS1040NRScheduleOI">
		<xsd:annotation>
			<xsd:documentation>IRS Form 1040-NR Schedule Other Information</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:complexContent>
				<xsd:extension base="IRS1040NRScheduleOIType">
					<xsd:attributeGroup ref="DocumentAttributes">
						<xsd:annotation>
							<xsd:documentation>Common return document attributes</xsd:documentation>
						</xsd:annotation>
					</xsd:attributeGroup>
					<xsd:attribute name="documentName" type="xsd:string" fixed="IRS1040NRScheduleOI">
						<xsd:annotation>
							<xsd:documentation>IRS internal use only. To avoid error in the return, do not include the attribute name or value.</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
					<xsd:attribute name="referenceDocumentId" type="IdListType">
						<xsd:annotation>
							<xsd:documentation>List of document ID's of forms, schedules, supporting info. etc. attached to this form</xsd:documentation>
						</xsd:annotation>
					</xsd:attribute>
				</xsd:extension>
			</xsd:complexContent>
		</xsd:complexType>
	</xsd:element>
	<xsd:complexType name="IRS1040NRScheduleOIType">
		<xsd:annotation>
			<xsd:documentation>Content model for IRS Form 1040NR</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<!-- =============== Schedule OI - Other Information =============== -->
			<!-- Citizen Country Code -->
			<xsd:element name="CitizenCountryCd" type="AllCountriesType" maxOccurs="5">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Citizen country code</Description>
						<LineNumber>Line A</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Foreign Tax Residence Country Code -->
			<xsd:element name="ForeignTaxResidenceCountryCd" type="AllCountriesType">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Foreign tax residence country code</Description>
						<LineNumber>Line B</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Applied To Be Lawful Permanent Resident Of U.S. Indicator -->
			<xsd:element name="AppLawfulPermanentResidentInd" type="BooleanType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Applied to be lawful permanent resident of U.S. indicator</Description>
						<LineNumber>Line C</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- U.S. Citizen Indicator -->
			<xsd:element name="USCitizenInd" type="BooleanType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>U.S. citizen indicator</Description>
						<LineNumber>Line D1</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Lawful Permanent Resident Indicator -->
			<xsd:element name="LawfulPermanentResidentInd" type="BooleanType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Lawful permanent resident indicator</Description>
						<LineNumber>Line D2</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:choice>
				<!-- Nonimmigrant Visa Type Code -->
				<xsd:element name="NonImmigrantVisaTypeCd">
					<xsd:annotation>
						<xsd:documentation>
							<Description>Nonimmigrant visa type code</Description>
							<LineNumber>Line E</LineNumber>
						</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="TextType">
							<xsd:enumeration value="A1"/>
							<xsd:enumeration value="A2"/>
							<xsd:enumeration value="A3"/>
							<xsd:enumeration value="B1"/>
							<xsd:enumeration value="B2"/>
							<xsd:enumeration value="B1/B2"/>
							<xsd:enumeration value="C1"/>
							<xsd:enumeration value="C1/D"/>
							<xsd:enumeration value="C2"/>
							<xsd:enumeration value="C3"/>
							<xsd:enumeration value="CW1"/>
							<xsd:enumeration value="CW2"/>
							<xsd:enumeration value="D"/>
