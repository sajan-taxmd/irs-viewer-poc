							<xsd:enumeration value="T4"/>
							<xsd:enumeration value="T5"/>
							<xsd:enumeration value="TN"/>
							<xsd:enumeration value="TD"/>
							<xsd:enumeration value="U1"/>
							<xsd:enumeration value="U2"/>
							<xsd:enumeration value="U3"/>
							<xsd:enumeration value="U4"/>
							<xsd:enumeration value="U5"/>
							<xsd:enumeration value="V1"/>
							<xsd:enumeration value="V2"/>
							<xsd:enumeration value="V3"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:element>
				<!-- Immigrant Visa Type Code -->
				<xsd:element name="ImmigrantVisaTypeCd">
					<xsd:annotation>
						<xsd:documentation>
							<Description>Immigrant visa type code</Description>
							<LineNumber>Line E</LineNumber>
						</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="TextType">
							<xsd:enumeration value="IR1"/>
							<xsd:enumeration value="IR2"/>
							<xsd:enumeration value="IR3"/>
							<xsd:enumeration value="IH3"/>
							<xsd:enumeration value="IR4"/>
							<xsd:enumeration value="IH4"/>
							<xsd:enumeration value="IR5"/>
							<xsd:enumeration value="CR1"/>
							<xsd:enumeration value="CR2"/>
							<xsd:enumeration value="IW1"/>
							<xsd:enumeration value="IW2"/>
							<xsd:enumeration value="IB1"/>
							<xsd:enumeration value="IB2"/>
							<xsd:enumeration value="IB3"/>
							<xsd:enumeration value="VI5"/>
							<xsd:enumeration value="AM1"/>
							<xsd:enumeration value="AM2"/>
							<xsd:enumeration value="AM3"/>
							<xsd:enumeration value="SB1"/>
							<xsd:enumeration value="SC1"/>
							<xsd:enumeration value="SC2"/>
							<xsd:enumeration value="SI1"/>
							<xsd:enumeration value="SI2"/>
							<xsd:enumeration value="SI3"/>
							<xsd:enumeration value="SM1"/>
							<xsd:enumeration value="SM2"/>
							<xsd:enumeration value="SM3"/>
							<xsd:enumeration value="SQ1"/>
							<xsd:enumeration value="SQ2"/>
							<xsd:enumeration value="SQ3"/>
							<xsd:enumeration value="SU2"/>
							<xsd:enumeration value="SU3"/>
							<xsd:enumeration value="SU5"/>
							<xsd:enumeration value="F11"/>
							<xsd:enumeration value="F12"/>
							<xsd:enumeration value="B11"/>
							<xsd:enumeration value="B12"/>
							<xsd:enumeration value="F21"/>
							<xsd:enumeration value="F22"/>
							<xsd:enumeration value="F23"/>
							<xsd:enumeration value="F24"/>
							<xsd:enumeration value="F25"/>
							<xsd:enumeration value="C21"/>
							<xsd:enumeration value="C22"/>
							<xsd:enumeration value="C23"/>
							<xsd:enumeration value="C24"/>
							<xsd:enumeration value="C25"/>
							<xsd:enumeration value="B21"/>
							<xsd:enumeration value="B22"/>
							<xsd:enumeration value="B23"/>
							<xsd:enumeration value="B24"/>
							<xsd:enumeration value="B25"/>
							<xsd:enumeration value="FX1"/>
							<xsd:enumeration value="FX3"/>
							<xsd:enumeration value="CX1"/>
							<xsd:enumeration value="CX2"/>
							<xsd:enumeration value="CX3"/>
							<xsd:enumeration value="BX1"/>
							<xsd:enumeration value="BX2"/>
							<xsd:enumeration value="BX3"/>
							<xsd:enumeration value="F31"/>
							<xsd:enumeration value="F32"/>
							<xsd:enumeration value="F33"/>
							<xsd:enumeration value="C31"/>
							<xsd:enumeration value="C32"/>
							<xsd:enumeration value="C33"/>
							<xsd:enumeration value="B31"/>
							<xsd:enumeration value="B32"/>
							<xsd:enumeration value="B33"/>
							<xsd:enumeration value="F41"/>
							<xsd:enumeration value="F42"/>
							<xsd:enumeration value="F43"/>
							<xsd:enumeration value="E11"/>
							<xsd:enumeration value="E12"/>
							<xsd:enumeration value="E13"/>
							<xsd:enumeration value="E14"/>
							<xsd:enumeration value="E15"/>
							<xsd:enumeration value="E21"/>
							<xsd:enumeration value="E22"/>
							<xsd:enumeration value="E23"/>
							<xsd:enumeration value="E31"/>
							<xsd:enumeration value="E32"/>
							<xsd:enumeration value="E34"/>
							<xsd:enumeration value="E35"/>
							<xsd:enumeration value="EW3"/>
							<xsd:enumeration value="EW4"/>
							<xsd:enumeration value="EW5"/>
							<xsd:enumeration value="BC1"/>
							<xsd:enumeration value="BC2"/>
							<xsd:enumeration value="BC3"/>
							<xsd:enumeration value="SD1"/>
							<xsd:enumeration value="SD2"/>
							<xsd:enumeration value="SD3"/>
							<xsd:enumeration value="SE1"/>
							<xsd:enumeration value="SE2"/>
							<xsd:enumeration value="SE3"/>
							<xsd:enumeration value="SF1"/>
							<xsd:enumeration value="SF2"/>
							<xsd:enumeration value="SG1"/>
							<xsd:enumeration value="SG2"/>
							<xsd:enumeration value="SH1"/>
							<xsd:enumeration value="SH2"/>
							<xsd:enumeration value="SJ1"/>
							<xsd:enumeration value="SJ2"/>
							<xsd:enumeration value="SK1"/>
							<xsd:enumeration value="SK2"/>
							<xsd:enumeration value="SK3"/>
							<xsd:enumeration value="SK4"/>
							<xsd:enumeration value="SL1"/>
							<xsd:enumeration value="SN1"/>
							<xsd:enumeration value="SN2"/>
							<xsd:enumeration value="SN3"/>
							<xsd:enumeration value="SN4"/>
							<xsd:enumeration value="SP"/>
							<xsd:enumeration value="SR1"/>
							<xsd:enumeration value="SR2"/>
							<xsd:enumeration value="SR3"/>
							<xsd:enumeration value="C51"/>
							<xsd:enumeration value="C52"/>
							<xsd:enumeration value="C53"/>
							<xsd:enumeration value="T51"/>
							<xsd:enumeration value="T52"/>
							<xsd:enumeration value="T53"/>
							<xsd:enumeration value="R51"/>
							<xsd:enumeration value="R52"/>
							<xsd:enumeration value="R53"/>
							<xsd:enumeration value="I51"/>
							<xsd:enumeration value="I52"/>
							<xsd:enumeration value="I53"/>
							<xsd:enumeration value="DV1"/>
							<xsd:enumeration value="DV2"/>
							<xsd:enumeration value="DV3"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:element>
				<!-- U.S. Immigrant Status Description -->
				<xsd:element name="USImmigrationStatusDesc">
					<xsd:annotation>
						<xsd:documentation>
							<Description>U.S. immigrant status description</Description>
							<LineNumber>Line E</LineNumber>
						</xsd:documentation>
					</xsd:annotation>
					<xsd:simpleType>
						<xsd:restriction base="TextType">
							<xsd:maxLength value="50"/>
						</xsd:restriction>
					</xsd:simpleType>
				</xsd:element>
			</xsd:choice>
			<!-- U.S. Immigration Status Or Visa Type Changed Indicator -->
			<xsd:element name="USImmigrationStatVisaTypChgInd" type="BooleanType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>U.S. immigration status or visa type changed indicator</Description>
						<LineNumber>Line F</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Visa Change Date -->
			<xsd:element name="VisaChangeDt" type="DateType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Visa change date</Description>
						<LineNumber>Line F</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Visa Change Description -->
			<xsd:element name="VisaChangeDesc" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Visa change description</Description>
						<LineNumber>Line F</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="TextType">
						<xsd:maxLength value="50"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<!-- Resident Of Canada Working In U.S. Indicator -->
			<xsd:element name="CanadaResidentWorkInUSInd" type="CheckboxType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Resident of Canada working in U.S. indicator</Description>
						<LineNumber>Line G</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Resident Of Mexico Working In U.S. Indicator -->
			<xsd:element name="MexicoResidentWorkInUSInd" type="CheckboxType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Resident of Mexico working in U.S. indicator</Description>
						<LineNumber>Line G</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Entered/Departed U.S. -->
			<xsd:element name="EnteredDepartedUSGrp" minOccurs="0" maxOccurs="25">
				<xsd:complexType>
					<xsd:sequence>
						<!-- Entered U.S. Date -->
						<xsd:element name="EnteredUSDt" type="DateType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Entered U.S. date</Description>
									<LineNumber>Line G</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
						<!-- Departed U.S. date -->
						<xsd:element name="DepartedUSDt" type="DateType" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Departed U.S. date</Description>
									<LineNumber>Line G</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<!-- Number Of Days Physically Present In U.S. Count -->
			<xsd:element name="PhysicallyPresUSPYLess2DayCnt" type="NumberOfDaysType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Number of days physically present in U.S. count</Description>
						<LineNumber>Line H</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Number Of Days Physically Present In U.S. Count -->
			<xsd:element name="PhysicallyPresUSPYLess1DayCnt" type="NumberOfDaysType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Number of days physically present in U.S. count</Description>
						<LineNumber>Line H</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Number Of Days Physically Present In U.S. Count -->
			<xsd:element name="PhysicallyPresUSPYDayCnt" type="NumberOfDaysType">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Number of days physically present in U.S. count</Description>
						<LineNumber>Line H</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- U.S. Tax Return Filed For Any Prior Year Indicator -->
			<xsd:element name="USTaxRetFiledForAnyPYInd" type="BooleanType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>U.S. tax return filed for any prior year indicator</Description>
						<LineNumber>Line I</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Latest Year You Filed A U.S. Return -->
			<xsd:element name="ReturnFiledYr" type="YearType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Latest year you filed a U.S. return</Description>
						<LineNumber>Line I</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Form Type Code -->
			<xsd:element name="FormTypeCd" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Form type code</Description>
						<LineNumber>Line I</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:simpleType>
					<xsd:restriction base="TextType">
						<xsd:enumeration value="1040"/>
						<xsd:enumeration value="1040A"/>
						<xsd:enumeration value="1040EZ"/>
						<xsd:enumeration value="1040NR"/>
						<xsd:enumeration value="1040NR-EZ"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
			<!-- Grantor Trust Distribution Or Loan Or Contribution Indicator -->
			<!-- Element not needed for this release
			<xsd:element name="GrantorTrDistriLoanOrContriInd" type="BooleanType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Grantor trust distribution or loan or contribution indicator</Description>
						<LineNumber>Line J</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			-->
			<!-- Total Compensation Of $250,000 Or More Indicator -->
			<xsd:element name="TotalComp250KOrMoreInd" type="BooleanType" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Total compensation of $250,000 or more indicator</Description>
						<LineNumber>Line K</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<!-- Alternative Method Used To Determine Source Of Compensation Indicator -->
			<xsd:element name="AltBasisCompensationSourceInd" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>
						<Description>Alternative method used to determine source of compensation indicator</Description>
						<LineNumber>Line K</LineNumber>
					</xsd:documentation>
				</xsd:annotation>
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="BooleanType">
							<xsd:attribute name="referenceDocumentId" type="IdListType"/>
							<xsd:attribute name="referenceDocumentName" type="TextType" fixed="AltBasisCompensationSourceStatement"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<!-- Australia Treaty -->
			<xsd:element name="AustraliaTreatyGrp" minOccurs="0" maxOccurs="5">
				<xsd:complexType>
					<xsd:sequence>
						<!-- Country Code -->
						<xsd:element name="CountryCd">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Country code</Description>
									<LineNumber>Line L1(a)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="CountryType">
									<xsd:enumeration value="AS"/>
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:element>
						<!-- Tax Treaty Article Code -->
						<xsd:element name="TaxTreatyArticleCd">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Tax treaty article code</Description>
									<LineNumber>Line L1(b)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="TextType">
									<xsd:enumeration value="14"/>
									<xsd:enumeration value="15"/>
									<xsd:enumeration value="17"/>
									<xsd:enumeration value="19"/>
									<xsd:enumeration value="20"/>
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:element>
						<!-- Number Of Months For Which Exemption Was Claimed In Prior Tax Years -->
						<xsd:element name="MnthExemptClmPriorTYNum" minOccurs="0">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Number of months for which exemption was claimed in prior tax years</Description>
									<LineNumber>Line L1(c)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="IntegerType">
									<xsd:totalDigits value="3"/>
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:element>
						<!-- Exempt Income In Current Tax Year Amount -->
						<xsd:element name="ExemptIncomeCurrentTYAmt" type="USAmountType">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Exempt income in current tax year amount</Description>
									<LineNumber>Line L1(d)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
						</xsd:element>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<!-- Austria Treaty -->
			<xsd:element name="AustriaTreatyGrp" minOccurs="0" maxOccurs="5">
				<xsd:complexType>
					<xsd:sequence>
						<!-- Country Code -->
						<xsd:element name="CountryCd">
							<xsd:annotation>
								<xsd:documentation>
									<Description>Country code</Description>
									<LineNumber>Line L1(a)</LineNumber>
								</xsd:documentation>
							</xsd:annotation>
							<xsd:simpleType>
								<xsd:restriction base="CountryType">
									<xsd:enumeration value="AU"/>
								</xsd:restriction>
							</xsd:simpleType>
						</xsd:element>
						<!-- Tax Treaty Article Code -->
						<xsd:element name="TaxTreatyArticleCd">
